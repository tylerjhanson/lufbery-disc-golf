---
import { siteBanner } from "../data/siteBanner.js";

const banner = siteBanner;
---

{banner.enabled && (
  <div
    id="siteBanner"
    class="site-banner"
    data-banner-id={banner.id}
    data-dismissible={banner.dismissible ? "true" : "false"}
  >
    <div class="site-banner-inner">
      <p class="site-banner-copy">
        {banner.label && <strong>{banner.label}</strong>}
        <span>{banner.message}</span>
      </p>

      {banner.dismissible && (
        <button class="site-banner-close" type="button" aria-label="Dismiss banner">
          ×
        </button>
      )}
    </div>
  </div>
)}

<script>
  const banner = document.getElementById("siteBanner");

  if (banner) {
    const bannerId = banner.dataset.bannerId;
    const dismissible = banner.dataset.dismissible === "true";
    const storageKey = `lufbery-site-banner-dismissed-${bannerId}`;

    if (bannerId && localStorage.getItem(storageKey) === "true") {
      banner.remove();
    }

    const closeButton = banner.querySelector(".site-banner-close");

    closeButton?.addEventListener("click", () => {
      if (dismissible && bannerId) {
        localStorage.setItem(storageKey, "true");
      }

      banner.remove();
    });
  }
</script>

<style>
  .site-banner {
    width: 100%;
    background: #b91c1c;
    color: #ffffff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    position: relative;
    z-index: 70;
  }

  .site-banner-inner {
    width: min(100%, 1440px);
    margin: 0 auto;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }

  .site-banner-copy {
    min-width: 0;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
    line-height: 1.35;
  }

  .site-banner-copy strong {
    flex: 0 0 auto;
    font-weight: 800;
  }

  .site-banner-copy span {
    min-width: 0;
  }

  .site-banner-close {
    width: 32px;
    height: 32px;
    flex: 0 0 32px;
    border: 0;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.16);
    color: #ffffff;
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
  }

  .site-banner-close:hover,
  .site-banner-close:focus-visible {
    background: rgba(255, 255, 255, 0.28);
  }

  @media (max-width: 700px) {
    .site-banner-inner {
      padding: 9px 10px;
      align-items: flex-start;
      gap: 10px;
    }

    .site-banner-copy {
      display: block;
      font-size: 0.86rem;
    }

    .site-banner-copy strong {
      display: block;
      margin-bottom: 2px;
    }

    .site-banner-close {
      width: 30px;
      height: 30px;
      flex-basis: 30px;
    }
  }
</style>
