---

<section class="hole-chart">
  {holes.map((hole) => (
    <article class="hole-card">
      <div class="hole-card__header">
        <h3>Hole {hole.hole}</h3>
        <div class="hole-card__stats">
          <span>Difficulty <strong>{hole.difficultyRank}</strong></span>
          <span>Avg <strong>{hole.average.toFixed(2)}</strong></span>
        </div>
      </div>

      <div
        class="score-bar"
        style={`grid-template-columns:${hole.segments.map((segment) => `${segment.count}fr`).join(" ")};`}
        aria-label={`Hole ${hole.hole} scoring distribution`}
      >
        {hole.segments.map((segment) => {
          const showLabel = segment.pct >= 7;

          return (
            <div
              class={`score-bar__segment score-bar__segment--${segment.kind}`}
              title={`${segment.label}: ${segment.count}`}
              aria-label={`${segment.label}: ${segment.count}`}
            >
              {showLabel && <span class="score-bar__label">{segment.count}</span>}
            </div>
          );
        })}
      </div>
    </article>
  ))}
</section>

<style>
  .hole-chart {
    --hd-card-bg: #f7f9fc;
    --hd-card-border: #d7e6f3;
    --hd-card-shadow: 0 1px 0 rgba(15, 23, 42, 0.03);
    --hd-title: var(--text, #1f2937);
    --hd-muted: var(--muted, #6b7280);
    --hd-bar-bg: #ffffff;
    --hd-bar-border: #cfe0ef;
    --hd-bar-divider: rgba(22, 34, 51, 0.08);
    --hd-par-fill: #ffffff;
    --hd-par-label: #2e3440;
    --hd-warm-label: #2e3440;
    display: grid;
    gap: 8px;
  }

  html[data-theme="dark"] .hole-chart {
    --hd-card-bg: #111b2d;
    --hd-card-border: #31445f;
    --hd-card-shadow: 0 1px 0 rgba(255, 255, 255, 0.03);
    --hd-title: var(--text, #f8fafc);
    --hd-muted: var(--muted, #94a3b8);
    --hd-bar-bg: #0d1625;
    --hd-bar-border: #2e425d;
    --hd-bar-divider: rgba(255, 255, 255, 0.06);
    --hd-par-fill: #172233;
    --hd-par-label: #e8eff9;
    --hd-warm-label: #2b3441;
  }

  @media (prefers-color-scheme: dark) {
    html[data-theme="system"] .hole-chart {
      --hd-card-bg: #111b2d;
      --hd-card-border: #31445f;
      --hd-card-shadow: 0 1px 0 rgba(255, 255, 255, 0.03);
      --hd-title: var(--text, #f8fafc);
      --hd-muted: var(--muted, #94a3b8);
      --hd-bar-bg: #0d1625;
      --hd-bar-border: #2e425d;
      --hd-bar-divider: rgba(255, 255, 255, 0.06);
      --hd-par-fill: #172233;
      --hd-par-label: #e8eff9;
      --hd-warm-label: #2b3441;
    }
  }

  .hole-card {
    border: 2px solid var(--hd-card-border);
    border-radius: 16px;
    background: var(--hd-card-bg);
    padding: 10px 14px;
    box-shadow: var(--hd-card-shadow);
  }

  .hole-card__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 6px;
  }

  .hole-card__header h3 {
    margin: 0;
    font-size: clamp(1.08rem, 1.45vw, 1.34rem);
    line-height: 1;
    color: var(--hd-title);
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .hole-card__stats {
    display: flex;
    align-items: baseline;
    gap: 14px;
    color: var(--hd-muted);
    font-size: clamp(0.86rem, 0.96vw, 0.96rem);
    white-space: nowrap;
  }

  .hole-card__stats span {
    display: inline-flex;
    align-items: baseline;
    gap: 5px;
  }

  .hole-card__stats strong {
