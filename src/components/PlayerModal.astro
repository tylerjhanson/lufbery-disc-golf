---
interface Props {
  profiles: Record<string, unknown>;
}

const { profiles = {} } = Astro.props;
const profileJson = JSON.stringify(profiles).replace(/</g, "\\u003c");
---

<style is:global>
  .player-button {
    appearance: none;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    font-weight: inherit;
    padding: 0;
    margin: 0;
    cursor: pointer;
    text-align: left;
    text-decoration-line: underline !important;
    text-decoration-style: dotted !important;
    text-decoration-thickness: 1px !important;
    text-decoration-color: color-mix(in srgb, currentColor 24%, transparent) !important;
    text-underline-offset: 2px;
    transition: color 0.15s ease, text-decoration-color 0.15s ease;
  }

  .player-button:hover,
  .player-button:focus-visible {
    color: var(--accent, #2563eb);
    text-decoration-color: color-mix(in srgb, currentColor 42%, transparent) !important;
    outline: none;
  }

  .player-link-stack {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  .player-link-inline {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
  }

  .player-link-inline .player-button {
    display: inline;
  }

  .player-details-modal[hidden] {
    display: none;
  }

  .player-details-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
  }

  .player-details-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(2px);
  }

  .player-details-modal-panel {
    position: relative;
    z-index: 1;
    width: min(92vw, 560px);
    margin: 6vh auto 0;
    background: var(--card, #ffffff);
    border: 1px solid var(--line-soft, #eef2f7);
    border-radius: 22px;
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.22);
    max-height: 88vh;
    overflow-y: auto;
    padding: 0;
  }

  .player-details-modal-header {
    position: sticky;
    top: 0;
    z-index: 8;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 18px 18px 14px;
    background: var(--card, #ffffff);
    border-bottom: 1px solid var(--line-soft, #eef2f7);
    border-top-left-radius: 22px;
    border-top-right-radius: 22px;
  }

  .player-details-modal-title {
    margin: 0;
    font-size: 1.12rem;
    line-height: 1.2;
    font-weight: 800;
    flex: 1 1 auto;
    min-width: 0;
    padding-top: 4px;
  }

  .player-details-modal-close {
    width: 40px;
    height: 40px;
    border: 1px solid var(--line-soft, #e6edf5);
    border-radius: 10px;
    background: var(--card, #ffffff);
    color: var(--text, #111827);
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    flex: 0 0 auto;
  }

  .player-details-modal-close:hover {
    color: var(--text, #111827);
    background: var(--button-bg-hover, #eceff4);
  }

  #playerDetailsModalBody {
    padding: 0 18px 16px;
  }

  .player-details-section {
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--line-soft, #eef2f7);
  }

  .player-details-section-label {
    margin: 0 0 10px;
    font-size: 0.84rem;
    font-weight: 800;
    line-height: 1.2;
    color: var(--text, #111827);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .player-details-history-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
  }

  .player-details-history-table th,
  .player-details-history-table td {
    padding: 10px 0;
    border-bottom: 1px solid var(--line-soft, #eef2f7);
    font-size: 0.98rem;
    text-align: left;
  }

  .player-details-history-table thead th {
    position: static;
    background: transparent;
    border-bottom: 1px solid var(--line-soft, #eef2f7);
    color: var(--text, #111827);
    font-size: 0.82rem;
    text-transform: none;
    letter-spacing: 0;
    padding-top: 0;
    padding-bottom: 8px;
  }

  .player-details-history-table th:last-child,
  .player-details-history-table td:last-child {
    text-align: right;
  }

  .player-details-summary-grid {
    display: grid;
    gap: 10px 14px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 16px;
    margin-bottom: 8px;
  }

  .player-details-summary-row {
    font-size: 0.98rem;
    line-height: 1.35;
    color: var(--text, #111827);
  }

  .player-details-summary-row strong {
    font-weight: 800;
  }

  .player-details-summary-stack {
    display: grid;
    gap: 4px;
    margin-top: 2px;
  }

  .player-details-summary-item {
    font-size: 0.94rem;
    line-height: 1.35;
  }

  .player-details-chart-shell {
    position: relative;
    margin-top: 0;
    margin-bottom: 10px;
    padding: 4px 4px 18px;
    border: 0;
    border-radius: 14px;
    background: transparent;
    touch-action: manipulation;
  }

  .player-details-chart-svg {
    display: block;
    width: 100%;
    height: 190px;
    overflow: visible;
    cursor: crosshair;
  }

  .player-details-chart-grid {
    stroke: var(--line-soft, #eef2f7);
    stroke-width: 1;
    opacity: 0.72;
    vector-effect: non-scaling-stroke;
  }

  .player-details-chart-axis-label {
    fill: var(--muted, #6b7280);
    font-size: 11px;
    font-family: Inter, Arial, Helvetica, sans-serif;
  }

  .player-details-chart-line-player {
    fill: none;
    stroke: var(--accent, #2563eb);
    stroke-width: 2.35;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  .player-details-chart-line-trend {
    fill: none;
    stroke: var(--muted, #6b7280);
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-dasharray: 5 5;
    opacity: 0.42;
    vector-effect: non-scaling-stroke;
  }

  .player-details-chart-active-line {
    stroke: var(--muted, #6b7280);
    stroke-width: 1;
    stroke-dasharray: 3 4;
    opacity: 0;
    pointer-events: none;
    vector-effect: non-scaling-stroke;
  }

  .player-details-chart-active-dot {
    fill: var(--card, #ffffff);
    stroke: var(--accent, #2563eb);
    stroke-width: 2.25;
    opacity: 0;
    pointer-events: none;
    vector-effect: non-scaling-stroke;
  }

  .player-details-chart-point {
    fill: var(--accent, #2563eb);
    stroke: var(--card, #ffffff);
    stroke-width: 1.6;
    opacity: 0;
    transition: opacity 0.12s ease, r 0.12s ease;
    vector-effect: non-scaling-stroke;
  }

  .player-details-chart-hit-area {
    fill: transparent;
    stroke: transparent;
    cursor: pointer;
  }

  .player-details-chart-point-group:hover .player-details-chart-point,
  .player-details-chart-point-group:focus .player-details-chart-point,
  .player-details-chart-point-group:focus-visible .player-details-chart-point,
  .player-details-chart-shell[data-chart-active="true"] .player-details-chart-active-line,
  .player-details-chart-shell[data-chart-active="true"] .player-details-chart-active-dot {
    opacity: 1;
  }

  .player-details-chart-tooltip {
    position: absolute;
    left: 0;
    top: 0;
    z-index: 5;
    min-width: 132px;
    max-width: min(230px, 78vw);
    padding: 8px 10px;
    border: 1px solid var(--line-soft, #e5e7eb);
    border-radius: 10px;
    background: var(--card, #ffffff);
    color: var(--text, #111827);
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.14);
    font-size: 0.82rem;
    line-height: 1.25;
    font-weight: 700;
    opacity: 0;
    transform: translate(-50%, calc(-100% - 10px));
    pointer-events: none;
    white-space: normal;
    transition: opacity 0.12s ease;
  }

  .player-details-chart-tooltip span {
    display: block;
    margin-top: 2px;
    color: var(--muted, #6b7280);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .player-details-chart-shell[data-chart-active="true"] .player-details-chart-tooltip {
    opacity: 1;
  }

  .player-details-muted {
    color: var(--muted, #6b7280);
    font-weight: 600;
  }

  .player-details-note {
    margin: 12px 0 0;
    color: var(--muted, #6b7280);
    font-size: 0.83rem;
    line-height: 1.35;
  }

  .player-details-chart-note {
    margin: -8px 0 10px;
    color: var(--muted, #6b7280);
    font-size: 0.78rem;
    line-height: 1.3;
  }

  .player-details-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }

  .player-details-list-item {
    font-size: 0.95rem;
    line-height: 1.35;
  }

  .player-details-link {
    color: var(--accent, #2563eb);
    text-decoration: none;
    font-weight: 600;
  }

  .player-details-link:hover {
    text-decoration: underline;
  }

  .player-details-link-inline {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .player-details-udisc-icon {
    height: 0.82em;
    width: auto;
    display: inline-block;
    vertical-align: middle;
    flex: 0 0 auto;
    opacity: 0.98;
    transform: translateY(-0.11em);
  }

  .player-details-year-stats {
    margin: 0;
    display: grid;
    gap: 6px;
  }

  .player-details-year-stats-title {
    font-size: 0.84rem;
    font-weight: 800;
    color: var(--muted, #6b7280);
    line-height: 1.2;
  }

  .player-details-year-stats-list {
    display: grid;
    gap: 4px;
  }

  .player-details-year-stats-item {
    font-size: 0.92rem;
    line-height: 1.35;
    color: var(--text, #111827);
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .player-details-chart-tooltip {
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.32);
    }
  }

  [data-theme="dark"] .player-details-chart-tooltip {
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.32);
  }

  @media (max-width: 700px) {
    .player-details-modal-panel {
      width: min(94vw, 560px);
      margin-top: 4vh;
      border-radius: 20px;
    }

    .player-details-modal-header {
      top: 0;
      gap: 10px;
      padding: 16px 14px 12px;
      border-top-left-radius: 20px;
      border-top-right-radius: 20px;
    }

    #playerDetailsModalBody {
      padding: 0 14px 14px;
    }

    .player-details-modal-title {
      font-size: 1.05rem;
    }

    .player-details-chart-svg {
      height: 160px;
    }

    .player-details-chart-hit-area {
      r: 17;
    }

    .player-details-history-table th,
    .player-details-history-table td {
      font-size: 0.92rem;
      padding: 9px 0;
    }

    .player-details-summary-grid {
      grid-template-columns: 1fr;
    }

    .player-details-chart-axis-label {
      font-size: 10px;
    }

    .player-details-chart-tooltip {
      min-width: 124px;
      font-size: 0.78rem;
    }
  }
</style>

<script
  id="playerDetailsProfilesData"
  type="application/json"
  set:html={profileJson}
></script>

<div id="playerDetailsModal" class="player-details-modal" hidden>
  <div class="player-details-modal-backdrop" data-close-player-modal></div>

  <div
    id="playerDetailsModalPanel"
    class="player-details-modal-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="playerDetailsModalTitle"
  >
    <div class="player-details-modal-header">
      <h2 id="playerDetailsModalTitle" class="player-details-modal-title">Player details</h2>
      <button
        id="playerDetailsModalClose"
        class="player-details-modal-close"
        type="button"
        aria-label="Close player details popup"
      >
        ×
      </button>
    </div>

    <div id="playerDetailsModalBody"></div>
  </div>
</div>

<script is:inline>
  const HANDICAP_PAR = 56;

  const playerProfilesDataEl = document.getElementById("playerDetailsProfilesData");
  let PLAYER_PROFILES = {};

  try {
    PLAYER_PROFILES = JSON.parse(playerProfilesDataEl?.textContent || "{}");
  } catch (error) {
    console.error("Failed to parse player profile data.", error);
    PLAYER_PROFILES = {};
  }

  const playerDetailsModal = document.getElementById("playerDetailsModal");
  const playerDetailsModalPanel = document.getElementById("playerDetailsModalPanel");
  const playerDetailsModalTitle = document.getElementById("playerDetailsModalTitle");
  const playerDetailsModalBody = document.getElementById("playerDetailsModalBody");
  const playerDetailsModalClose = document.getElementById("playerDetailsModalClose");

  let lastPlayerTrigger = null;

  function escapeHtml(value) {
    return String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function cleanText(value) {
    return String(value ?? "").replace(/\s+/g, " ").trim();
  }

  function getPlayerKey(value) {
    return cleanText(value).toLowerCase();
  }

  function isUdiscUrl(value) {
    return /(^https?:\/\/)?(www\.)?udisc\.com\b/i.test(String(value || "").trim());
  }

  function getResolvedThemeMode() {
    const mode = document.documentElement.getAttribute("data-theme") || "system";

    if (mode === "dark") return "dark";
    if (mode === "light") return "light";

    return window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light";
  }

  function getUdiscIconSrc() {
    return getResolvedThemeMode() === "dark" ? "/udisc-icon-white.png" : "/udisc-icon.png";
  }

  function renderUdiscIconMarkup(href) {
    if (!isUdiscUrl(href)) return "";

    return `
      <img
        class="player-details-udisc-icon"
        src="${getUdiscIconSrc()}"
        alt="UDisc"
        loading="lazy"
        decoding="async"
      />
    `;
  }

  function renderLinkedLabel(href, label) {
    const safeLabel = escapeHtml(label);

    if (!href) return safeLabel;

    return `<a class="player-details-link player-details-link-inline" href="${escapeHtml(
      href
    )}">${safeLabel}${renderUdiscIconMarkup(href)}</a>`;
  }

  function formatRelativeToPar(score) {
    const numericScore = Number(score);
    const diff = numericScore - HANDICAP_PAR;

    if (!Number.isFinite(numericScore)) return "";
    if (diff === 0) return "E";
    if (diff > 0) return `+${diff}`;
    return `${diff}`;
  }

  function formatScoreWithPar(score) {
    const numericScore = Number(score);
    if (!Number.isFinite(numericScore)) return "";

    return `${numericScore} (${formatRelativeToPar(numericScore)})`;
  }

  function parseDisplayYear(value) {
    const parts = String(value || "").split("/");
    let year = Number(parts[2] || 0);
    if (year < 100) year += 2000;
    return year;
  }

  function parseUsDate(value) {
    const match = String(value || "").match(/(\d{1,2})\/(\d{1,2})\/(\d{2,4})/);
    if (!match) return new Date(0);

    let year = Number(match[3]);
    if (year < 100) year += 2000;

    return new Date(year, Number(match[1]) - 1, Number(match[2]));
  }

  function formatCurrentUsDate() {
    const now = new Date();
    return `${now.getMonth() + 1}/${now.getDate()}/${now.getFullYear()}`;
  }

  function buildTrendValues(rounds) {
    if (!rounds || rounds.length < 2) return [];

    const n = rounds.length;
    let sumX = 0;
    let sumY = 0;
    let sumXY = 0;
    let sumXX = 0;

    rounds.forEach((round, index) => {
      const y = Number(round.score);
      sumX += index;
      sumY += y;
      sumXY += index * y;
      sumXX += index * index;
    });

    const denominator = n * sumXX - sumX * sumX;
    if (!denominator) return [];

    const slope = (n * sumXY - sumX * sumY) / denominator;
    const intercept = (sumY - slope * sumX) / n;

    return rounds.map((_, index) => intercept + slope * index);
  }

  function formatOneDecimal(value) {
    return Number(value).toFixed(1);
  }

  function formatChartValue(value) {
    const numericValue = Number(value);
    if (!Number.isFinite(numericValue)) return "";

    return Number.isInteger(numericValue) ? String(numericValue) : numericValue.toFixed(1);
  }

  function buildYearlyScoreAverages(rounds) {
    if (!Array.isArray(rounds) || !rounds.length) return [];

    const buckets = new Map();

    rounds.forEach((round) => {
      const year = parseDisplayYear(round?.date);
      const score = Number(round?.score);
      if (!Number.isFinite(year) || year < 2021 || Number.isNaN(score)) return;

      const bucket = buckets.get(year) || [];
      bucket.push(score);
      buckets.set(year, bucket);
    });

    return Array.from(buckets.entries())
      .sort((a, b) => a[0] - b[0])
      .map(([year, scores]) => ({
        year: String(year),
        value: formatOneDecimal(scores.reduce((sum, score) => sum + score, 0) / scores.length),
      }));
  }

  function buildEffectiveHandicapHistory(history, currentHandicap) {
    const baseHistory = Array.isArray(history)
      ? history
          .map((row) => ({
            date: String(row?.date || ""),
            handicap: Number(row?.handicap),
          }))
          .filter((row) => row.date && !Number.isNaN(row.handicap))
      : [];

    const current = Number(currentHandicap);
    if (Number.isNaN(current)) return baseHistory;

    if (!baseHistory.length) {
      return [
        {
          date: formatCurrentUsDate(),
          handicap: current,
        },
      ];
    }

    const lastPoint = baseHistory[baseHistory.length - 1];
    if (Number(lastPoint?.handicap) === current) {
      return baseHistory;
    }

    return [
      ...baseHistory,
      {
        date: formatCurrentUsDate(),
        handicap: current,
      },
    ];
  }

  function buildYearlyBestHandicaps(history) {
    if (!Array.isArray(history) || !history.length) return [];

    const bestByYear = new Map();

    history.forEach((row) => {
      const year = parseDisplayYear(row?.date);
      const handicap = Number(row?.handicap);

      if (!Number.isFinite(year) || year < 2023 || Number.isNaN(handicap)) return;

      const current = bestByYear.get(year);
      if (current == null || handicap < current) {
        bestByYear.set(year, handicap);
      }
    });

    return Array.from(bestByYear.entries())
      .sort((a, b) => a[0] - b[0])
      .map(([year, handicap]) => ({
        year: String(year),
        value: String(handicap),
      }));
  }

  function getLowestHandicap(history, currentHandicap) {
    const values = [];

    if (Array.isArray(history)) {
      values.push(
        ...history
          .map((row) => Number(row?.handicap))
          .filter((value) => !Number.isNaN(value))
      );
    }

    const current = Number(currentHandicap);
    if (!Number.isNaN(current)) {
      values.push(current);
    }

    if (!values.length) return "";

    return String(Math.min(...values));
  }

  function buildYearlyBestTags(history) {
    if (!Array.isArray(history) || !history.length) return [];

    const bestByYear = new Map();

    history.forEach((row) => {
      const year = parseDisplayYear(row?.date);
      const tag = Number(row?.tag);
      if (!Number.isFinite(year) || year < 2023 || Number.isNaN(tag)) return;

      const current = bestByYear.get(year);
      if (current == null || tag < current) {
        bestByYear.set(year, tag);
      }
    });

    return Array.from(bestByYear.entries())
      .sort((a, b) => a[0] - b[0])
      .map(([year, tag]) => ({
        year: String(year),
        value: String(tag),
      }));
  }

  function renderYearStats(title, rows) {
    if (!rows || !rows.length) return "";

    return `
      <div class="player-details-year-stats">
        <div class="player-details-year-stats-title">${escapeHtml(title)}</div>
        <div class="player-details-year-stats-list">
          ${rows
            .map(
              (row) =>
                `<div class="player-details-year-stats-item"><strong>${escapeHtml(
                  row.year
                )}:</strong> ${escapeHtml(row.value)}</div>`
            )
            .join("")}
        </div>
      </div>
    `;
  }

  function buildLineChart(values, ariaLabel, lowerValuesAtBottom = false, options = {}) {
    const cleanValues = Array.isArray(values)
      ? values
          .map((point) => ({
            ...point,
            value: Number(point?.value),
          }))
          .filter((point) => !Number.isNaN(point.value))
      : [];

    if (!cleanValues.length) return "";

    const numericValues = cleanValues.map((point) => Number(point.value));

    const width = 640;
    const height = 210;
    const padTop = 16;
    const padRight = 16;
    const padBottom = 22;
    const padLeft = 40;
    const innerWidth = width - padLeft - padRight;
    const innerHeight = height - padTop - padBottom;

    const fixedStep = Number(options.step);
    const useFixedStep = Number.isFinite(fixedStep) && fixedStep > 0;

    let chartMin = Math.min(...numericValues);
    let chartMax = Math.max(...numericValues);

    if (useFixedStep) {
      const minBase = Number.isFinite(Number(options.min)) ? Number(options.min) : 0;
      chartMin = Math.min(minBase, chartMin);
      chartMin = Math.floor(chartMin / fixedStep) * fixedStep;
      chartMax = Math.ceil(chartMax / fixedStep) * fixedStep;
      if (chartMax <= chartMin) chartMax = chartMin + fixedStep;
    } else {
      if (chartMin === chartMax) chartMax = chartMin + 1;

      const range = chartMax - chartMin;
      const step = range <= 10 ? 1 : range <= 30 ? 5 : 10;

      chartMin = Math.max(1, Math.floor(chartMin / step) * step);
      chartMax = Math.ceil(chartMax / step) * step;

      if (chartMin === chartMax) chartMax = chartMin + step;
    }

    const tickStep = useFixedStep
      ? fixedStep
      : (() => {
          const range = chartMax - chartMin;
          return range <= 10 ? 1 : range <= 30 ? 5 : 10;
        })();

    const ticks = [];
    for (let value = chartMin; value <= chartMax + tickStep / 2; value += tickStep) {
      ticks.push(value);
    }

    const getX = (index) =>
      cleanValues.length === 1
        ? padLeft + innerWidth / 2
        : padLeft + (index / (cleanValues.length - 1)) * innerWidth;

    const getY = (value) =>
      lowerValuesAtBottom
        ? padTop + ((chartMax - value) / (chartMax - chartMin)) * innerHeight
        : padTop + ((value - chartMin) / (chartMax - chartMin)) * innerHeight;

    const pointCoordinates = cleanValues.map((point, index) => ({
      ...point,
      x: getX(index),
      y: getY(Number(point.value)),
    }));

    const playerPoints = pointCoordinates
      .map((point) => `${point.x},${point.y}`)
      .join(" ");

    const showTrend = options.showTrend !== false;
    const trendValues = showTrend
      ? buildTrendValues(cleanValues.map((point) => ({ score: Number(point.value) })))
      : [];
    const trendPoints = trendValues.length
      ? trendValues.map((value, index) => `${getX(index)},${getY(value)}`).join(" ")
      : "";

    const gridMarkup = ticks
      .map((tick) => {
        const y = getY(tick);
        return `
          <line
            class="player-details-chart-grid"
            x1="${padLeft}"
            y1="${y}"
            x2="${width - padRight}"
            y2="${y}"
          />
          <text
            class="player-details-chart-axis-label"
            x="${padLeft - 8}"
            y="${y + 4}"
            text-anchor="end"
          >${escapeHtml(formatChartValue(tick))}</text>
        `;
      })
      .join("");

    const firstLabel = cleanValues[0]?.label || "";
    const lastLabel = cleanValues[cleanValues.length - 1]?.label || "";

    const xAxisMarkup =
      firstLabel || lastLabel
        ? `
          <text
            class="player-details-chart-axis-label"
            x="${padLeft}"
            y="${height - 3}"
            text-anchor="start"
          >${escapeHtml(firstLabel)}</text>
          <text
            class="player-details-chart-axis-label"
            x="${width - padRight}"
            y="${height - 3}"
            text-anchor="end"
          >${escapeHtml(lastLabel)}</text>
        `
        : "";

    const pointsMarkup = pointCoordinates
      .map((point) => {
        const title = point.title || point.label || "";
        const valueLabel = point.valueLabel || formatChartValue(point.value);
        const tooltip = point.detail || `${title}${title ? " — " : ""}${valueLabel}`;

        return `
          <g
            class="player-details-chart-point-group"
            tabindex="0"
            role="button"
            aria-label="${escapeHtml(tooltip)}"
            data-chart-title="${escapeHtml(title)}"
            data-chart-value="${escapeHtml(valueLabel)}"
            data-chart-tooltip="${escapeHtml(tooltip)}"
            data-chart-x="${point.x}"
            data-chart-y="${point.y}"
          >
            <circle
              class="player-details-chart-point"
              cx="${point.x}"
              cy="${point.y}"
              r="3.6"
            />
            <circle
              class="player-details-chart-hit-area"
              cx="${point.x}"
              cy="${point.y}"
              r="15"
            />
          </g>
        `;
      })
      .join("");

    return `
      <div class="player-details-chart-shell" data-player-chart>
        <svg
          class="player-details-chart-svg"
          viewBox="0 0 ${width} ${height}"
          preserveAspectRatio="none"
          aria-label="${escapeHtml(ariaLabel)}"
        >
          ${gridMarkup}
          ${xAxisMarkup}
          ${trendPoints ? `<polyline class="player-details-chart-line-trend" points="${trendPoints}" />` : ""}
          <polyline class="player-details-chart-line-player" points="${playerPoints}" />
          <line
            class="player-details-chart-active-line"
            x1="0"
            y1="${padTop}"
            x2="0"
            y2="${height - padBottom}"
          />
          <circle
            class="player-details-chart-active-dot"
            cx="0"
            cy="0"
            r="5"
          />
          ${pointsMarkup}
        </svg>
        <div class="player-details-chart-tooltip" aria-hidden="true"></div>
      </div>
    `;
  }

  function buildRoundChart(rounds) {
    if (!rounds || !rounds.length) return "";

    return buildLineChart(
      rounds.map((round) => {
        const score = Number(round.score);
        const date = String(round.date || "");
        const scoreText = formatScoreWithPar(score);

        return {
          value: score,
          label: date,
          title: date,
          valueLabel: `Score ${scoreText}`,
          detail: `${date} — Score ${scoreText}`,
        };
      }),
      "Score history chart",
      true
    );
  }

  function buildHandicapChart(history) {
    if (!history || !history.length) return "";

    const values = history
      .map((row) => ({
        date: String(row.date || ""),
        handicap: Number(row.handicap),
      }))
      .filter((row) => !Number.isNaN(row.handicap));

    if (!values.length) return "";

    const playerMin = Math.min(...values.map((row) => row.handicap));
    const chartMin = Math.floor(playerMin) - 1;

    return buildLineChart(
      values.map((row) => ({
        value: row.handicap,
        label: row.date,
        title: row.date,
        valueLabel: `Handicap ${formatChartValue(row.handicap)}`,
        detail: `${row.date} — Handicap ${formatChartValue(row.handicap)}`,
      })),
      "Handicap history chart",
      true,
      { step: 1, min: chartMin, showTrend: false }
    );
  }

  function buildTagChart(history) {
    if (!history || !history.length) return "";

    const values = history
      .map((row) => ({
        date: String(row.date || ""),
        tag: Number(row.tag),
      }))
      .filter((row) => !Number.isNaN(row.tag));

    return buildLineChart(
      values.map((row) => ({
        value: row.tag,
        label: row.date,
        title: row.date,
        valueLabel: `Tag #${formatChartValue(row.tag)}`,
        detail: `${row.date} — Tag #${formatChartValue(row.tag)}`,
      })),
      "Tag history chart",
      true,
      { step: 5, min: 0, showTrend: false }
    );
  }

  function renderLinkList(items, formatter, emptyText) {
    if (!items || !items.length) {
      return `<p class="player-details-note">${escapeHtml(emptyText)}</p>`;
    }

    return `
      <ul class="player-details-list">
        ${items.map((item) => `<li class="player-details-list-item">${formatter(item)}</li>`).join("")}
      </ul>
    `;
  }

  function renderPersonalBestMarkup(items) {
    if (!items || !items.length) {
      return `<span class="player-details-muted">—</span>`;
    }

    if (items.length === 1) {
      const item = items[0];
      return `<strong>${escapeHtml(item.score)}</strong> ${renderLinkedLabel(item.href, item.date)}`;
    }

    return `
      <div class="player-details-summary-stack">
        ${items
          .map(
            (item) =>
              `<div class="player-details-summary-item"><strong>${escapeHtml(
                item.score
              )}</strong> ${renderLinkedLabel(item.href, item.date)}</div>`
          )
          .join("")}
      </div>
    `;
  }

  function renderPlayerDetailsModal(profile, fallbackName) {
    if (!playerDetailsModalTitle || !playerDetailsModalBody) return;

    const name = profile?.name || fallbackName || "Player details";
    const recentRounds = Array.isArray(profile?.recentRounds) ? profile.recentRounds : [];
    const allRounds = Array.isArray(profile?.allRounds) ? profile.allRounds : [];
    const weeklyWins = Array.isArray(profile?.weeklyWins) ? profile.weeklyWins : [];
    const bestOverallWins = Array.isArray(profile?.bestOverallWins) ? profile.bestOverallWins : [];
    const aces = Array.isArray(profile?.aces) ? profile.aces : [];
    const average = profile?.average ? String(profile.average) : "";
    const handicap =
      profile?.handicap != null && String(profile.handicap) !== "" ? String(profile.handicap) : "";
    const established = Boolean(profile?.handicapEstablished);
    const currentTag = profile?.currentTag ? String(profile.currentTag) : "";
    const bestTagEver = profile?.bestTagEver ? String(profile.bestTagEver) : "";
    const averageTag = profile?.averageTag ? String(profile.averageTag) : "";
    const weeksAtOne = Number(profile?.weeksAtOne || 0);
    const hasTag = Boolean(profile?.hasTag);

    const handicapHistory = Array.isArray(profile?.handicapHistory)
      ? profile.handicapHistory.filter((row) => {
          const year = parseDisplayYear(row?.date);
          return year >= 2023;
        })
      : [];

    const effectiveHandicapHistory = buildEffectiveHandicapHistory(handicapHistory, handicap);
    const lowestHandicap = getLowestHandicap(handicapHistory, handicap);

    const tagHistory = Array.isArray(profile?.tagHistory)
      ? profile.tagHistory.filter((row) => {
          const year = parseDisplayYear(row?.date);
          return year >= 2023;
        })
      : [];

    const personalBests =
      Array.isArray(profile?.personalBests) && profile.personalBests.length
        ? profile.personalBests
        : profile?.personalBest
          ? [profile.personalBest]
          : [];

    playerDetailsModalTitle.textContent = name;

    const sortedRecentRounds = [...recentRounds].sort(
      (a, b) => parseUsDate(b.date).getTime() - parseUsDate(a.date).getTime()
    );

    const rowsHtml = sortedRecentRounds.length
      ? sortedRecentRounds
          .map((round) => {
            const droppedStyle = round.dropped
              ? 'style="text-decoration: line-through; text-decoration-thickness: 1.5px; color: var(--muted, #6b7280);"'
              : "";

            return `
              <tr>
                <td><span ${droppedStyle}>${escapeHtml(round.date)}</span></td>
                <td><span ${droppedStyle}>${escapeHtml(formatScoreWithPar(round.score))}</span></td>
              </tr>
            `;
          })
          .join("")
      : `
        <tr>
          <td colspan="2" class="player-details-muted">No handicap rounds found.</td>
        </tr>
      `;

    const scoreChartMarkup = allRounds.length
      ? `
          <div class="player-details-section">
            <p class="player-details-section-label">SCORE HISTORY (SINCE 2021)</p>
            ${buildRoundChart(allRounds)}
            <p class="player-details-chart-note">Hover on desktop or tap a point on mobile to see the exact date and value.</p>
            ${renderYearStats("Average by year", buildYearlyScoreAverages(allRounds))}
          </div>
        `
      : "";

    const handicapChartMarkup = effectiveHandicapHistory.length
      ? `
          <div class="player-details-section">
            <p class="player-details-section-label">HANDICAP HISTORY (SINCE 2023)</p>
            ${buildHandicapChart(effectiveHandicapHistory)}
            <p class="player-details-chart-note">Hover on desktop or tap a point on mobile to see the exact date and value.</p>
            ${renderYearStats("Best handicap by year", buildYearlyBestHandicaps(effectiveHandicapHistory))}
          </div>
        `
      : "";

    const tagChartMarkup = tagHistory.length
      ? `
          <div class="player-details-section">
            <p class="player-details-section-label">TAG HISTORY (SINCE 2023)</p>
            ${buildTagChart(tagHistory)}
            <p class="player-details-chart-note">Hover on desktop or tap a point on mobile to see the exact date and value.</p>
            ${renderYearStats("Best tag by year", buildYearlyBestTags(tagHistory))}
          </div>
        `
      : "";

    const weeklyWinsMarkup = `
      <div class="player-details-section">
        <p class="player-details-section-label">WEEKLY WINS</p>
        ${renderLinkList(
          weeklyWins,
          (item) => {
            const label = item.label || item.roundType || "Win";
            const text = `${item.date}${item.score ? ` — ${item.score}` : ""}${label ? ` (${label})` : ""}`;
            return renderLinkedLabel(item.href, text);
          },
          "No weekly wins found."
        )}
      </div>
    `;

    const bestOverallMarkup = `
      <div class="player-details-section">
        <p class="player-details-section-label">BEST OVERALL WINS</p>
        ${renderLinkList(
          bestOverallWins,
          (item) => {
            const label = item.label || item.roundType || "Best Overall";
            const tieText = item.isTie ? "Tied " : "";
            const text = `${item.date}${item.score ? ` — ${tieText}${item.score}` : ""}${label ? ` (${label})` : ""}`;
            return renderLinkedLabel(item.href, text);
          },
          "No best overall wins found."
        )}
      </div>
    `;

    const acesMarkup = `
      <div class="player-details-section">
        <p class="player-details-section-label">ACES</p>
        ${renderLinkList(
          aces,
          (item) => {
            const kind = item.kind === "doubles" ? "Doubles" : "Singles";
            const label = item.label || `${kind} ace`;
            const hole = item.hole ? `Hole ${item.hole}` : "Ace";
            const text = `${item.date} — ${hole} (${label})`;
            return renderLinkedLabel(item.href, text);
          },
          "No aces found."
        )}
      </div>
    `;

    const handicapDisplay = handicap
      ? `${escapeHtml(handicap)}${established ? "" : ' <span class="player-details-muted">(provisional)</span>'}`
      : '<span class="player-details-muted">—</span>';

    const tagDisplay = hasTag && currentTag
      ? escapeHtml(currentTag)
      : currentTag
        ? escapeHtml(currentTag)
        : '<span class="player-details-muted">—</span>';

    const lowestHandicapMarkup = lowestHandicap
      ? escapeHtml(lowestHandicap)
      : '<span class="player-details-muted">—</span>';

    const bestTagMarkup = bestTagEver
      ? escapeHtml(bestTagEver)
      : '<span class="player-details-muted">—</span>';

    const averageTagMarkup = averageTag
      ? escapeHtml(averageTag)
      : '<span class="player-details-muted">—</span>';

    playerDetailsModalBody.innerHTML = `
      <div class="player-details-summary-grid">
        <div class="player-details-summary-row"><strong>Average:</strong> ${
          average ? escapeHtml(average) : '<span class="player-details-muted">—</span>'
        }</div>
        <div class="player-details-summary-row"><strong>Handicap:</strong> ${handicapDisplay}</div>
        <div class="player-details-summary-row"><strong>Lowest Handicap:</strong> ${lowestHandicapMarkup}</div>
        <div class="player-details-summary-row"><strong>Current Tag:</strong> ${tagDisplay}</div>
        <div class="player-details-summary-row"><strong>Best Tag:</strong> ${bestTagMarkup}</div>
        <div class="player-details-summary-row"><strong>Average Tag:</strong> ${averageTagMarkup}</div>
        ${
          weeksAtOne
            ? `<div class="player-details-summary-row"><strong>Weeks at #1:</strong> ${escapeHtml(weeksAtOne)}</div>`
            : ""
        }
        <div class="player-details-summary-row"><strong>Personal Best:</strong> ${renderPersonalBestMarkup(personalBests)}</div>
      </div>

      <div class="player-details-section">
        <p class="player-details-section-label">RECENT HANDICAP ROUNDS</p>
        <table class="player-details-history-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Score</th>
            </tr>
          </thead>
          <tbody>
            ${rowsHtml}
          </tbody>
        </table>
      </div>

      ${scoreChartMarkup}
      ${handicapChartMarkup}
      ${tagChartMarkup}
      ${weeklyWinsMarkup}
      ${bestOverallMarkup}
      ${acesMarkup}
    `;
  }

  function openPlayerDetailsModal(profile, fallbackName, trigger) {
    if (!playerDetailsModal || !playerDetailsModalPanel) return;

    lastPlayerTrigger = trigger || null;
    renderPlayerDetailsModal(profile, fallbackName);

    hideAllChartTooltips();

    playerDetailsModal.hidden = false;
    document.documentElement.style.overflow = "hidden";
    playerDetailsModalPanel.scrollTop = 0;

    window.requestAnimationFrame(() => {
      playerDetailsModalClose?.focus();
    });
  }

  function closePlayerDetailsModal() {
    if (!playerDetailsModal || playerDetailsModal.hidden) return;

    playerDetailsModal.hidden = true;
    document.documentElement.style.overflow = "";
    hideAllChartTooltips();

    if (lastPlayerTrigger && typeof lastPlayerTrigger.focus === "function") {
      lastPlayerTrigger.focus();
    }

    lastPlayerTrigger = null;
  }

  function getPointFromEventTarget(target) {
    return target?.closest?.(".player-details-chart-point-group") || null;
  }

  function getChartShellFromPoint(point) {
    return point?.closest?.("[data-player-chart]") || null;
  }

  function hideAllChartTooltips() {
    document.querySelectorAll("[data-player-chart]").forEach((shell) => {
      shell.removeAttribute("data-chart-active");

      const tooltip = shell.querySelector(".player-details-chart-tooltip");
      const activeLine = shell.querySelector(".player-details-chart-active-line");
      const activeDot = shell.querySelector(".player-details-chart-active-dot");

      if (tooltip) tooltip.innerHTML = "";
      if (activeLine) {
        activeLine.setAttribute("x1", "0");
        activeLine.setAttribute("x2", "0");
      }
      if (activeDot) {
        activeDot.setAttribute("cx", "0");
        activeDot.setAttribute("cy", "0");
      }
    });
  }

  function positionTooltip(shell, point) {
    const tooltip = shell.querySelector(".player-details-chart-tooltip");
    const svg = shell.querySelector(".player-details-chart-svg");
    const activeLine = shell.querySelector(".player-details-chart-active-line");
    const activeDot = shell.querySelector(".player-details-chart-active-dot");

    if (!tooltip || !svg || !activeLine || !activeDot) return;

    const x = Number(point.dataset.chartX || 0);
    const y = Number(point.dataset.chartY || 0);
    const viewBox = svg.viewBox?.baseVal;
    const viewBoxWidth = viewBox?.width || 640;
    const viewBoxHeight = viewBox?.height || 210;
    const svgRect = svg.getBoundingClientRect();
    const shellRect = shell.getBoundingClientRect();

    const scaledX = svg.offsetLeft + (x / viewBoxWidth) * svgRect.width;
    const scaledY = svg.offsetTop + (y / viewBoxHeight) * svgRect.height;

    const title = point.dataset.chartTitle || "";
    const value = point.dataset.chartValue || point.dataset.chartTooltip || "";

    tooltip.innerHTML = `${escapeHtml(value)}${title ? `<span>${escapeHtml(title)}</span>` : ""}`;

    const minLeft = 70;
    const maxLeft = Math.max(minLeft, shellRect.width - 70);
    const left = Math.min(Math.max(scaledX, minLeft), maxLeft);
    const top = Math.max(scaledY, 36);

    tooltip.style.left = `${left}px`;
    tooltip.style.top = `${top}px`;

    activeLine.setAttribute("x1", String(x));
    activeLine.setAttribute("x2", String(x));
    activeDot.setAttribute("cx", String(x));
    activeDot.setAttribute("cy", String(y));

    shell.setAttribute("data-chart-active", "true");
  }

  function showChartTooltip(point) {
    if (!point) return;

    const shell = getChartShellFromPoint(point);
    if (!shell) return;

    hideAllChartTooltips();
    positionTooltip(shell, point);
  }

  document.addEventListener("click", (event) => {
    const playerButton = event.target.closest?.("[data-player-key]");
    const chartPoint = getPointFromEventTarget(event.target);

    if (chartPoint) {
      event.preventDefault();
      event.stopPropagation();
      showChartTooltip(chartPoint);
      return;
    }

    if (playerButton) {
      const key = playerButton.getAttribute("data-player-key") || "";
      const fallbackName = playerButton.getAttribute("data-player-name") || playerButton.textContent || "";
      const profile = PLAYER_PROFILES[key] || PLAYER_PROFILES[getPlayerKey(fallbackName)];

      if (!profile) return;

      event.preventDefault();
      openPlayerDetailsModal(profile, fallbackName, playerButton);
      return;
    }

    if (event.target.closest?.("[data-close-player-modal]")) {
      closePlayerDetailsModal();
      return;
    }

    if (!event.target.closest?.("[data-player-chart]")) {
      hideAllChartTooltips();
    }
  });

  playerDetailsModalClose?.addEventListener("click", closePlayerDetailsModal);

  playerDetailsModalBody?.addEventListener("pointerover", (event) => {
    const point = getPointFromEventTarget(event.target);
    if (point) showChartTooltip(point);
  });

  playerDetailsModalBody?.addEventListener("pointerout", (event) => {
    const point = getPointFromEventTarget(event.target);
    if (!point) return;

    const nextTarget = event.relatedTarget;
    if (nextTarget && point.contains(nextTarget)) return;

    if (window.matchMedia && window.matchMedia("(hover: hover)").matches) {
      hideAllChartTooltips();
    }
  });

  playerDetailsModalBody?.addEventListener("focusin", (event) => {
    const point = getPointFromEventTarget(event.target);
    if (point) showChartTooltip(point);
  });

  playerDetailsModalBody?.addEventListener("focusout", (event) => {
    const point = getPointFromEventTarget(event.target);
    if (point) hideAllChartTooltips();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      if (playerDetailsModal && !playerDetailsModal.hidden) {
        closePlayerDetailsModal();
      }
    }
  });

  window.addEventListener("resize", hideAllChartTooltips);
</script>
