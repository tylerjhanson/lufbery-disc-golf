---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = "" } = Astro.props;

function cleanName(value: string) {
  return String(value || "").replace(/\s+/g, " ").trim();
}

function playerSlug(value: string) {
  return cleanName(value)
    .toLowerCase()
    .replace(/&/g, " and ")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

const displayName = cleanName(name);
const href = displayName ? `/singles/players/${playerSlug(displayName)}/` : "";
const linkClass = ["player-button", className].filter(Boolean).join(" ");
---

<style is:global>
  .player-button {
    appearance: none;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    font-weight: 650;
    padding: 0;
    margin: 0;
    cursor: pointer;
    text-align: left;
    text-decoration: none !important;
    border-bottom: 1px solid rgba(34, 34, 34, 0.22);
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background-color 0.15s ease;
  }

  .player-button::after {
    content: "›";
    color: var(--accent, #b91c1c);
    margin-left: 4px;
    font-weight: 800;
  }

  .player-button:hover,
  .player-button:focus-visible {
    color: var(--accent, #b91c1c);
    border-bottom-color: currentColor;
    background: rgba(185, 28, 28, 0.08);
    border-radius: 4px;
    outline: none;
  }
</style>

{displayName && (
  <a class={linkClass} href={href} aria-label={`View player profile for ${displayName}`}>
    {displayName}
  </a>
)}

<script is:inline>
  (() => {
    if (document.getElementById("playerModalHomeFixesScript")) return;
    const script = document.createElement("script");
    script.id = "playerModalHomeFixesScript";
    script.src = "/player-modal-home-fixes.js?v=20260524c";
    script.defer = true;
    document.head.appendChild(script);
  })();
</script>
