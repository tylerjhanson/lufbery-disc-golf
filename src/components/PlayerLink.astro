---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = "" } = Astro.props;

function cleanName(value: string) {
  return String(value || "").replace(/\s+/g, " ").trim();
}

function playerSlug(value: string) {
  return cleanName(value)
    .toLowerCase()
    .replace(/&/g, " and ")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

const displayName = cleanName(name);
const href = displayName ? `/singles/players/${playerSlug(displayName)}/` : "";
const linkClass = ["player-button", className].filter(Boolean).join(" ");
---

{displayName && (
  <a class={linkClass} href={href} aria-label={`View player profile for ${displayName}`}>
    {displayName}
  </a>
)}

<script is:inline>
  (() => {
    if (document.getElementById("playerModalHomeFixesScript")) return;
    const script = document.createElement("script");
    script.id = "playerModalHomeFixesScript";
    script.src = "/player-modal-home-fixes.js?v=20260524c";
    script.defer = true;
    document.head.appendChild(script);
  })();
</script>
