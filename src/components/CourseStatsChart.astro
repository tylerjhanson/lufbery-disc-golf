---
const { stats } = Astro.props;
const years = Array.isArray(stats?.years) ? stats.years : [];
const numberFormatter = new Intl.NumberFormat("en-US");

function formatPlusMinus(value) {
  const number = Number(value || 0);
  if (number === 0) return "E";
  return number > 0 ? `+${number.toFixed(2)}` : number.toFixed(2);
}

function formatRounds(rounds) {
  const count = Number(rounds || 0);
  return `${numberFormatter.format(count)} round${count === 1 ? "" : "s"}`;
}

function barStyle(segments) {
  const visible = (segments || []).filter((segment) => Number(segment.count) > 0);
  return visible.length
    ? `grid-template-columns:${visible.map((segment) => `${Math.max(1, Number(segment.count))}fr`).join(" ")};`
    : "grid-template-columns:1fr;";
}

const panels = [
  { key: "total", label: "All years", data: stats?.total },
  ...years.map((year) => ({ key: String(year), label: String(year), data: stats?.byYear?.[year] })),
]
  .filter((panel) => panel.data && Array.isArray(panel.data.holes))
  .map((panel) => {
    const holes = panel.data.holes;
    return {
      ...panel,
      holes,
      tableHoles: [...holes].sort((a, b) =>
        (Number(a.hole || 0) - Number(b.hole || 0)) ||
        (Number(a.difficultyRank || 0) - Number(b.difficultyRank || 0))
      ),
    };
  });

const defaultPanelKey = panels[0]?.key || "total";
---

<section class="course-stats" data-course-stats>
  <header class="course-stats__header">
    <h1>Course Stats</h1>

    {panels.length > 1 && (
      <select id="course-stats-view" class="course-stats__filter" aria-label="Course stats view" data-course-stats-select>
        {panels.map((panel) => <option value={panel.key}>{panel.label}</option>)}
      </select>
    )}
  </header>

  {panels.length === 0 ? (
    <div class="empty">Add UDisc exports to <code>src/data/udisc-exports/</code>, then run <code>npm run generate-course-stats</code>.</div>
  ) : (
    panels.map((panel) => (
      <section
        class={`panel${panel.key === defaultPanelKey ? " is-active" : ""}`}
        data-course-stats-panel={panel.key}
        aria-hidden={panel.key === defaultPanelKey ? "false" : "true"}
      >
        <p class="round-count">{formatRounds(panel.data.rounds)}</p>

        <div class="hole-grid">
          {panel.holes.map((hole) => (
            <article class="hole-card">
              <div class="hole-header">
                <h3>Hole {hole.hole} <span>Par {hole.par}</span></h3>
                <div class="hole-stats">
                  <span>Difficulty <strong>{hole.difficultyRank || "—"}</strong></span>
                  <span>Avg <strong>{Number(hole.average || 0).toFixed(2)}</strong></span>
                </div>
              </div>
              <div class="score-bar" style={barStyle(hole.segments)}>
                {(hole.segments || []).map((segment) => (
                  <div class={`segment segment--${segment.kind}`} title={`${segment.label}: ${segment.count} (${Number(segment.pct || 0).toFixed(1)}%)`}>
                    {Number(segment.pct || 0) >= 9 && <span>{segment.count}</span>}
                  </div>
                ))}
              </div>
            </article>
          ))}
        </div>

        <div class="table-wrap">
          <table data-sort-table data-sort-key="hole" data-sort-dir="asc">
            <thead>
              <tr>
                <th><button type="button" data-sort-key="hole" aria-sort="ascending">Hole</button></th>
                <th><button type="button" data-sort-key="par">Par</button></th>
                <th><button type="button" data-sort-key="toPar">To Par</button></th>
                <th><button type="button" data-sort-key="difficulty">Difficulty</button></th>
              </tr>
            </thead>
            <tbody>
              {panel.tableHoles.map((hole) => (
                <tr
                  data-hole={hole.hole}
                  data-par={hole.par}
                  data-to-par={Number(hole.plusMinus || 0)}
                  data-difficulty={hole.difficultyRank || 0}
                >
                  <td>Hole {hole.hole}</td>
                  <td>{hole.par}</td>
                  <td>{formatPlusMinus(hole.plusMinus)}</td>
                  <td>{hole.difficultyRank || "—"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))
  )}
</section>

<script>
  const root = document.querySelector("[data-course-stats]");
  const select = root?.querySelector("[data-course-stats-select]");
  const panels = Array.from(root?.querySelectorAll("[data-course-stats-panel]") || []);

  function setActivePanel(value) {
    panels.forEach((panel) => {
      const isActive = panel.getAttribute("data-course-stats-panel") === value;
      panel.classList.toggle("is-active", isActive);
      panel.setAttribute("aria-hidden", isActive ? "false" : "true");
    });
  }

  select?.addEventListener("change", (event) => setActivePanel(event.target.value));

  root?.querySelectorAll("[data-sort-table]").forEach((table) => {
    const tbody = table.querySelector("tbody");
    const buttons = Array.from(table.querySelectorAll("button[data-sort-key]"));

    function sortRows(key, direction) {
      const multiplier = direction === "asc" ? 1 : -1;
      const rows = Array.from(tbody?.querySelectorAll("tr") || []);
      rows.sort((a, b) => {
        const aValue = Number(a.dataset[key] || 0);
        const bValue = Number(b.dataset[key] || 0);
        return ((aValue - bValue) || (Number(a.dataset.hole || 0) - Number(b.dataset.hole || 0))) * multiplier;
      });
      rows.forEach((row) => tbody?.appendChild(row));
    }

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const key = button.dataset.sortKey;
        const currentKey = table.dataset.sortKey;
        const currentDir = table.dataset.sortDir || "asc";
        const nextDir = currentKey === key && currentDir === "asc" ? "desc" : "asc";

        table.dataset.sortKey = key;
        table.dataset.sortDir = nextDir;
        buttons.forEach((item) => item.removeAttribute("aria-sort"));
        button.setAttribute("aria-sort", nextDir === "asc" ? "ascending" : "descending");
        sortRows(key, nextDir);
      });
    });
  });
</script>

<style>
  :global(body) {
    background: linear-gradient(180deg, #f8fafc 0%, #f5f7fb 100%);
  }

  .course-stats {
    --course-card: #ffffff;
    --course-bg: #f5f7fb;
    --course-line: #e5e7eb;
    --course-line-soft: #eef2f7;
    --course-muted: var(--muted, #6b7280);
    --course-text: var(--text, #111827);
    --course-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    display: grid;
    gap: 12px;
    color: var(--course-text);
  }

  .course-stats__header { display: grid; gap: 10px; align-items: start; justify-items: start; }
  h1 { margin: 0; font-size: clamp(2rem, 4vw, 3.1rem); line-height: 1; letter-spacing: -.04em; }
  .course-stats__filter { width: min(100%, 220px); padding: 9px 11px; border: 1px solid var(--course-line-soft); border-radius: 10px; background: var(--course-card); color: var(--course-text); font: inherit; }
  .empty, .hole-card, .table-wrap { border: 1px solid var(--course-line); border-radius: 14px; background: var(--course-card); box-shadow: var(--course-shadow); }
  .empty { padding: 12px 14px; color: var(--course-muted); }
  .panel { display: none; gap: 10px; }
  .panel.is-active { display: grid; }
  .round-count { margin: 0; color: var(--course-muted); font-weight: 800; }
  .hole-grid { display: grid; gap: 8px; }
  .hole-card { padding: 9px 11px; }
  .hole-header { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; margin-bottom: 6px; }
  .hole-header h3 { margin: 0; font-size: clamp(1rem, 1.4vw, 1.18rem); letter-spacing: -.02em; }
  .hole-header h3 span { margin-left: 7px; color: var(--course-muted); font-size: .82em; font-weight: 800; letter-spacing: 0; }
  .hole-stats { display: flex; gap: 12px; white-space: nowrap; }
  .hole-stats span { color: var(--course-muted); font-size: .9rem; }
  .hole-stats strong { color: var(--course-text); font-size: 1.15em; }
  .score-bar { display: grid; min-height: 24px; overflow: hidden; border: 2px solid #cfe0ef; border-radius: 10px; background: var(--course-card); }
  .segment { position: relative; min-width: 0; }
  .segment + .segment { box-shadow: inset 1px 0 0 rgba(15, 23, 42, .1); }
  .segment span { position: absolute; inset: 0; display: grid; place-items: center; font-size: .78rem; font-weight: 800; }
  .segment--ace { background: #2f6fb6; color: #fff; }
  .segment--birdie { background: #6c9bd1; color: #fff; }
  .segment--par { background: var(--course-card); color: var(--course-text); }
  .segment--bogey { background: #f2d8c8; color: #2e3440; }
  .segment--double { background: #efb286; color: #2e3440; }
  .segment--triple { background: #eb7b3c; color: #fff; }
  .table-wrap { overflow: visible; }
  table { width: 100%; border-collapse: collapse; table-layout: fixed; min-width: 0; }
  th, td { padding: 8px 9px; border-bottom: 1px solid var(--course-line); text-align: left; }
  th { color: var(--course-muted); font-size: .78rem; text-transform: uppercase; letter-spacing: .04em; }
  th:nth-child(1), td:nth-child(1) { width: 28%; }
  th:nth-child(2), td:nth-child(2) { width: 15%; }
  th:nth-child(3), td:nth-child(3) { width: 27%; }
  th:nth-child(4), td:nth-child(4) { width: 30%; text-align: right; }
  th:nth-child(4) button { margin-left: auto; }
  th button { all: unset; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; font: inherit; color: inherit; white-space: nowrap; }
  th button::after { content: "↕"; opacity: .45; }
  th button[aria-sort="ascending"]::after { content: "↑"; opacity: 1; }
  th button[aria-sort="descending"]::after { content: "↓"; opacity: 1; }
  tr:last-child td { border-bottom: 0; }
  @media (max-width: 760px) {
    .course-stats { gap: 11px; }
    .course-stats__filter { width: 100%; }
    .hole-card { padding: 8px 9px; }
    .hole-header { align-items: center; }
    .hole-stats { gap: 9px; }
    .hole-stats span { font-size: .82rem; }
    .score-bar { min-height: 22px; }
    th, td { padding: 7px 8px; }
    th { font-size: .72rem; letter-spacing: .02em; }
    td { font-size: .94rem; }
  }
</style>
