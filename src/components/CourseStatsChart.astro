---
const { stats } = Astro.props;
const years = Array.isArray(stats?.years) ? stats.years : [];
const numberFormatter = new Intl.NumberFormat("en-US");

function formatPlusMinus(value) {
  const number = Number(value || 0);
  if (number === 0) return "E";
  return number > 0 ? `+${number.toFixed(2)}` : number.toFixed(2);
}

function formatRounds(rounds) {
  const count = Number(rounds || 0);
  return `${numberFormatter.format(count)} round${count === 1 ? "" : "s"}`;
}

function barStyle(segments) {
  const visible = (segments || []).filter((segment) => Number(segment.count) > 0);
  return visible.length
    ? `grid-template-columns:${visible.map((segment) => `${Math.max(1, Number(segment.count))}fr`).join(" ")};`
    : "grid-template-columns:1fr;";
}

const panels = [
  { key: "total", label: "All years", data: stats?.total },
  ...years.map((year) => ({ key: String(year), label: String(year), data: stats?.byYear?.[year] })),
]
  .filter((panel) => panel.data && Array.isArray(panel.data.holes))
  .map((panel) => {
    const holes = panel.data.holes;
    return {
      ...panel,
      holes,
      tableHoles: [...holes].sort((a, b) =>
        (Number(a.difficultyRank || 0) - Number(b.difficultyRank || 0)) ||
        (Number(a.hole || 0) - Number(b.hole || 0))
      ),
    };
  });

const defaultPanelKey = panels[0]?.key || "total";
---

<section class="course-stats" data-course-stats>
  <header class="course-stats__header">
    <h1>Course Stats</h1>

    {panels.length > 1 && (
      <select id="course-stats-view" class="course-stats__filter" aria-label="Course stats view" data-course-stats-select>
        {panels.map((panel) => <option value={panel.key}>{panel.label}</option>)}
      </select>
    )}
  </header>

  {panels.length === 0 ? (
    <div class="empty">Add UDisc exports to <code>src/data/udisc-exports/</code>, then run <code>npm run generate-course-stats</code>.</div>
  ) : (
    panels.map((panel) => (
      <section
        class={`panel${panel.key === defaultPanelKey ? " is-active" : ""}`}
        data-course-stats-panel={panel.key}
        aria-hidden={panel.key === defaultPanelKey ? "false" : "true"}
      >
        <p class="round-count">{formatRounds(panel.data.rounds)}</p>

        <div class="hole-grid">
          {panel.holes.map((hole) => (
            <article class="hole-card">
              <div class="hole-header">
                <h3>Hole {hole.hole} <span>Par {hole.par}</span></h3>
                <div class="hole-stats">
                  <span>Difficulty <strong>{hole.difficultyRank || "—"}</strong></span>
                  <span>Avg <strong>{Number(hole.average || 0).toFixed(2)}</strong></span>
                </div>
              </div>
              <div class="score-bar" style={barStyle(hole.segments)}>
                {(hole.segments || []).map((segment) => (
                  <div class={`segment segment--${segment.kind}`} title={`${segment.label}: ${numberFormatter.format(Number(segment.count || 0))} (${Number(segment.pct || 0).toFixed(1)}%)`}>
                    {Number(segment.pct || 0) >= 9 && <span>{numberFormatter.format(Number(segment.count || 0))}</span>}
                  </div>
                ))}
              </div>
            </article>
          ))}
        </div>

        <div class="table-wrap course-stats-table-wrap">
          <table class="course-stats-table" data-sort-table data-sort-key="difficulty" data-sort-dir="asc">
            <colgroup>
              <col class="hole-col" />
              <col class="par-col" />
              <col class="to-par-col" />
              <col class="difficulty-col" />
            </colgroup>
            <thead>
              <tr>
                <th class="sortable"><button type="button" data-sort-key="hole"><span class="th-inner">Hole <span class="sort-indicator"></span></span></button></th>
                <th class="sortable"><button type="button" data-sort-key="par"><span class="th-inner">Par <span class="sort-indicator"></span></span></button></th>
                <th class="sortable"><button type="button" data-sort-key="toPar"><span class="th-inner">To Par <span class="sort-indicator"></span></span></button></th>
                <th class="sortable"><button type="button" data-sort-key="difficulty" aria-sort="ascending"><span class="th-inner">Difficulty <span class="sort-indicator"></span></span></button></th>
              </tr>
            </thead>
            <tbody>
              {panel.tableHoles.map((hole) => (
                <tr
                  data-hole={hole.hole}
                  data-par={hole.par}
                  data-to-par={Number(hole.plusMinus || 0)}
                  data-difficulty={hole.difficultyRank || 0}
                >
                  <td>Hole {hole.hole}</td>
                  <td>{hole.par}</td>
                  <td>{formatPlusMinus(hole.plusMinus)}</td>
                  <td>{hole.difficultyRank || "—"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))
  )}
</section>

<script>
  const root = document.querySelector("[data-course-stats]");
  const select = root?.querySelector("[data-course-stats-select]");
  const panels = Array.from(root?.querySelectorAll("[data-course-stats-panel]") || []);

  function setActivePanel(value) {
    panels.forEach((panel) => {
      const isActive = panel.getAttribute("data-course-stats-panel") === value;
      panel.classList.toggle("is-active", isActive);
      panel.setAttribute("aria-hidden", isActive ? "false" : "true");
    });
  }

  select?.addEventListener("change", (event) => setActivePanel(event.target.value));

  root?.querySelectorAll("[data-sort-table]").forEach((table) => {
    const tbody = table.querySelector("tbody");
    const buttons = Array.from(table.querySelectorAll("button[data-sort-key]"));

    function updateIndicators(activeKey, direction) {
      buttons.forEach((button) => {
        const indicator = button.querySelector(".sort-indicator");
        if (!indicator) return;

        if (button.dataset.sortKey === activeKey) {
          indicator.textContent = direction === "asc" ? "▲" : "▼";
          indicator.style.color = "#2563eb";
        } else {
          indicator.textContent = "";
          indicator.style.color = "#94a3b8";
        }
      });
    }

    function sortRows(key, direction) {
      const multiplier = direction === "asc" ? 1 : -1;
      const rows = Array.from(tbody?.querySelectorAll("tr") || []);
      rows.sort((a, b) => {
        const aValue = Number(a.dataset[key] || 0);
        const bValue = Number(b.dataset[key] || 0);
        return ((aValue - bValue) || (Number(a.dataset.hole || 0) - Number(b.dataset.hole || 0))) * multiplier;
      });
      rows.forEach((row) => tbody?.appendChild(row));
      updateIndicators(key, direction);
    }

    updateIndicators(table.dataset.sortKey || "hole", table.dataset.sortDir || "asc");

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const key = button.dataset.sortKey;
        const currentKey = table.dataset.sortKey;
        const currentDir = table.dataset.sortDir || "asc";
        const nextDir = currentKey === key && currentDir === "asc" ? "desc" : "asc";

        table.dataset.sortKey = key;
        table.dataset.sortDir = nextDir;
        buttons.forEach((item) => item.removeAttribute("aria-sort"));
        button.setAttribute("aria-sort", nextDir === "asc" ? "ascending" : "descending");
        sortRows(key, nextDir);
      });
    });
  });
</script>

<style>
  .course-stats {
    --course-card: var(--card, #ffffff);
    --course-bg: var(--bg, #f5f7fb);
    --course-bg-strong: var(--header, #f8fafc);
    --course-line: var(--line, #d8e0ea);
    --course-line-soft: var(--line-soft, #e6edf5);
    --course-muted: var(--muted, #6b7280);
    --course-text: var(--text, #111827);
    --course-hover: var(--hover, #f9fbff);
    --course-shadow: var(--shadow, 0 10px 30px rgba(15, 23, 42, 0.08));
    --course-bar-border: #cfe0ef;
    --course-separator: rgba(15, 23, 42, 0.1);
    --course-orange-text: #2e3440;
    display: grid;
    gap: 12px;
    color: var(--course-text);
  }

  :global(html[data-theme="dark"]) .course-stats {
    --course-bar-border: #334155;
    --course-separator: rgba(248, 250, 252, 0.16);
    --course-orange-text: #1f2937;
  }

  @media (prefers-color-scheme: dark) {
    :global(html[data-theme="system"]) .course-stats {
      --course-bar-border: #334155;
      --course-separator: rgba(248, 250, 252, 0.16);
      --course-orange-text: #1f2937;
    }
  }

  .course-stats__header { display: grid; gap: 10px; align-items: start; justify-items: start; }
  h1 { margin: 0; font-size: clamp(2rem, 4vw, 3.1rem); line-height: 1; letter-spacing: -.04em; }
  .course-stats__filter { width: min(100%, 220px); padding: 9px 11px; border: 1px solid var(--course-line-soft); border-radius: 10px; background: var(--course-card); color: var(--course-text); font: inherit; }
  .empty, .hole-card, .table-wrap { border: 1px solid var(--course-line); border-radius: 14px; background: var(--course-card); box-shadow: var(--course-shadow); }
  .empty { padding: 12px 14px; color: var(--course-muted); }
  .panel { display: none; gap: 10px; }
  .panel.is-active { display: grid; }
  .round-count { margin: 0; color: var(--course-muted); font-weight: 800; }
  .hole-grid { display: grid; gap: 8px; }
  .hole-card { padding: 9px 11px; }
  .hole-header { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; margin-bottom: 6px; }
  .hole-header h3 { margin: 0; font-size: 1.035rem; font-weight: 800; letter-spacing: -.02em; }
  .hole-header h3 span { margin-left: 7px; color: var(--course-muted); font-size: .9rem; font-weight: 400; letter-spacing: 0; }
  .hole-stats { display: flex; gap: 12px; white-space: nowrap; }
  .hole-stats span { color: var(--course-muted); font-size: .9rem; }
  .hole-stats strong { color: var(--course-text); font-size: 1.15em; }
  .score-bar { display: grid; min-height: 24px; overflow: hidden; border: 2px solid var(--course-bar-border); border-radius: 10px; background: var(--course-card); }
  .segment { position: relative; min-width: 0; }
  .segment + .segment { box-shadow: inset 1px 0 0 var(--course-separator); }
  .segment span { position: absolute; inset: 0; display: grid; place-items: center; font-size: .78rem; font-weight: 800; }
  .segment--ace { background: #2f6fb6; color: #fff; }
  .segment--birdie { background: #6c9bd1; color: #fff; }
  .segment--par { background: var(--course-card); color: var(--course-text); }
  .segment--bogey { background: #f2d8c8; color: var(--course-orange-text); }
  .segment--double { background: #efb286; color: var(--course-orange-text); }
  .segment--triple { background: #eb7b3c; color: var(--course-orange-text); }
  .segment--bogey span, .segment--double span, .segment--triple span { color: var(--course-orange-text); }

  .course-stats-table-wrap {
    padding: 0 10px 8px;
    overflow-x: visible;
    overflow-y: auto;
    border-color: var(--course-line-soft);
    border-radius: 22px;
  }

  .course-stats-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    table-layout: fixed;
    min-width: 0;
  }

  .course-stats-table .hole-col { width: 34%; }
  .course-stats-table .par-col { width: 17%; }
  .course-stats-table .to-par-col { width: 24%; }
  .course-stats-table .difficulty-col { width: 25%; }

  .course-stats-table thead th {
    position: sticky;
    top: 0;
    z-index: 5;
    background: var(--course-bg-strong);
    color: var(--course-muted);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    padding: 10px 5px;
    border-bottom: 1px solid var(--course-line);
    user-select: none;
    text-align: center;
    white-space: normal;
    line-height: 1.08;
  }

  .course-stats-table thead th.sortable {
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .course-stats-table thead th.sortable:hover {
    background: #f1f5f9;
    color: var(--course-text);
  }

  .course-stats-table thead th:first-child {
    border-top-left-radius: 14px;
    text-align: left;
  }

  .course-stats-table thead th:last-child {
    border-top-right-radius: 14px;
  }

  .course-stats-table th button {
    all: unset;
    width: 100%;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font: inherit;
    color: inherit;
    white-space: nowrap;
  }

  .course-stats-table .th-inner {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 100%;
  }

  .course-stats-table th:first-child .th-inner {
    justify-content: flex-start;
  }

  .course-stats-table .sort-indicator {
    display: inline-block;
    width: 10px;
    color: #94a3b8;
    font-size: 0.72rem;
    flex: 0 0 10px;
  }

  .course-stats-table tbody td {
    padding: 10px 5px;
    border-bottom: 1px solid var(--course-line-soft);
    color: var(--course-text);
    font-size: 0.94rem;
    text-align: center;
    vertical-align: middle;
    line-height: 1.1;
    white-space: normal;
  }

  .course-stats-table tbody tr:nth-child(even) td {
    background: #fcfdff;
  }

  .course-stats-table tbody tr:hover td {
    background: var(--course-hover);
  }

  .course-stats-table tbody td:first-child {
    text-align: left;
    font-weight: 600;
  }

  .course-stats-table tbody tr:last-child td {
    border-bottom: 0;
  }

  @media (min-width: 980px) {
    .panel.is-active {
      display: grid;
      grid-template-columns: minmax(0, 2fr) minmax(300px, 1fr);
      grid-template-areas:
        "round round"
        "holes table";
      gap: 14px 18px;
      align-items: start;
    }

    .round-count { grid-area: round; }
    .hole-grid { grid-area: holes; }
    .table-wrap { grid-area: table; }
  }

  @media (max-width: 760px) {
    .course-stats { gap: 11px; }
    .course-stats__filter { width: 100%; }
    .hole-card { padding: 8px 9px; }
    .hole-header { align-items: center; }
    .hole-stats { gap: 9px; }
    .hole-header h3 { font-size: .943rem; }
    .hole-header h3 span { font-size: .82rem; }
    .hole-stats span { font-size: .82rem; }
    .score-bar { min-height: 22px; }
    .course-stats-table-wrap {
      padding: 0 2px 6px;
      border-radius: 14px;
    }
    .course-stats-table .hole-col { width: 32%; }
    .course-stats-table .par-col { width: 16%; }
    .course-stats-table .to-par-col { width: 25%; }
    .course-stats-table .difficulty-col { width: 27%; }
    .course-stats-table thead th {
      font-size: 0.58rem;
      padding: 6px 2px;
      letter-spacing: 0;
      line-height: 1.04;
    }
    .course-stats-table .sort-indicator {
      width: 8px;
      font-size: 0.62rem;
      flex-basis: 8px;
    }
    .course-stats-table tbody td {
      font-size: 0.78rem;
      padding: 7px 2px;
      line-height: 1.06;
    }
  }
</style>
