      background: var(--button-bg-hover, #eceff4);
      transform: translateY(-1px);
    }

    :global(.event-date) {
      margin: 0 0 3px;
      font-weight: 700;
      font-size: 0.92rem;
      line-height: 1.2;
    }

    :global(.event-time) {
      margin: 0 0 1px;
      color: var(--text);
      font-size: 0.92rem;
      line-height: 1.18;
    }

    :global(.event-title) {
      margin: 0;
      font-weight: 400;
      font-size: 0.94rem;
      line-height: 1.2;
    }

    :global(.event-meta) {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.4;
    }

