      color: var(--text);
      text-decoration: none;
    }

    .result-fallback-link:hover {
      text-decoration: underline;
    }

    .event-item {
      border: 1px solid var(--line-soft);
      border-radius: 7px;
      padding: 12px 14px;
      background: var(--button-bg, #f3f5f8);
    }

    .event-date {
