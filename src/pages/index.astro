<SiteLayout title="Lufbery Disc Golf" showBrandBar={true}>
  <style>
    .home-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.9fr) minmax(250px, 0.78fr);
      gap: 18px;
      align-items: start;
    }

    .left-stack,
    .middle-stack,
    .right-stack {
      display: grid;
      gap: 18px;
      align-content: start;
      min-width: 0;
    }

    .mobile-quick-row {
      display: none;
    }

    .card,
    .utility-card {
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-radius: 12px;
      box-shadow: var(--shadow);
    }

    .card {
      padding: 22px 20px 18px;
      min-width: 0;
    }

    .card h2 {
      margin: 0 0 8px;
      font-size: 1.2rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .subtle-note {
      color: var(--muted);
      font-size: 0.97rem;
      line-height: 1.6;
      margin: 0 0 14px;
    }

    .link-list,
    .event-list {
      display: grid;
      gap: 10px;
    }

    .link-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      min-height: 46px;
      padding: 12px 16px;
      border: 1px solid var(--line-soft);
      border-radius: 7px;
      background: var(--button-bg, #f3f5f8);
      font-weight: 500;
      text-align: left;
      transition: background 0.12s ease, transform 0.12s ease;
    }

    .link-item:hover {
      background: var(--button-bg-hover, #eceff4);
      transform: translateY(-1px);
    }

    .link-item-label {
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
      flex: 1;
    }

    .link-item-text {
      line-height: 1.35;
    }

    .link-arrow {
      color: var(--muted);
      font-size: 1rem;
      line-height: 1;
      flex: 0 0 auto;
      transition: transform 0.12s ease, color 0.12s ease;
    }

    .link-item:hover .link-arrow {
      transform: translateX(2px);
      color: var(--text);
    }

    .utility-card {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 64px;
      padding: 14px 16px;
      text-decoration: none;
      transition: background 0.12s ease, transform 0.12s ease;
    }

    .utility-card:hover {
      background: var(--button-bg, #f3f5f8);
      transform: translateY(-1px);
    }

    .utility-card-text {
      font-weight: 500;
      line-height: 1.3;
      text-align: center;
    }

    .udisc-logo-only {
      display: block;
      height: 20px;
      width: auto;
      object-fit: contain;
    }

    .latest-result-card {
      min-width: 0;
    }

    .result-title-link {
  display: inline-block;
  color: #2563eb;
  text-decoration: none;
  font-size: 1.2rem;
  font-weight: 700;
  line-height: 1.15;
  margin: 0 0 10px;
}

.result-title-link:hover {
  text-decoration: underline;
}

.result-title-plain {
  margin: 0 0 10px;
  font-size: 1.2rem;
  font-weight: 700;
  line-height: 1.15;
  color: var(--text);
}

.result-collapse {
  position: relative;
  overflow: hidden;
  max-height: 535px;
  transition: max-height 0.22s ease;
}

.latest-result-card.is-expanded .result-collapse {
  max-height: none;
  overflow: visible;
}

.latest-result-card.has-overflow:not(.is-expanded) .result-collapse::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 70px;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0), var(--card) 88%);
  pointer-events: none;
}

.result-table-wrap {
  overflow-x: auto;
  border: 1px solid var(--line-soft);
  border-radius: 12px;
  background: var(--button-bg, #f3f5f8);
}

.result-table {
  width: 100%;
  border-collapse: collapse;
  table-layout: fixed;
  font-size: 0.9rem;
}

.result-table thead th {
  padding: 8px 6px 7px;
  border-bottom: 1px solid var(--line-soft);
  color: var(--muted);
  font-size: 0.66rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  text-align: left;
  white-space: nowrap;
}

.result-table tbody td {
  padding: 7px 6px;
  border-bottom: 1px solid var(--line-soft);
  line-height: 1.2;
}

.result-table tbody tr:last-child td {
  border-bottom: 0;
}

.result-table th:first-child,
.result-table td:first-child {
  width: 34%;
  padding-left: 10px;
  white-space: normal;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.result-table th:not(:first-child),
.result-table td:not(:first-child) {
  white-space: nowrap;
}

.result-table th:last-child,
.result-table td:last-child {
  padding-right: 10px;
}

    .working-heading {
      margin: 16px 0 8px;
      font-size: 1rem;
      font-weight: 700;
      color: var(--muted);
      line-height: 1.3;
    }

    .result-actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

