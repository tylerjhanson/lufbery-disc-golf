<SiteLayout title="Lufbery Disc Golf" showBrandBar={true}>
  <style>
    * {
      box-sizing: border-box;
    }

    .home-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.97fr) minmax(0, 0.92fr) minmax(210px, 0.62fr);
      gap: 18px;
      align-items: stretch;
    }

    .left-stack,
    .middle-stack,
    .right-stack {
      display: grid;
      gap: 18px;
      align-content: start;
      min-width: 0;
    }

    .right-stack {
      grid-template-rows: auto auto minmax(0, 1fr);
      height: 100%;
    }

    .mobile-quick-row {
      display: none;
    }

    .card,
    .utility-card {
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-radius: 12px;
      box-shadow: var(--shadow);
    }

    .card {
      padding: 20px 18px 16px;
      min-width: 0;
    }

    .card h2 {
      margin: 0 0 8px;
      font-size: 1.2rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .events-card {
      --home-event-count: 5;
      display: flex;
      flex-direction: column;
      min-height: 0;
      padding-bottom: 18px;
    }

    .events-card h2 {
      margin-bottom: 13px;
    }

    .subtle-note {
      color: var(--muted);
      font-size: 0.97rem;
      line-height: 1.6;
      margin: 0 0 14px;
    }

    .desktop-lostfound .utility-card-text {
      color: var(--text);
      font-size: 1.2rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .link-list {
      display: grid;
      gap: 10px;
    }

    :global(.event-list) {
      display: grid;
      gap: 14px;
    }

    .events-card :global(.event-list) {
      flex: 1;
      grid-template-rows: repeat(var(--home-event-count), minmax(0, 1fr));
      min-height: 0;
    }

    :global(.event-list .event-item:nth-of-type(n + 6)) {
      display: none;
    }

    .link-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      min-height: 46px;
      padding: 12px 16px;
      border: 1px solid var(--line-soft);
      border-radius: 7px;
      background: var(--button-bg, #f3f5f8);
      font-weight: 500;
      text-align: left;
      transition: background 0.12s ease, transform 0.12s ease;
    }

    .link-item:hover {
      background: var(--button-bg-hover, #eceff4);
      transform: translateY(-1px);
    }

    .link-item-label {
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
      flex: 1;
    }

    .link-item-text {
      line-height: 1.35;
    }

    .link-arrow {
      color: var(--muted);
      font-size: 1rem;
      line-height: 1;
      flex: 0 0 auto;
      transition: transform 0.12s ease, color 0.12s ease;
    }

    .link-item:hover .link-arrow {
      transform: translateX(2px);
      color: var(--text);
    }

    .utility-card {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 58px;
      padding: 14px 16px;
      text-decoration: none;
      transition: background 0.12s ease, transform 0.12s ease;
    }

    .utility-card:hover {
      background: var(--button-bg, #f3f5f8);
      transform: translateY(-1px);
    }

    .utility-card-text {
      font-weight: 500;
      line-height: 1.3;
      text-align: center;
    }

    .udisc-logo-only {
      display: block;
      height: 20px;
      width: auto;
      object-fit: contain;
    }

    .udisc-logo-dark {
      display: none;
    }

    html[data-theme="dark"] .udisc-logo-light {
      display: none;
    }

    html[data-theme="dark"] .udisc-logo-dark {
      display: block;
    }

    @media (prefers-color-scheme: dark) {
      html[data-theme="system"] .udisc-logo-light {
        display: none;
      }

      html[data-theme="system"] .udisc-logo-dark {
        display: block;
      }
    }

    .latest-result-card {
      min-width: 0;
    }

