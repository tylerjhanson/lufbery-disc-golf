---
import SiteLayout from "../layouts/SiteLayout.astro";
import { getWeeklyResults } from "../lib/data";

const singlesLinks = [
  { href: "/singles/handicaps-tags", label: "Handicaps & Tags" },
  { href: "/singles/weekly-results", label: "Weekly Results" },
  { href: "/singles/weekly-winners", label: "Weekly Winners" },
  { href: "/singles/course-records", label: "Course Records" },
  { href: "/singles/aces", label: "Aces" },
];

const doublesLinks = [
  { href: "/doubles/course-records", label: "Course Records" },
  { href: "/doubles/aces", label: "Aces" },
];

const lostFoundUrl = "/lost-and-found";
const handicapTagsUrl = "/singles/handicaps-tags";
const udiscLeagueUrl = "https://udisc.com/leagues/lufbery-league";

type LooseRow = Record<string, unknown>;
type WeeklyResultItem = Record<string, unknown> & {
  title?: string;
  url?: string;
};

type EventItem = {
  key: string;
  title: string;
  location: string;
  stamp: string;
  displayDate: string;
  displayTime: string;
};

const weeklyResults = getWeeklyResults() as WeeklyResultItem[];

function getEventDateParts(title: string) {
  const match = String(title || "").match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})/);
  if (!match) return null;

  const month = Number(match[1]);
  const day = Number(match[2]);
  let year = Number(match[3]);

  if (year < 100) year += 2000;

  return { month, day, year };
}

function getEventTimestamp(title: string) {
  const parts = getEventDateParts(title);
  if (!parts) return 0;
  return new Date(parts.year, parts.month - 1, parts.day).getTime();
}

function normalizeKey(value: string) {
  return String(value || "")
    .toLowerCase()
    .replace(/[^a-z0-9]/g, "");
}

function asObjectArray(value: unknown): LooseRow[] {
  if (!Array.isArray(value)) return [];
  return value.filter((item) => item && typeof item === "object") as LooseRow[];
}

function getFirstObjectArray(source: WeeklyResultItem | null, keys: string[]) {
  if (!source) return [];

  for (const key of keys) {
    const rows = asObjectArray(source[key]);
    if (rows.length) return rows;
  }

  return [];
}

const latestResult =
  [...weeklyResults]
    .filter((event) => String(event?.title || "").trim())
    .sort((a, b) => getEventTimestamp(String(b.title || "")) - getEventTimestamp(String(a.title || "")))[0] ||
  null;

const latestResultHref = String(latestResult?.url || "/singles/weekly-results");

const latestResultMainRows = getFirstObjectArray(latestResult, [
  "rows",
  "results",
  "tableRows",
  "mainRows",
  "players",
  "scores",
]);

const latestResultWorkingRows = getFirstObjectArray(latestResult, [
  "workingRows",
  "workingToHandicapRows",
  "handicapRows",
  "provisionalRows",
  "unratedRows",
]);

type ResolvedColumn = {
  key: string;
  label: string;
};

const MAIN_COLUMN_DEFS = [
  { label: "Name", aliases: ["name", "player"] },
  { label: "Raw", aliases: ["raw", "score", "gross"] },
  { label: "HCP.", aliases: ["hcp", "handicap"] },
  { label: "Net", aliases: ["net"] },
  { label: "Payout", aliases: ["payout", "pay"] },
];

const WORKING_COLUMN_DEFS = [
  { label: "Name", aliases: ["name", "player"] },
  { label: "Raw", aliases: ["raw", "score", "gross"] },
];

function humanizeKey(key: string) {
  const cleaned = String(key || "").replace(/[_-]+/g, " ").trim();
  if (!cleaned) return "";
  return cleaned
    .split(/\s+/)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
}

function resolveColumns(rows: LooseRow[], defs: { label: string; aliases: string[] }[]) {
  const keyMap = new Map<string, string>();

  rows.forEach((row) => {
    Object.keys(row).forEach((key) => {
      const normalized = normalizeKey(key);
      if (normalized && !keyMap.has(normalized)) keyMap.set(normalized, key);
    });
  });

  const resolved: ResolvedColumn[] = [];
  const used = new Set<string>();

  defs.forEach((def) => {
    const actualKey = def.aliases
      .map((alias) => keyMap.get(normalizeKey(alias)))
      .find(Boolean);

    if (actualKey && !used.has(actualKey)) {
      used.add(actualKey);
      resolved.push({ key: actualKey, label: def.label });
    }
  });

  rows.forEach((row) => {
    Object.keys(row).forEach((key) => {
      if (!used.has(key)) {
        used.add(key);
        resolved.push({ key, label: humanizeKey(key) });
      }
    });
  });

  return resolved;
}

const latestResultMainColumns = resolveColumns(latestResultMainRows, MAIN_COLUMN_DEFS).slice(0, 5);
const latestResultWorkingColumns = resolveColumns(latestResultWorkingRows, WORKING_COLUMN_DEFS);

function getCellText(row: LooseRow, key: string) {
  const value = row[key];

  if (value === null || value === undefined) return "";
  if (Array.isArray(value)) return value.map((item) => String(item ?? "")).join(", ");
  return String(value);
}

const hasLatestResultTable =
  latestResultMainRows.length > 0 || latestResultWorkingRows.length > 0;

let upcomingEvents: EventItem[] = [];
---

<SiteLayout title="Lufbery Disc Golf" showBrandBar={true}>
  <style>
    * {
      box-sizing: border-box;
    }

    .home-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.97fr) minmax(0, 0.92fr) minmax(210px, 0.62fr);
      gap: 18px;
      align-items: start;
    }

    .left-stack,
    .middle-stack,
    .right-stack {
      display: grid;
      gap: 18px;
      align-content: start;
      min-width: 0;
    }

    .mobile-quick-row {
      display: none;
    }

    .card,
    .utility-card {
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-radius: 12px;
      box-shadow: var(--shadow);
    }

    .card {
      padding: 20px 18px 16px;
      min-width: 0;
    }

    .card h2 {
      margin: 0 0 8px;
      font-size: 1.2rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .events-card {
      padding-bottom: 16px;
      min-height: 456px;
    }

    .subtle-note {
      color: var(--muted);
      font-size: 0.97rem;
      line-height: 1.6;
      margin: 0 0 14px;
    }

    #eventsEmpty {
      margin: 0;
    }

    .desktop-lostfound .utility-card-text {
      color: var(--text);
      font-size: 1.2rem;
      font-weight: 700;
      line-height: 1.2;
    }

    .link-list,
    .event-list {
      display: grid;
      gap: 10px;
    }

    .event-list {
      align-content: start;
    }

    .link-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      min-height: 46px;
      padding: 12px 16px;
      border: 1px solid var(--line-soft);
      border-radius: 7px;
      background: var(--button-bg, #f3f5f8);
      font-weight: 500;
      text-align: left;
      transition: background 0.12s ease, transform 0.12s ease;
    }

    .link-item:hover {
      background: var(--button-bg-hover, #eceff4);
      transform: translateY(-1px);
    }

    .link-item-label {
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
      flex: 1;
    }

    .link-item-text {
      line-height: 1.35;
    }

    .link-arrow {
      color: var(--muted);
      font-size: 1rem;
      line-height: 1;
      flex: 0 0 auto;
      transition: transform 0.12s ease, color 0.12s ease;
    }

    .link-item:hover .link-arrow {
      transform: translateX(2px);
      color: var(--text);
    }

    .utility-card {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 58px;
      padding: 14px 16px;
      text-decoration: none;
      transition: background 0.12s ease, transform 0.12s ease;
    }

    .utility-card:hover {
      background: var(--button-bg, #f3f5f8);
      transform: translateY(-1px);
    }

    .utility-card-text {
      font-weight: 500;
      line-height: 1.3;
      text-align: center;
    }

    .udisc-logo-only {
      display: block;
      height: 20px;
      width: auto;
      object-fit: contain;
    }

    .udisc-logo-dark {
      display: none;
    }

    html[data-theme="dark"] .udisc-logo-light {
      display: none;
    }

    html[data-theme="dark"] .udisc-logo-dark {
      display: block;
    }

    @media (prefers-color-scheme: dark) {
      html[data-theme="system"] .udisc-logo-light {
        display: none;
      }

      html[data-theme="system"] .udisc-logo-dark {
        display: block;
      }
    }

    .latest-result-card {
      min-width: 0;
    }

    .result-title-link,
    .result-title-plain {
      display: inline-block;
      margin: 0 0 12px;
      font-size: 0.97rem;
      font-weight: 400;
      line-height: 1.6;
    }

    .result-title-link {
      color: #2563eb;
      text-decoration: none;
    }

    .result-title-link:hover {
      color: #1d4ed8;
      text-decoration: underline;
    }

    .result-title-plain {
      color: var(--muted);
    }

    .result-collapse {
      position: relative;
      overflow: hidden;
      max-height: 458px;
      transition: max-height 0.22s ease;
    }

    .latest-result-card.is-expanded .result-collapse {
      max-height: none;
      overflow: visible;
    }

    .latest-result-card.has-overflow:not(.is-expanded) .result-collapse::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 68px;
      background: linear-gradient(to bottom, rgba(255, 255, 255, 0), var(--card) 88%);
      pointer-events: none;
    }

    .result-table-block {
      margin-top: 2px;
    }

    .result-table-wrap {
      overflow-x: visible;
      border: 1px solid var(--line-soft);
      border-radius: 12px;
      background: var(--button-bg, #f3f5f8);
    }

    .result-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: fixed;
      min-width: 0;
    }

    .result-main-table thead th,
    .result-working-table thead th {
      background: #f8fafc;
      color: var(--muted);
      font-weight: 700;
      text-transform: uppercase;
      border-bottom: 1px solid #e5e7eb;
      text-align: center;
      white-space: normal;
      line-height: 1.05;
      letter-spacing: 0.01em;
    }

    .result-main-table tbody td,
    .result-working-table tbody td {
      border-bottom: 1px solid var(--line-soft);
      text-align: center;
      vertical-align: top;
      line-height: 1.08;
      white-space: normal;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .result-main-table tbody tr:last-child td,
    .result-working-table tbody tr:last-child td {
      border-bottom: 0;
    }

    .result-main-table thead th:first-child,
    .result-main-table tbody td:first-child,
    .result-working-table thead th:first-child,
    .result-working-table tbody td:first-child {
      text-align: left;
      overflow-wrap: anywhere;
      word-break: break-word;
      border-top-left-radius: 14px;
    }

    .result-main-table thead th:last-child,
    .result-working-table thead th:last-child {
      border-top-right-radius: 14px;
    }

    .result-main-table thead th {
      font-size: 0.64rem;
      padding: 7px 3px;
    }

    .result-main-table tbody td {
      font-size: 0.8rem;
      padding: 7px 3px;
    }

    .result-main-table thead th:first-child,
    .result-main-table tbody td:first-child {
      width: 28%;
      padding-left: 8px;
    }

    .result-main-table thead th:nth-child(2),
    .result-main-table tbody td:nth-child(2),
    .result-main-table thead th:nth-child(3),
    .result-main-table tbody td:nth-child(3),
    .result-main-table thead th:nth-child(4),
    .result-main-table tbody td:nth-child(4) {
      width: 11%;
    }

    .result-main-table thead th:nth-child(5),
    .result-main-table tbody td:nth-child(5) {
      width: 21%;
    }

    .result-working-table thead th {
      font-size: 0.68rem;
      padding: 8px 5px;
    }

    .result-working-table tbody td {
      font-size: 0.84rem;
      padding: 8px 5px;
    }

    .result-working-table thead th:first-child,
    .result-working-table tbody td:first-child {
      width: 32%;
      padding-left: 10px;
    }

    .working-heading {
      margin: 16px 0 8px;
      font-size: 0.96rem;
      font-weight: 700;
      color: var(--muted);
      line-height: 1.3;
    }

    .result-actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    .result-toggle {
      appearance: none;
      border: 1px solid var(--line-soft);
      border-radius: 8px;
      background: var(--button-bg, #f3f5f8);
      color: var(--text);
      font: inherit;
      font-weight: 600;
      line-height: 1.2;
      padding: 10px 12px;
      cursor: pointer;
      transition: background 0.12s ease, transform 0.12s ease;
    }

    .result-toggle:hover {
      background: var(--button-bg-hover, #eceff4);
      transform: translateY(-1px);
    }

    .result-fallback-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
      color: var(--text);
      text-decoration: none;
    }

    .result-fallback-link:hover {
      text-decoration: underline;
    }

    .event-item {
      border: 1px solid var(--line-soft);
      border-radius: 7px;
      padding: 11px 13px;
      background: var(--button-bg, #f3f5f8);
    }

    .event-date {
      margin: 0 0 3px;
      font-weight: 700;
      font-size: 0.92rem;
      line-height: 1.2;
    }

    .event-time {
      margin: 0 0 5px;
      color: var(--text);
      font-size: 0.92rem;
      line-height: 1.25;
    }

    .event-title {
      margin: 0;
      font-weight: 400;
      font-size: 0.94rem;
      line-height: 1.35;
    }

    .event-meta {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.4;
    }

    @media (max-width: 1120px) {
      .home-grid {
        grid-template-columns: minmax(0, 1fr) minmax(0, 0.92fr) minmax(210px, 0.7fr);
      }
    }

    @media (max-width: 900px) {
      .home-grid {
        grid-template-columns: 1fr;
      }

      .mobile-quick-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }

      .desktop-lostfound {
        display: none;
      }

      .events-card {
        order: 1;
        min-height: 0;
        padding-bottom: 16px;
      }

      .udisc-card {
        order: 99;
      }

      .result-collapse {
        max-height: 250px;
      }
    }

    @media (max-width: 560px) {
      .card {
        padding: 18px 14px 14px;
      }

      .utility-card {
        min-height: 58px;
        padding: 12px 14px;
      }

      .mobile-quick-row {
        gap: 10px;
      }

      .result-title-link,
      .result-title-plain {
        font-size: 0.97rem;
      }

      .result-main-table thead th {
        font-size: 0.56rem;
        padding: 6px 2px;
        letter-spacing: 0;
      }

      .result-main-table tbody td {
        font-size: 0.76rem;
        padding: 6px 2px;
      }

      .result-main-table thead th:first-child,
      .result-main-table tbody td:first-child {
        width: 34%;
        padding-left: 6px;
      }

      .result-main-table thead th:nth-child(2),
      .result-main-table tbody td:nth-child(2),
      .result-main-table thead th:nth-child(3),
      .result-main-table tbody td:nth-child(3),
      .result-main-table thead th:nth-child(4),
      .result-main-table tbody td:nth-child(4) {
        width: 9%;
      }

      .result-main-table thead th:nth-child(5),
      .result-main-table tbody td:nth-child(5) {
        width: 18%;
      }

      .result-working-table thead th {
        font-size: 0.64rem;
        padding: 8px 4px;
      }

      .result-working-table tbody td {
        font-size: 0.82rem;
        padding: 8px 4px;
      }

      .result-actions {
        align-items: stretch;
      }

      .result-toggle,
      .result-fallback-link {
        width: 100%;
      }
    }
  </style>

  <section class="home-grid">
    <div class="mobile-quick-row">
      <a class="utility-card" href={lostFoundUrl}>
        <span class="utility-card-text">Lost &amp; Found</span>
      </a>

      <a class="utility-card" href={handicapTagsUrl}>
        <span class="utility-card-text">Handicaps &amp; Tags</span>
      </a>
    </div>

    <div class="left-stack">
      <div class="card latest-result-card" id="latestResultCard">
        <h2>Latest League Result</h2>

        {latestResult ? (
          <>
            {latestResult.url ? (
              <a class="result-title-link" href={latestResultHref}>
                {latestResult.title}
              </a>
            ) : (
              <p class="result-title-plain">{latestResult.title}</p>
            )}

            <div class="result-collapse" id="latestResultCollapse">
              {hasLatestResultTable ? (
                <>
                  {latestResultMainRows.length > 0 ? (
                    <div class="result-table-block">
                      <div class="result-table-wrap">
                        <table class="result-table result-main-table">
                          <thead>
                            <tr>
                              {latestResultMainColumns.map((column) => (
                                <th>{column.label}</th>
                              ))}
                            </tr>
                          </thead>
                          <tbody>
                            {latestResultMainRows.map((row) => (
                              <tr>
                                {latestResultMainColumns.map((column) => (
                                  <td>{getCellText(row, column.key)}</td>
                                ))}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </div>
                  ) : null}

                  {latestResultWorkingRows.length > 0 ? (
                    <>
                      <p class="working-heading">Working to a handicap</p>
                      <div class="result-table-wrap">
                        <table class="result-table result-working-table">
                          <thead>
                            <tr>
                              {latestResultWorkingColumns.map((column) => (
                                <th>{column.label}</th>
                              ))}
                            </tr>
                          </thead>
                          <tbody>
                            {latestResultWorkingRows.map((row) => (
                              <tr>
                                {latestResultWorkingColumns.map((column) => (
                                  <td>{getCellText(row, column.key)}</td>
                                ))}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </>
                  ) : null}
                </>
              ) : (
                <p class="subtle-note">
                  The latest result is available, but the homepage summary data does not include the full
                  score table.
                </p>
              )}
            </div>

            <div class="result-actions">
              <button
                type="button"
                class="result-toggle"
                id="latestResultToggle"
                aria-controls="latestResultCollapse"
                aria-expanded="false"
                hidden
              >
                Show more
              </button>

              <a class="result-fallback-link" href="/singles/weekly-results">
                View all weekly results <span aria-hidden="true">→</span>
              </a>
            </div>
          </>
        ) : (
          <p class="subtle-note">No recent weekly results are available right now.</p>
        )}
      </div>
    </div>

    <div class="middle-stack">
      <div class="card singles-card">
        <h2>Singles</h2>
        <p class="subtle-note">Thursday evenings April-September</p>
        <div class="link-list">
          {singlesLinks.map((item) => (
            <a class="link-item" href={item.href}>
              <span class="link-item-label">
                <span class="link-item-text">{item.label}</span>
              </span>
              <span class="link-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>

      <div class="card doubles-card">
        <h2>Doubles</h2>
        <p class="subtle-note">Sundays, 9 a.m., year round</p>
        <div class="link-list">
          {doublesLinks.map((item) => (
            <a class="link-item" href={item.href}>
              <span class="link-item-label">
                <span class="link-item-text">{item.label}</span>
              </span>
              <span class="link-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="right-stack">
      <a class="utility-card desktop-lostfound" href={lostFoundUrl}>
        <span class="utility-card-text">Lost &amp; Found</span>
      </a>

      <a
        class="utility-card udisc-card"
        href={udiscLeagueUrl}
        target="_blank"
        rel="noopener"
        aria-label="UDisc"
        title="UDisc"
      >
        <img class="udisc-logo-only udisc-logo-light" src="/udisc-logo.png" alt="UDisc" />
        <img class="udisc-logo-only udisc-logo-dark" src="/udisc-logo-white.png" alt="UDisc" />
      </a>

      <div class="card events-card">
        <h2>Upcoming Events</h2>
        <div id="eventsList" class="event-list" data-has-server-events={upcomingEvents.length > 0 ? "true" : "false"}>
          {upcomingEvents.length > 0 ? (
            upcomingEvents.map((event) => (
              <article class="event-item">
                <p class="event-date">{event.displayDate}</p>
                <p class="event-time">{event.displayTime}</p>
                <p class="event-title">{event.title}</p>
                {event.location ? <p class="event-meta">{event.location}</p> : null}
              </article>
            ))
          ) : (
            <p id="eventsEmpty" class="subtle-note">Loading upcoming events...</p>
          )}
        </div>
      </div>
    </div>
  </section>

  <script>
    (() => {
      const card = document.getElementById("latestResultCard");
      const collapse = document.getElementById("latestResultCollapse");
      const toggle = document.getElementById("latestResultToggle");

      if (!card || !collapse || !toggle) return;

      function syncButton() {
        const expanded = card.classList.contains("is-expanded");
        toggle.textContent = expanded ? "Show less" : "Show more";
        toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
      }

      function updateToggleState() {
        const wasExpanded = card.classList.contains("is-expanded");

        card.classList.remove("is-expanded");

        const overflowing = collapse.scrollHeight > collapse.clientHeight + 4;

        card.classList.toggle("has-overflow", overflowing);

        if (!overflowing) {
          card.classList.add("is-expanded");
          toggle.hidden = true;
          syncButton();
          return;
        }

        if (wasExpanded) {
          card.classList.add("is-expanded");
        }

        toggle.hidden = false;
        syncButton();
      }

      toggle.addEventListener("click", () => {
        card.classList.toggle("is-expanded");
        syncButton();
      });

      if ("ResizeObserver" in window) {
        const ro = new ResizeObserver(() => updateToggleState());
        ro.observe(collapse);
        ro.observe(document.body);
      } else {
        window.addEventListener("resize", updateToggleState);
      }

      window.addEventListener("load", updateToggleState);
      updateToggleState();
    })();
  </script>

  <script>
    (() => {
      const eventsList = document.getElementById("eventsList");
      if (!eventsList) return;

      function escapeHtml(value) {
        return String(value ?? "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function renderEvents(events) {
        if (!Array.isArray(events) || !events.length) {
          eventsList.innerHTML = `<p id="eventsEmpty" class="subtle-note">No upcoming events are available right now.</p>`;
          return;
        }

        eventsList.innerHTML = events
          .map((event) => {
            const locationHtml = event.location
              ? `<p class="event-meta">${escapeHtml(event.location)}</p>`
              : "";

            return `
              <article class="event-item">
                <p class="event-date">${escapeHtml(event.displayDate)}</p>
                <p class="event-time">${escapeHtml(event.displayTime)}</p>
                <p class="event-title">${escapeHtml(event.title)}</p>
                ${locationHtml}
              </article>
            `;
          })
          .join("");
      }

      fetch("https://silent-hill-50calufbery-calendar-api.tylerjhanson.workers.dev", {
        cache: "no-store",
      })
        .then((res) => {
          if (!res.ok) throw new Error(`Calendar API failed: ${res.status}`);
          return res.json();
        })
        .then((data) => {
          renderEvents(data?.upcomingEvents || []);
        })
        .catch((error) => {
          console.error("Client calendar load failed:", error);
          renderEvents([]);
        });
    })();
  </script>
</SiteLayout>
