    .result-working-table tbody td:first-child {
      padding-left: 10px;
    }

    .result-working-table col.col-name {
      width: 72%;
    }

    .result-working-table col.col-score {
      width: 28%;
    }

    .working-heading {
      margin: 16px 0 8px;
      font-size: 0.96rem;
      font-weight: 700;
      color: var(--muted);
      line-height: 1.3;
    }

