  <script>
    (() => {
      const card = document.getElementById("latestResultCard");
      const collapse = document.getElementById("latestResultCollapse");
      const toggle = document.getElementById("latestResultToggle");

      if (!card || !collapse || !toggle) return;

      let userExpanded = false;

      function syncButton() {
        const expanded = card.classList.contains("is-expanded");
        toggle.textContent = expanded ? "Show less" : "Show more";
        toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
      }

      function isDesktopLayout() {
        return window.matchMedia("(min-width: 901px)").matches;
      }

      function setDesktopCollapsedHeight() {
        collapse.style.removeProperty("--result-collapse-max");

        if (!isDesktopLayout()) return false;

        const rows = Array.from(collapse.querySelectorAll(".result-main-table tbody tr, .result-working-table tbody tr"));
        const visibleRows = 10;

        if (rows.length <= visibleRows) return false;

        const collapseTop = collapse.getBoundingClientRect().top;
        const lastVisibleRowBottom = rows[visibleRows - 1].getBoundingClientRect().bottom;
        const collapsedHeight = Math.ceil(lastVisibleRowBottom - collapseTop + 2);

        if (collapsedHeight > 0) {
          collapse.style.setProperty("--result-collapse-max", `${collapsedHeight}px`);
        }

        return true;
      }

      function updateToggleState() {
        card.classList.remove("is-expanded");

        const hasDesktopRowLimit = setDesktopCollapsedHeight();
        const overflowing = hasDesktopRowLimit || collapse.scrollHeight > collapse.clientHeight + 4;

        card.classList.toggle("has-overflow", overflowing);

        if (!overflowing) {
          card.classList.add("is-expanded");
          toggle.hidden = true;
          syncButton();
          return;
        }

        if (userExpanded) {
          card.classList.add("is-expanded");
        }

        toggle.hidden = false;
        syncButton();
      }

      toggle.addEventListener("click", () => {
        userExpanded = !card.classList.contains("is-expanded");
        card.classList.toggle("is-expanded");
        syncButton();
      });

      function runUpdate() {
        updateToggleState();
        requestAnimationFrame(updateToggleState);
      }

      if ("ResizeObserver" in window) {
        const ro = new ResizeObserver(() => runUpdate());
        ro.observe(collapse);
        ro.observe(document.body);
      } else {
        window.addEventListener("resize", runUpdate);
      }

      window.addEventListener("load", runUpdate);
      window.addEventListener("pageshow", runUpdate);
      runUpdate();
    })();
  </script>

  <script>
    (() => {
      const eventsList = document.getElementById("eventsList");
      if (!eventsList) return;

      const CALENDAR_CACHE_KEY = "fa_home_upcoming_events_v3";
      const EVENT_LIMIT = 5;
      const DEFAULT_SCHEDULE_URL = "https://udisc.com/leagues/lufbery-league-NS86wI/schedule";
      const scheduleUrl = eventsList.getAttribute("data-schedule-url") || DEFAULT_SCHEDULE_URL;
      const CACHE_MAX_AGE_MS = 12 * 60 * 60 * 1000;
      const FETCH_TIMEOUT_MS = 3500;
      const POSSIBLE_EVENT_ENDPOINTS = ["/events.json", "/calendar-events.json", "/api/events", "/api/upcoming-events"];

      function escapeHtml(value) {
        return String(value ?? "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function renderEmpty(message) {
        eventsList.innerHTML = '<p class="subtle-note">' + escapeHtml(message) + "</p>";
      }

      function formatEventTime(value) {
        return String(value || "")
          .replace(/\bAM\b/g, "a.m.")
          .replace(/\bPM\b/g, "p.m.")
          .replace(/\bam\b/g, "a.m.")
          .replace(/\bpm\b/g, "p.m.");
      }

      function getEventDateKey(event) {
        const rawDate =
          event.dateKey ||
          event.isoDate ||
          event.startDate ||
          event.start ||
          event.date ||
          event.dateText ||
          "";

        if (typeof rawDate === "string") {
          const isoMatch = rawDate.match(/\b(\d{4}-\d{2}-\d{2})\b/);
          if (isoMatch) return isoMatch[1];

          const monthMatch = rawDate.match(/\b(Jan|January|Feb|February|Mar|March|Apr|April|May|Jun|June|Jul|July|Aug|August|Sep|Sept|September|Oct|October|Nov|November|Dec|December)\.?\s+(\d{1,2})(?:,\s*(\d{4}))?/i);

          if (monthMatch) {
            const monthMap = {
              jan: "01",
              january: "01",
              feb: "02",
              february: "02",
              mar: "03",
              march: "03",
              apr: "04",
              april: "04",
              may: "05",
              jun: "06",
              june: "06",
              jul: "07",
              july: "07",
              aug: "08",
              august: "08",
              sep: "09",
              sept: "09",
              september: "09",
              oct: "10",
              october: "10",
              nov: "11",
              november: "11",
              dec: "12",
              december: "12",
            };

            const year = monthMatch[3] || String(new Date().getFullYear());
            const month = monthMap[monthMatch[1].toLowerCase()];
            const day = String(Number(monthMatch[2])).padStart(2, "0");

            if (month) return `${year}-${month}-${day}`;
          }
        }

        const parsedDate = new Date(rawDate);

        if (!Number.isNaN(parsedDate.getTime())) {
          return [
            parsedDate.getFullYear(),
            String(parsedDate.getMonth() + 1).padStart(2, "0"),
            String(parsedDate.getDate()).padStart(2, "0"),
          ].join("-");
        }

        return "";
      }

      function isCanceledHomeEvent(event) {
        return homeEventOverrides[getEventDateKey(event)]?.canceled === true;
      }

      function normalizeEvents(payload) {
        const events = Array.isArray(payload)
          ? payload
          : Array.isArray(payload?.events)
            ? payload.events
            : Array.isArray(payload?.items)
              ? payload.items
              : [];

        return events
          .filter((event) => !isCanceledHomeEvent(event))
          .map((event) => ({
            date: event.date || event.dateText || event.startDate || event.start || "",
            time: formatEventTime(event.time || event.timeText || ""),
            title: event.title || event.summary || event.name || "League event",
            location: event.location || "",
            url: event.url || event.link || event.htmlLink || event.detailsUrl || scheduleUrl,
          }))
          .filter((event) => event.date || event.time || event.title);
      }

      function formatDisplayDate(date) {
        return new Intl.DateTimeFormat("en-US", {
          weekday: "long",
          month: "short",
          day: "numeric",
        }).format(date);
      }

      function getDateKey(date) {
  return [
    date.getFullYear(),
    String(date.getMonth() + 1).padStart(2, "0"),
    String(date.getDate()).padStart(2, "0"),
  ].join("-");
}

const homeEventOverrides = {
  "2026-05-10": { canceled: true },
  "2026-05-24": { canceled: true },
};

function getLastThursdayDay(year, monthIndex) {
  let day = new Date(year, monthIndex + 1, 0).getDate();

  while (new Date(year, monthIndex, day).getDay() !== 4) {
    day -= 1;
  }

  return day;
}

function getFirstThursdayDay(year, monthIndex) {
  let day = 1;

  while (new Date(year, monthIndex, day).getDay() !== 4) {
    day += 1;
  }

  return day;
}

function isNonDoublesSeasonDate(candidate) {
  const day = candidate.getDay();
  const monthIndex = candidate.getMonth();

  if (day !== 4) return false;

  // April through August: every Thursday
  if (monthIndex >= 3 && monthIndex <= 7) return true;

  // September: only the first Thursday
  if (monthIndex === 8) {
    return candidate.getDate() === getFirstThursdayDay(candidate.getFullYear(), monthIndex);
  }

  return false;
}

function applyHomeEventOverride(date, event) {
  const override = homeEventOverrides[getDateKey(date)];

  if (!override) return event;
  if (override.canceled) return null;

  return {
    ...event,
    ...override,
  };
}

function buildGeneratedEvents(count = EVENT_LIMIT) {
  const events = [];
  const today = new Date();
  const start = new Date(today.getFullYear(), today.getMonth(), today.getDate());

  for (let offset = 0; offset < 370 && events.length < count; offset += 1) {
    const candidate = new Date(start);
    candidate.setDate(start.getDate() + offset);

    const day = candidate.getDay();
    const monthIndex = candidate.getMonth();

    if (day === 0) {
      const event = applyHomeEventOverride(candidate, {
        date: formatDisplayDate(candidate),
        time: "9:00 a.m.",
        title: "Doubles",
        url: scheduleUrl,
      });

      if (event) events.push(event);
      continue;
    }

    if (isNonDoublesSeasonDate(candidate)) {
      const isMonthly =
        candidate.getDate() === getLastThursdayDay(candidate.getFullYear(), monthIndex);

      const event = applyHomeEventOverride(candidate, {
        date: formatDisplayDate(candidate),
        time: "5:30 p.m.",
        title: isMonthly ? "Monthly" : "Handicap",
        url: scheduleUrl,
      });

      if (event) events.push(event);
    }
  }

  return events;
}

      function getFallbackEvents() {
        try {
          const fallbackEvents = JSON.parse(eventsList.getAttribute("data-fallback-events") || "[]");
          if (Array.isArray(fallbackEvents) && fallbackEvents.length) return fallbackEvents;
        } catch (_error) {
          // Use generated events below.
        }

        return buildGeneratedEvents();
      }

      function renderEvents(events) {
        const normalizedEvents = normalizeEvents(events).slice(0, EVENT_LIMIT);

        if (!normalizedEvents.length) {
          renderEmpty("No upcoming events are available right now.");
          return;
        }

        eventsList.innerHTML = normalizedEvents
          .map((event) => {
            const locationHtml = event.location
              ? '<p class="event-meta">' + escapeHtml(event.location) + "</p>"
              : "";

            const href = event.url || scheduleUrl;

            return (
              '<a class="event-item" href="' + escapeHtml(href) + '" target="_blank" rel="noopener">' +
                '<p class="event-date">' + escapeHtml(event.date) + "</p>" +
                (event.time ? '<p class="event-time">' + escapeHtml(event.time) + "</p>" : "") +
                '<p class="event-title">' + escapeHtml(event.title) + "</p>" +
                locationHtml +
              "</a>"
            );
          })
          .join("");
      }

      function readCachedEvents() {
        try {
          const cached = JSON.parse(window.localStorage.getItem(CALENDAR_CACHE_KEY) || "null");
          if (!cached || !Array.isArray(cached.events)) return false;
          if (!cached.cachedAt || Date.now() - cached.cachedAt > CACHE_MAX_AGE_MS) return false;

          renderEvents(cached.events);
          return true;
        } catch (_error) {
          return false;
        }
      }

      async function fetchJsonWithTimeout(endpoint) {
        const controller = "AbortController" in window ? new AbortController() : null;
        const timeoutId = controller
          ? window.setTimeout(() => controller.abort(), FETCH_TIMEOUT_MS)
          : null;

        try {
          const response = await fetch(endpoint, {
            cache: "no-store",
            signal: controller ? controller.signal : undefined,
          });

          if (!response.ok) return null;

          return await response.json();
        } finally {
          if (timeoutId) window.clearTimeout(timeoutId);
        }
      }

      async function fetchEvents() {
        for (const endpoint of POSSIBLE_EVENT_ENDPOINTS) {
          try {
            const payload = await fetchJsonWithTimeout(endpoint);
            if (!payload) continue;

            const events = normalizeEvents(payload).slice(0, EVENT_LIMIT);
            if (!events.length) continue;

            window.localStorage.setItem(
              CALENDAR_CACHE_KEY,
              JSON.stringify({ events, cachedAt: Date.now() })
            );

            renderEvents(events);
            return;
          } catch (_error) {
            // Try the next endpoint.
          }
        }

        if (!readCachedEvents()) {
          renderEvents(buildGeneratedEvents());
        }
      }

      renderEvents(getFallbackEvents());
      fetchEvents();
    })();
  </script>

  <script>
    (() => {
      const leftStack = document.querySelector(".left-stack");
      const middleStack = document.querySelector(".middle-stack");
      const rightStack = document.querySelector(".right-stack");
      const eventsCard = document.getElementById("upcomingEventsCard");

      if (!leftStack || !middleStack || !rightStack || !eventsCard) return;

      function getGapPx(element) {
        const styles = window.getComputedStyle(element);
        return Number.parseFloat(styles.rowGap || styles.gap || "0") || 0;
      }

      function resetEventsHeight() {
        eventsCard.style.minHeight = "";
        eventsCard.style.height = "";
      }

      function alignEventsCard() {
        resetEventsHeight();

        if (window.matchMedia("(max-width: 900px)").matches) return;

        const targetHeight = Math.max(
          leftStack.getBoundingClientRect().height,
          middleStack.getBoundingClientRect().height
        );

        const rightChildren = Array.from(rightStack.children);
        const cardsBeforeEvents = rightChildren.filter((child) => child !== eventsCard);
        const usedHeight = cardsBeforeEvents.reduce(
          (total, child) => total + child.getBoundingClientRect().height,
          0
        );
        const gapTotal = getGapPx(rightStack) * Math.max(rightChildren.length - 1, 0);
        const targetEventsHeight = Math.max(0, targetHeight - usedHeight - gapTotal);

        if (targetEventsHeight > 0) {
          const height = Math.ceil(targetEventsHeight);
          eventsCard.style.minHeight = `${height}px`;
          eventsCard.style.height = `${height}px`;
        }
      }

      function runAlign() {
        alignEventsCard();
        requestAnimationFrame(alignEventsCard);
      }

      window.addEventListener("load", runAlign);
      window.addEventListener("resize", runAlign);
      window.addEventListener("pageshow", runAlign);
      document.addEventListener("astro:page-load", runAlign);

      if ("ResizeObserver" in window) {
        const observer = new ResizeObserver(runAlign);
        observer.observe(leftStack);
        observer.observe(middleStack);
        observer.observe(rightStack);
        observer.observe(eventsCard);
      }

      runAlign();
    })();
  </script>

  <PlayerModal profiles={playerProfiles} />
</SiteLayout>
