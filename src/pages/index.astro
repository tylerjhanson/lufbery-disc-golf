      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    .result-toggle,
    .result-view-full {
      appearance: none;
      border: 1px solid var(--line-soft);
      border-radius: 8px;
      background: var(--button-bg, #f3f5f8);
      color: var(--text);
      font: inherit;
      font-weight: 500;
      line-height: 1.2;
      padding: 10px 12px;
      transition: background 0.12s ease, transform 0.12s ease;
      min-height: 42px;
