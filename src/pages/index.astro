    }

    .event-meta {
      margin: 0;
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.4;
    }

    @media (max-width: 900px) {
  .home-grid {
    grid-template-columns: 1fr;
  }

  .mobile-quick-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .desktop-lostfound {
    display: none;
  }

  .result-collapse {
    max-height: 250px;
  }
}

   @media (max-width: 560px) {
  .card {
    padding: 18px 14px 14px;
  }

  .utility-card {
    min-height: 58px;
    padding: 12px 14px;
  }

  .mobile-quick-row {
    gap: 10px;
  }

  .result-title-link,
  .result-title-plain {
    font-size: 1.08rem;
  }

  .result-table {
    font-size: 0.84rem;
  }

  .result-table thead th {
    font-size: 0.62rem;
    padding: 8px 5px 6px;
  }

  .result-table tbody td {
    padding: 6px 5px;
  }

  .result-table th:first-child,
  .result-table td:first-child {
    padding-left: 8px;
  }

  .result-table th:last-child,
  .result-table td:last-child {
    padding-right: 8px;
  }

  .result-actions {
    align-items: stretch;
  }

  .result-toggle,
  .result-fallback-link {
    width: 100%;
  }
}
  </style>

  <section class="home-grid">
    <div class="mobile-quick-row">
      <a class="utility-card" href={lostFoundUrl}>
        <span class="utility-card-text">Lost &amp; Found</span>
      </a>

      <a class="utility-card" href={handicapTagsUrl}>
        <span class="utility-card-text">Handicaps &amp; Tags</span>
      </a>
    </div>

    <div class="left-stack">
      <div class="card latest-result-card" id="latestResultCard">
        <h2>Latest League Result</h2>

        {latestResult ? (
          <>
            {latestResult.url ? (
              <a class="result-title-link" href={latestResultHref}>
                {latestResult.title}
              </a>
            ) : (
              <p class="result-title-plain">{latestResult.title}</p>
            )}

            <div class="result-collapse" id="latestResultCollapse">
              {hasLatestResultTable ? (
                <>
                  {latestResultMainRows.length > 0 ? (
                    <div class="result-table-block">
                      <div class="result-table-wrap">
                        <table class="result-table">
                          <thead>
                            <tr>
                              {latestResultMainColumns.map((column) => (
                                <th>{column.label}</th>
                              ))}
                            </tr>
                          </thead>
                          <tbody>
                            {latestResultMainRows.map((row) => (
                              <tr>
                                {latestResultMainColumns.map((column) => (
                                  <td>{getCellText(row, column.key)}</td>
                                ))}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </div>
                  ) : null}

                  {latestResultWorkingRows.length > 0 ? (
                    <>
                      <p class="working-heading">Working to a handicap</p>
                      <div class="result-table-wrap">
                        <table class="result-table">
                          <thead>
                            <tr>
                              {latestResultWorkingColumns.map((column) => (
                                <th>{column.label}</th>
                              ))}
                            </tr>
                          </thead>
                          <tbody>
                            {latestResultWorkingRows.map((row) => (
                              <tr>
                                {latestResultWorkingColumns.map((column) => (
                                  <td>{getCellText(row, column.key)}</td>
                                ))}
                              </tr>
                            ))}
                          </tbody>
                        </table>
                      </div>
                    </>
                  ) : null}
                </>
              ) : (
                <p class="subtle-note">
                  The latest result is available, but the homepage summary data does not include the full
                  score table.
                </p>
              )}
            </div>

            <div class="result-actions">
              <button
  type="button"
  class="result-toggle"
  id="latestResultToggle"
  aria-controls="latestResultCollapse"
  aria-expanded="false"
  hidden
>
  Show more
</button>

              <a class="result-fallback-link" href="/singles/weekly-results">
                View all weekly results <span aria-hidden="true">→</span>
              </a>
            </div>
          </>
        ) : (
          <p class="subtle-note">No recent weekly results are available right now.</p>
        )}
      </div>
    </div>

    <div class="middle-stack">
      <div class="card singles-card">
        <h2>Singles</h2>
        <p class="subtle-note">Thursday evenings April-September</p>
        <div class="link-list">
          {singlesLinks.map((item) => (
            <a class="link-item" href={item.href}>
              <span class="link-item-label">
                <span class="link-item-text">{item.label}</span>
              </span>
              <span class="link-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>

      <div class="card doubles-card">
        <h2>Doubles</h2>
        <p class="subtle-note">Sundays, 9 a.m., year round</p>
        <div class="link-list">
          {doublesLinks.map((item) => (
            <a class="link-item" href={item.href}>
              <span class="link-item-label">
                <span class="link-item-text">{item.label}</span>
              </span>
              <span class="link-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="right-stack">
      <a class="utility-card desktop-lostfound" href={lostFoundUrl}>
  <span class="utility-card-text">Lost &amp; Found</span>
</a>

<a
  class="utility-card udisc-card"
  href={udiscLeagueUrl}
  target="_blank"
  rel="noopener"
  aria-label="UDisc"
  title="UDisc"
>
  <img class="udisc-logo-only" src="/udisc-logo.png" alt="UDisc" />
</a>

      <div class="card events-card">
        <h2>Upcoming Events</h2>
        {upcomingEvents.length > 0 ? (
          <div class="event-list">
            {upcomingEvents.map((event) => (
              <article class="event-item">
                <p class="event-date">
                  {event.displayDate} · {event.displayTime}
                </p>
                <p class="event-title">{event.title}</p>
                {event.location ? <p class="event-meta">{event.location}</p> : null}
              </article>
            ))}
          </div>
        ) : (
          <p class="subtle-note">No upcoming events are available right now.</p>
        )}
      </div>
    </div>
  </section>

  <script>
    <script>
  (() => {
    const card = document.getElementById("latestResultCard");
    const collapse = document.getElementById("latestResultCollapse");
    const toggle = document.getElementById("latestResultToggle");

    if (!card || !collapse || !toggle) return;

    function syncButton() {
      const expanded = card.classList.contains("is-expanded");
      toggle.textContent = expanded ? "Show less" : "Show more";
      toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
    }

    function updateToggleState() {
      const wasExpanded = card.classList.contains("is-expanded");

      card.classList.remove("is-expanded");

      const overflowing = collapse.scrollHeight > collapse.clientHeight + 4;

      card.classList.toggle("has-overflow", overflowing);

      if (!overflowing) {
        card.classList.add("is-expanded");
        toggle.hidden = true;
        syncButton();
        return;
      }

      if (wasExpanded) {
        card.classList.add("is-expanded");
      }

      toggle.hidden = false;
      syncButton();
    }

    toggle.addEventListener("click", () => {
      card.classList.toggle("is-expanded");
      syncButton();
    });

    if ("ResizeObserver" in window) {
      const ro = new ResizeObserver(() => updateToggleState());
      ro.observe(collapse);
      ro.observe(document.body);
    } else {
      window.addEventListener("resize", updateToggleState);
    }

    window.addEventListener("load", updateToggleState);
    updateToggleState();
  })();
</script>
</SiteLayout>
