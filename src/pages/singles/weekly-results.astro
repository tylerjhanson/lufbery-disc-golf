---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getWeeklyResults } from "../../lib/data";

const events = getWeeklyResults();

function getEventDateParts(title: string) {
  const match = String(title || "").match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})/);
  if (!match) return null;

  const month = Number(match[1]);
  const day = Number(match[2]);
  let year = Number(match[3]);

  if (year < 100) year += 2000;

  return { month, day, year };
}

function getEventTimestamp(title: string) {
  const parts = getEventDateParts(title);
  if (!parts) return 0;
  return new Date(parts.year, parts.month - 1, parts.day).getTime();
}

function getEventYear(title: string) {
  const parts = getEventDateParts(title);
  return parts ? String(parts.year) : "";
}

function getRoundType(event: { title?: string; kind?: string }) {
  const title = String(event?.title || "").toLowerCase();

  if (
    title.includes("2 rounds") ||
    title.includes("2 round") ||
    title.includes("2-round") ||
    title.includes("27 hole") ||
    title.includes("27-hole") ||
    title.includes("27 holes") ||
    title.includes("27-holes")
  ) {
    return "2-rounds";
  }

  if (event?.kind === "handicap" || title.includes("handicap")) {
    return "handicap";
  }

  return "monthly";
}

function cleanPlayerName(value: unknown) {
  return String(value || "").replace(/\s+/g, " ").trim();
}

function normalizeHeaderValue(value: unknown) {
  return cleanPlayerName(value).toLowerCase();
}

function getCellValueByHeaders(headers: unknown[], row: unknown[], headerNames: string[]) {
  const normalizedHeaders = (headers || []).map((header) =>
    cleanPlayerName(header).toLowerCase()
  );

  for (const headerName of headerNames) {
    const index = normalizedHeaders.indexOf(headerName.toLowerCase());
    if (index !== -1) {
      return String((row || [])[index] ?? "").trim();
    }
  }

  return "";
}

function isValidPlayerOption(value: unknown) {
  const name = cleanPlayerName(value).toLowerCase();

  return (
    !!name &&
    name !== "name" &&
    name !== "working towards a handicap" &&
    name !== "working to a handicap"
  );
}

function getEventPlayers(event: any) {
  const values: string[] = [];

  if (event.kind === "handicap") {
    if (Array.isArray(event.rows)) {
      event.rows.forEach((row: any) => {
        const name = cleanPlayerName(row?.name);
        if (isValidPlayerOption(name)) values.push(name);
      });
    }

    if (event.working?.rows && Array.isArray(event.working.rows)) {
      event.working.rows.forEach((row: any[]) => {
        const name = cleanPlayerName(row?.[0]);
        if (isValidPlayerOption(name)) values.push(name);
      });
    }
  }

  if (event.kind === "pools" && Array.isArray(event.pools)) {
    event.pools.forEach((pool: any) => {
      if (Array.isArray(pool?.rows)) {
        pool.rows.forEach((row: any[]) => {
          const name = cleanPlayerName(row?.[0]);
          if (isValidPlayerOption(name)) values.push(name);
        });
      }
    });
  }

  return [...new Set(values)];
}

function getVisibleColumnIndexes(headers: unknown[], hiddenHeaders: string[]) {
  const hidden = hiddenHeaders.map((header) => normalizeHeaderValue(header));

  return (headers || [])
    .map((_, index) => index)
    .filter((index) => !hidden.includes(normalizeHeaderValue(headers[index])));
}

const sortedEvents = [...events].sort(
  (a, b) => getEventTimestamp(b.title) - getEventTimestamp(a.title)
);

const eventYears = [
  ...new Set(sortedEvents.map((event) => getEventYear(event.title)).filter(Boolean)),
].sort((a, b) => Number(b) - Number(a));

const defaultYear = "all";
const defaultRoundType = "all";
---

<SiteLayout title="Weekly Results" showBrandBar={true}>
  <style>
    :root {
      --bg: #f5f7fb;
      --card: #ffffff;
      --text: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --line-soft: #eef2f7;
      --header: #f8fafc;
      --hover: #f9fbff;
      --accent: #2563eb;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      --radius: 22px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 24px;
      font-family: Inter, Arial, Helvetica, sans-serif;
      background: linear-gradient(180deg, #f8fafc 0%, var(--bg) 100%);
      color: var(--text);
    }

    .wrap {
      width: 100%;
      max-width: none;
      margin: 0;
    }

    .page-header {
      margin-bottom: 18px;
    }

    .weekly-results-page {
      overflow-x: hidden;
    }

    .results-toolbar {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 10px;
    }

    .results-toolbar label {
      min-width: 150px;
    }

    .search-wrap {
      position: relative;
      width: min(360px, 100%);
      flex: 1 1 280px;
    }

    .search-input {
      width: 100%;
      padding: 11px 42px 11px 13px;
      border: 1px solid var(--line-soft);
      border-radius: 9px;
      background: var(--card);
      color: var(--text);
      font: inherit;
    }

    .search-clear {
      position: absolute;
      top: 50%;
      right: 9px;
      transform: translateY(-50%);
      width: 26px;
      height: 26px;
      border: 1px solid var(--line-soft);
      border-radius: 999px;
      background: #fff;
      color: #94a3b8;
      font-size: 0.95rem;
      line-height: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s ease, color 0.15s ease, background 0.15s ease;
    }

    .search-wrap.has-value .search-clear {
      opacity: 1;
      pointer-events: auto;
    }

    .search-clear:hover {
      color: var(--text);
      background: #f8fafc;
    }

    .filter-select {
      min-width: 170px;
      padding: 10px 12px;
      border: 1px solid var(--line-soft);
      border-radius: 9px;
      background: var(--card);
      color: var(--text);
      font: inherit;
    }

    .empty-state {
      display: none;
      padding: 14px 4px 0;
      color: var(--muted);
    }

    h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
    }

    .events {
      display: grid;
      gap: 14px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-radius: 10px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .card-header {
      padding: 12px 12px 10px;
    }

    .card-title {
      margin: 0;
      font-size: 1rem;
      line-height: 1.2;
    }

    .event-link,
    .event-link:visited {
      color: #2563eb;
      text-decoration: none;
      font-weight: 600;
    }

    .event-link:hover,
    .event-link:focus-visible {
      color: #1d4ed8;
      text-decoration: underline;
    }

    .event-summary {
      margin-top: 10px;
      display: grid;
      gap: 10px;
    }

    .summary-group {
      display: grid;
      gap: 4px;
    }

    .summary-label {
      color: var(--text);
      font-size: 0.88rem;
      font-weight: 800;
      line-height: 1.2;
    }

    .summary-item {
      color: var(--text);
      font-size: 0.9rem;
      line-height: 1.3;
    }

    .section-block {
      padding: 0 4px 6px;
    }

    .subheading {
      margin: 4px 0 10px;
      font-size: 0.96rem;
      color: var(--muted);
      font-weight: 700;
    }

    .table-wrap {
      padding: 0;
      overflow-x: visible;
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: auto;
      min-width: 0;
    }

    .weekly-results-page table.handicap-table {
      table-layout: fixed;
    }

    thead th {
      background: var(--header);
      color: var(--muted);
      font-size: 0.76rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      padding: 10px 6px;
      border-bottom: 1px solid var(--line);
      text-align: center;
      white-space: normal;
      line-height: 1.1;
    }

    thead th:first-child {
      text-align: left;
      border-top-left-radius: 14px;
    }

    thead th:last-child {
      border-top-right-radius: 14px;
    }

    tbody td {
      padding: 9px 6px;
      border-bottom: 1px solid var(--line-soft);
      font-size: 0.9rem;
      text-align: center;
      vertical-align: middle;
      line-height: 1.15;
      white-space: normal;
    }

    tbody tr:nth-child(even) td {
      background: #fcfdff;
    }

    tbody tr:hover td {
      background: var(--hover);
    }

    tbody td:first-child {
      text-align: left;
      font-weight: 600;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    thead th:first-child,
    tbody td:first-child {
      width: 34%;
    }

    tbody td:not(:first-child) {
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .player-match-row td {
      background: #eff6ff !important;
    }

    td.player-name-cell.player-match-name {
      background: #dbeafe !important;
      color: #1d4ed8 !important;
      font-weight: 700 !important;
      box-shadow: inset 0 0 0 1px rgba(37, 99, 235, 0.18);
    }

    .weekly-results-page table.handicap-table thead th {
      font-size: 0.66rem !important;
      padding: 8px 4px !important;
      line-height: 1.05 !important;
    }

    .weekly-results-page table.handicap-table tbody td {
      font-size: 0.82rem !important;
      padding: 7px 4px !important;
      line-height: 1.08 !important;
      vertical-align: top !important;
    }

    .weekly-results-page table.handicap-table thead th:first-child,
    .weekly-results-page table.handicap-table tbody td:first-child {
      width: 34% !important;
    }

    .weekly-results-page table.handicap-table th:nth-child(n + 2),
    .weekly-results-page table.handicap-table td:nth-child(n + 2) {
      text-align: center !important;
    }

    .weekly-results-page table.working-table thead th,
    .weekly-results-page table.pool-table thead th {
      font-size: 0.68rem !important;
      padding: 8px 5px !important;
    }

    .weekly-results-page table.working-table tbody td,
    .weekly-results-page table.pool-table tbody td {
      font-size: 0.84rem !important;
      padding: 8px 5px !important;
      line-height: 1.1 !important;
    }

    .weekly-results-page table.working-table thead th:first-child,
    .weekly-results-page table.working-table tbody td:first-child,
    .weekly-results-page table.pool-table thead th:first-child,
    .weekly-results-page table.pool-table tbody td:first-child {
      width: 32% !important;
    }

    .weekly-results-page tbody td:first-child {
      font-weight: 400 !important;
    }

    @media (max-width: 700px) {
      body {
        padding: 8px;
      }

      .results-toolbar {
        display: grid;
        grid-template-columns: 1.35fr 0.9fr 1.05fr;
        gap: 8px;
        align-items: stretch;
      }

      .results-toolbar label {
        min-width: 0;
        width: 100%;
      }

      .search-wrap {
        width: 100%;
      }

      .search-input {
        width: 100%;
        padding: 10px 40px 10px 12px;
        font-size: 0.92rem;
      }

      .filter-select {
        min-width: 0;
        width: 100%;
        padding: 9px 10px;
        font-size: 0.92rem;
      }

      .card-header {
        padding: 10px 10px 8px !important;
      }

      .card-title {
        font-size: 0.95rem !important;
      }

      .summary-label {
        font-size: 0.83rem;
      }

      .summary-item {
        font-size: 0.84rem;
      }

      .section-block {
        padding: 0 2px 6px !important;
      }

      .table-wrap {
        overflow-x: visible;
      }

      .weekly-results-page table.handicap-table thead th {
        font-size: 0.58rem !important;
        padding: 6px 2px !important;
        letter-spacing: 0 !important;
      }

      .weekly-results-page table.handicap-table tbody td {
        font-size: 0.76rem !important;
        padding: 6px 2px !important;
        line-height: 1.06 !important;
      }

      .weekly-results-page table.handicap-table thead th:first-child,
      .weekly-results-page table.handicap-table tbody td:first-child {
        width: 32% !important;
      }

      .weekly-results-page table.working-table thead th,
      .weekly-results-page table.pool-table thead th {
        font-size: 0.64rem !important;
        padding: 8px 4px !important;
      }

      .weekly-results-page table.working-table tbody td,
      .weekly-results-page table.pool-table tbody td {
        font-size: 0.82rem !important;
        padding: 8px 4px !important;
      }
    }

    @media (max-width: 420px) {
      h1 {
        font-size: 1.9rem;
      }

      .card-title {
        font-size: 0.92rem;
      }

      thead th {
        font-size: 0.58rem;
        padding: 7px 3px;
      }

      tbody td {
        font-size: 0.74rem;
        padding: 6px 3px;
      }

      thead th:first-child,
      tbody td:first-child {
        width: 30%;
      }
    }
  </style>

  <div class="wrap weekly-results-page">
    <div class="page-header">
      <h1>Weekly Results</h1>
    </div>

    <div class="results-toolbar">
      <div id="searchWrap" class="search-wrap">
        <input
          id="playerSearch"
          class="search-input"
          type="text"
          placeholder="Search player"
          aria-label="Search player"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
        />
        <button
          id="clearSearch"
          class="search-clear"
          type="button"
          aria-label="Clear search"
          title="Clear search"
        >
          ×
        </button>
      </div>

      <label>
        <select id="yearFilter" class="filter-select" aria-label="Filter results by year">
          <option value="all" selected={defaultYear === "all"}>All Years</option>
          {eventYears.map((year) => (
            <option value={year}>{year}</option>
          ))}
        </select>
      </label>

      <label>
        <select
          id="roundTypeFilter"
          class="filter-select"
          aria-label="Filter results by round type"
        >
          <option value="all" selected={defaultRoundType === "all"}>All Rounds</option>
          <option value="handicap">Handicap</option>
          <option value="monthly">Monthly</option>
          <option value="2-rounds">2 Rounds</option>
        </select>
      </label>
    </div>

    <div id="resultsEvents" class="events">
      {sortedEvents.map((event) => (
        <section
          class="card"
          data-year={getEventYear(event.title) || ""}
          data-round-type={getRoundType(event)}
          data-timestamp={String(getEventTimestamp(event.title))}
        >
          <div class="card-header">
            <h2 class="card-title">
              {event.url ? (
                <a class="event-link" href={event.url} target="_blank" rel="noopener">
                  {event.title}
                </a>
              ) : (
                event.title
              )}
            </h2>

            {(event.summary?.overall?.length ||
              event.summary?.ctps?.length ||
              event.summary?.aces?.length) > 0 && (
              <div class="event-summary">
                {event.summary?.overall?.length > 0 && (
                  <div class="summary-group">
                    <div class="summary-label">Best Overall</div>
                    {event.summary.overall.map((item: any) => (
                      <div class="summary-item">{item.text}</div>
                    ))}
                  </div>
                )}

                {event.summary?.ctps?.length > 0 && (
                  <div class="summary-group">
                    <div class="summary-label">CTP&apos;s</div>
                    {event.summary.ctps.map((item: any) => (
                      <div class="summary-item">{item.text}</div>
                    ))}
                  </div>
                )}

                {event.summary?.aces?.length > 0 && (
                  <div class="summary-group">
                    <div class="summary-label">
                      {event.summary.aces.length === 1 ? "Ace" : "Aces"}
                    </div>
                    {event.summary.aces.map((item: any) => (
                      <div class="summary-item">{item.text}</div>
                    ))}
                  </div>
                )}
              </div>
            )}
          </div>

          {event.kind === "handicap" && (
            <>
              <div class="section-block">
                <div class="table-wrap">
                  <table class="handicap-table">
                    <thead>
                      <tr>
                        {["Name", "Raw", "Hcp.", "Net", "Payout"].map((header) => (
                          <th>{header}</th>
                        ))}
                      </tr>
                    </thead>
                    <tbody>
                      {event.rows.map((row: any) => (
                        <tr
                          data-player-name={cleanPlayerName(row.name)}
                          data-raw-score={String(row.raw ?? "")}
                        >
                          <td data-label="Name" class="player-name-cell">{row.name}</td>
                          <td data-label="Raw">{row.raw}</td>
                          <td data-label="Hcp.">{row.hcp}</td>
                          <td data-label="Net">{row.net}</td>
                          <td data-label="Payout">{row.payout}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>

              {event.working && event.working.rows.length > 0 && (
                <div class="section-block">
                  <div class="table-wrap">
                    <table class="working-table">
                      <thead>
                        <tr>
                          {getVisibleColumnIndexes(event.working.headers, ["Overall", "Ovr", "CTP"]).map(
                            (idx) => <th>{event.working.headers[idx]}</th>
                          )}
                        </tr>
                      </thead>
                      <tbody>
                        {event.working.rows.map((row: any[]) => (
                          <tr
                            data-player-name={cleanPlayerName(row?.[0])}
                            data-raw-score={getCellValueByHeaders(
                              event.working.headers,
                              row,
                              ["R1", "Round 1", "Raw", "Score"]
                            )}
                          >
                            {getVisibleColumnIndexes(event.working.headers, ["Overall", "Ovr", "CTP"]).map(
                              (idx) => (
                                <td
                                  data-label={event.working.headers[idx] || ""}
                                  class={idx === 0 ? "player-name-cell" : undefined}
                                >
                                  {row[idx]}
                                </td>
                              )
                            )}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              )}
            </>
          )}

          {event.kind === "pools" &&
            event.pools.map((pool: any) => (
              <div class="section-block">
                <div class="subheading">{pool.title}</div>
                <div class="table-wrap">
                  <table class="pool-table">
                    <thead>
                      <tr>
                        {getVisibleColumnIndexes(pool.headers, ["CTP"]).map((idx) => (
                          <th>{pool.headers[idx]}</th>
                        ))}
                      </tr>
                    </thead>
                    <tbody>
                      {pool.rows.map((row: any[]) => (
                        <tr
                          data-player-name={cleanPlayerName(row?.[0])}
                          data-raw-score={getCellValueByHeaders(
                            pool.headers,
                            row,
                            ["R1", "Round 1", "Raw", "Score"]
                          )}
                        >
                          {getVisibleColumnIndexes(pool.headers, ["CTP"]).map((idx) => (
                            <td
                              data-label={pool.headers[idx] || ""}
                              class={idx === 0 ? "player-name-cell" : undefined}
                            >
                              {row[idx]}
                            </td>
                          ))}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            ))}
        </section>
      ))}
    </div>

    <div id="resultsEmpty" class="empty-state">No results found for the selected filters.</div>
  </div>

  <script>
    const yearFilter = document.getElementById("yearFilter");
    const roundTypeFilter = document.getElementById("roundTypeFilter");
    const playerSearch = document.getElementById("playerSearch");
    const searchWrap = document.getElementById("searchWrap");
    const clearSearch = document.getElementById("clearSearch");
    const eventCards = Array.from(document.querySelectorAll("#resultsEvents > .card"));
    const resultsEmpty = document.getElementById("resultsEmpty");
    const resultsEvents = document.getElementById("resultsEvents");

    function normalizeValue(value) {
      return String(value || "").toLowerCase().replace(/\s+/g, " ").trim();
    }

    function updateSearchClear() {
      if (!searchWrap || !playerSearch) return;
      searchWrap.classList.toggle("has-value", !!playerSearch.value.trim());
    }

    function sortCardsNewestFirst() {
      if (!resultsEvents) return;

      const sortedCards = [...eventCards].sort((a, b) => {
        const aTime = Number(a.getAttribute("data-timestamp") || "0");
        const bTime = Number(b.getAttribute("data-timestamp") || "0");
        return bTime - aTime;
      });

      resultsEvents.append(...sortedCards);
    }

    function cardHasPlayer(card, query) {
      if (!query) return true;

      const queryNorm = normalizeValue(query);
      const playerRows = Array.from(card.querySelectorAll("tr[data-player-name]"));

      return playerRows.some((row) => {
        const rowPlayer = normalizeValue(row.getAttribute("data-player-name") || "");
        return rowPlayer.includes(queryNorm);
      });
    }

    function clearHighlights(card) {
      card.querySelectorAll(".player-match-row").forEach((row) => {
        row.classList.remove("player-match-row");
      });

      card.querySelectorAll(".player-name-cell").forEach((cell) => {
        cell.classList.remove("player-match-name");
      });
    }

    function applyHighlights(card, query) {
      clearHighlights(card);

      if (!query) return;

      const queryNorm = normalizeValue(query);
      const rows = Array.from(card.querySelectorAll("tr[data-player-name]"));

      rows.forEach((row) => {
        const rowPlayer = normalizeValue(row.getAttribute("data-player-name") || "");
        if (!rowPlayer.includes(queryNorm)) return;

        row.classList.add("player-match-row");

        const nameCell = row.querySelector(".player-name-cell");
        if (nameCell) {
          nameCell.classList.add("player-match-name");
        }
      });
    }

    function applyFilters() {
      const selectedYear = yearFilter?.value || "all";
      const selectedRoundType = roundTypeFilter?.value || "all";
      const playerQuery = playerSearch?.value?.trim() || "";

      let visible = 0;

      eventCards.forEach((card) => {
        const year = card.getAttribute("data-year") || "";
        const roundType = card.getAttribute("data-round-type") || "";

        const matchesYear = selectedYear === "all" || selectedYear === year;
        const matchesRoundType =
          selectedRoundType === "all" || selectedRoundType === roundType;
        const matchesPlayer = cardHasPlayer(card, playerQuery);

        const show = matchesYear && matchesRoundType && matchesPlayer;

        card.style.display = show ? "" : "none";

        clearHighlights(card);
        if (show && playerQuery) {
          applyHighlights(card, playerQuery);
        }

        if (show) visible += 1;
      });

      if (resultsEmpty) {
        resultsEmpty.style.display = visible ? "none" : "block";
      }

      updateSearchClear();
    }

    yearFilter?.addEventListener("change", applyFilters);
    roundTypeFilter?.addEventListener("change", applyFilters);
    playerSearch?.addEventListener("input", applyFilters);

    clearSearch?.addEventListener("click", () => {
      if (!playerSearch) return;
      playerSearch.value = "";
      applyFilters();
      playerSearch.focus();
    });

    sortCardsNewestFirst();
    applyFilters();
    updateSearchClear();
  </script>
</SiteLayout>
