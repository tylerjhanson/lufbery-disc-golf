---
import { getPlayerProfiles, getSinglesRecords } from "../../lib/data";
import PlayerLink from "../../components/PlayerLink.astro";
import PlayerModal from "../../components/PlayerModal.astro";
import SiteLayout from "../../layouts/SiteLayout.astro";

const rows = getSinglesRecords();
const playerProfiles = getPlayerProfiles();

function getDateParts(value: string) {
  const match = String(value || "").match(/(\d{1,2})\/(\d{1,2})\/(\d{2,4})/);
  if (!match) return null;

  const month = Number(match[1]);
  const day = Number(match[2]);
  let year = Number(match[3]);

  if (year < 100) year += 2000;

  return { month, day, year };
}

function getRowYear(value: string) {
  const parts = getDateParts(value);
  return parts ? String(parts.year) : "";
}

function getScoreSortValue(value: string) {
  const text = String(value || "").trim();

  if (!text) return "";
  if (/^e$/i.test(text)) return "56";

  const match = text.match(/-?\d+(\.\d+)?/);
  return match ? match[0] : "";
}

function isUdiscUrl(value: string) {
  return /(^https?:\/\/)?(www\.)?udisc\.com\b/i.test(String(value || "").trim());
}

const recordYears = [...new Set(rows.map((row) => getRowYear(row.date)).filter(Boolean))].sort(
  (a, b) => Number(b) - Number(a)
);
---

<SiteLayout title="Singles Records" showBrandBar={true}>
  <style>
    :root {
      --bg: #f5f7fb;
      --card: #ffffff;
      --text: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --line-soft: #eef2f7;
      --header: #f8fafc;
      --hover: #f9fbff;
      --accent: #2563eb;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      --radius: 22px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      padding: 24px;
      font-family: Inter, Arial, Helvetica, sans-serif;
      background: linear-gradient(180deg, #f8fafc 0%, var(--bg) 100%);
      color: var(--text);
    }

    .wrap {
      width: 100%;
      max-width: none;
      margin: 0;
    }

    .page-header {
      margin-bottom: 18px;
    }

    .toolbar {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .filter-select {
      min-width: 170px;
      padding: 10px 12px;
      border: 1px solid var(--line-soft);
      border-radius: 9px;
      background: var(--card);
      color: var(--text);
      font: inherit;
    }

    .empty-state {
      display: none;
      padding: 14px 20px 18px;
      color: var(--muted);
    }

    .card {
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .card-header {
      padding: 26px 28px 14px;
    }

    h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
    }

    .table-wrap {
      padding: 0 20px 10px;
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: fixed;
    }

    col.name-col { width: 46%; }
    col.score-col { width: 20%; }
    col.date-col { width: 34%; }

    thead th {
      background: var(--header);
      color: var(--muted);
      font-size: 0.86rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      padding: 14px 16px;
      border-bottom: 1px solid var(--line);
      text-align: center;
      user-select: none;
    }

    thead th.sortable {
      cursor: pointer;
      transition: background 0.15s ease, color 0.15s ease;
    }

    thead th.sortable:hover {
      background: #f1f5f9;
      color: var(--text);
    }

    thead th:first-child {
      border-top-left-radius: 14px;
      text-align: left;
    }

    thead th:last-child {
      border-top-right-radius: 14px;
    }

    .th-inner {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
    }

    thead th:first-child .th-inner {
      justify-content: flex-start;
    }

    .sort-indicator {
      display: inline-block;
      width: 12px;
      color: #94a3b8;
      font-size: 0.8rem;
      flex: 0 0 12px;
    }

    tbody td {
      padding: 15px 16px;
      border-bottom: 1px solid var(--line-soft);
      font-size: 1rem;
      text-align: center;
      vertical-align: middle;
    }

    tbody tr:nth-child(even) td {
      background: #fcfdff;
    }

    tbody tr:hover td {
      background: var(--hover);
    }

    tbody td:first-child {
      text-align: left;
      font-weight: 600;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .date-link {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
    }

    .date-link:hover {
      text-decoration: underline;
    }

    .date-link-inline {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .udisc-icon {
      height: 0.82em;
      width: auto;
      display: inline-block;
      vertical-align: middle;
      flex: 0 0 auto;
      opacity: 0.98;
      transform: translateY(-0.11em);
    }

    .udisc-icon--dark {
      display: none;
    }

    :global(html.dark) .udisc-icon--light,
    :global(html[data-theme="dark"]) .udisc-icon--light,
    :global(body.dark) .udisc-icon--light,
    :global(body[data-theme="dark"]) .udisc-icon--light {
      display: none;
    }

    :global(html.dark) .udisc-icon--dark,
    :global(html[data-theme="dark"]) .udisc-icon--dark,
    :global(body.dark) .udisc-icon--dark,
    :global(body[data-theme="dark"]) .udisc-icon--dark {
      display: inline-block;
    }

    @media (prefers-color-scheme: dark) {
      .udisc-icon--light {
        display: none;
      }

      .udisc-icon--dark {
        display: inline-block;
      }
    }

    .footer-link {
      padding: 18px 28px 26px;
    }

    .footer-link a {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
    }

    .footer-link a:hover {
      text-decoration: underline;
    }

    @media (max-width: 700px) {
      body { padding: 10px; }
      .card-header { padding: 18px 16px 10px; }
      h1 { font-size: 2.1rem; }
      .table-wrap { padding: 0 8px 8px; }

      col.name-col { width: 42%; }
      col.score-col { width: 22%; }
      col.date-col { width: 36%; }

      thead th {
        font-size: 0.72rem;
        letter-spacing: 0.02em;
        padding: 10px 6px;
      }

      tbody td {
        font-size: 0.9rem;
        padding: 10px 6px;
      }

      .footer-link {
        padding: 14px 16px 18px;
      }
    }

    @media (max-width: 420px) {
      h1 { font-size: 1.95rem; }

      thead th {
        font-size: 0.68rem;
        padding: 9px 4px;
      }

      tbody td {
        font-size: 0.86rem;
        padding: 9px 4px;
      }
    }
  </style>

  <div class="wrap">
    <div class="page-header">
      <h1>Best Rounds – Original (A Baskets)</h1>
    </div>

    <div class="toolbar">
      <label>
        <select id="yearFilter" class="filter-select" aria-label="Filter records by year">
          <option value="all">All years</option>
          {recordYears.map((year) => (
            <option value={year}>{year}</option>
          ))}
        </select>
      </label>
    </div>

    <div class="card">
      <div class="table-wrap">
        <table id="sortable-table">
          <colgroup>
            <col class="name-col" />
            <col class="score-col" />
            <col class="date-col" />
          </colgroup>

          <thead>
            <tr>
              <th class="sortable" data-column="0" data-type="text">
                <span class="th-inner">Name <span class="sort-indicator"></span></span>
              </th>
              <th class="sortable" data-column="1" data-type="score">
                <span class="th-inner">Score <span class="sort-indicator"></span></span>
              </th>
              <th class="sortable" data-column="2" data-type="date">
                <span class="th-inner">Date <span class="sort-indicator"></span></span>
              </th>
            </tr>
          </thead>

          <tbody>
            {rows.map((row) => (
              <tr data-year={getRowYear(row.date)}>
                <td><PlayerLink name={row.name} /></td>
                <td data-sort={getScoreSortValue(row.score)}>{row.score}</td>
                <td>
                  {row.resultsHref ? (
                    <a class="date-link" href={row.resultsHref}>
                      {row.date}
                    </a>
                  ) : row.url ? (
                    <a
                      class={`date-link${isUdiscUrl(row.url) ? " date-link-inline" : ""}`}
                      href={row.url}
                      target="_blank"
                      rel="noopener"
                    >
                      <span>{row.date}</span>
                      {isUdiscUrl(row.url) && (
                        <>
                          <img
                            class="udisc-icon udisc-icon--light"
                            src="https://lufberydiscgolf.com/udisc-icon.png"
                            alt="UDisc"
                            loading="lazy"
                            decoding="async"
                          />
                          <img
                            class="udisc-icon udisc-icon--dark"
                            src="https://lufberydiscgolf.com/udisc-icon-white.png"
                            alt="UDisc"
                            loading="lazy"
                            decoding="async"
                          />
                        </>
                      )}
                    </a>
                  ) : (
                    row.date
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div id="recordsEmpty" class="empty-state">No records found for the selected year.</div>
    </div>
  </div>

  <script>
    const table = document.getElementById("sortable-table");
    const tbody = table.querySelector("tbody");
    const headers = table.querySelectorAll("thead th.sortable");
    const yearFilter = document.getElementById("yearFilter");
    const recordsEmpty = document.getElementById("recordsEmpty");

    let currentColumn = 1;
    let currentDirection = "asc";

    function getCellValue(row, columnIndex) {
      const cell = row.children[columnIndex];
      return cell?.dataset.sort || cell?.textContent?.trim() || "";
    }

    function parseUsDate(value) {
      const match = String(value || "").match(/(\d{1,2})\/(\d{1,2})\/(\d{2,4})/);
      if (!match) return new Date(0).getTime();

      let month = Number(match[1]);
      let day = Number(match[2]);
      let year = Number(match[3]);

      if (year < 100) year += 2000;

      return new Date(year, month - 1, day).getTime();
    }

    function parseScore(value) {
      const text = String(value || "").trim();

      if (!text) return 9999;
      if (/^e$/i.test(text)) return 56;

      const match = text.match(/-?\d+(\.\d+)?/);
      if (!match) return 9999;

      const n = Number(match[0]);
      return Number.isNaN(n) ? 9999 : n;
    }

    function compareValues(a, b, type, direction) {
      const emptyA = a === "";
      const emptyB = b === "";

      if (emptyA && emptyB) return 0;
      if (emptyA) return 1;
      if (emptyB) return -1;

      let result = 0;

      if (type === "date") {
        result = parseUsDate(a) - parseUsDate(b);
      } else if (type === "score") {
        result = parseScore(a) - parseScore(b);
      } else {
        result = a.localeCompare(b, undefined, { sensitivity: "base", numeric: true });
      }

      return direction === "asc" ? result : -result;
    }

    function updateIndicators(activeColumn, direction) {
      headers.forEach((header) => {
        const indicator = header.querySelector(".sort-indicator");
        const col = Number(header.dataset.column);

        if (!indicator) return;

        if (col === activeColumn) {
          indicator.textContent = direction === "asc" ? "▲" : "▼";
          indicator.style.color = "#2563eb";
        } else {
          indicator.textContent = "";
          indicator.style.color = "#94a3b8";
        }
      });
    }

    function sortTable(columnIndex, type, direction) {
      const sortedRows = Array.from(tbody.querySelectorAll("tr")).sort((rowA, rowB) => {
        const valueA = getCellValue(rowA, columnIndex);
        const valueB = getCellValue(rowB, columnIndex);
        return compareValues(valueA, valueB, type, direction);
      });

      tbody.append(...sortedRows);
      updateIndicators(columnIndex, direction);
    }

    function applyYearFilter() {
      const selectedYear = yearFilter?.value || "all";
      const rows = Array.from(tbody.querySelectorAll("tr"));
      let visible = 0;

      rows.forEach((row) => {
        const rowYear = row.getAttribute("data-year") || "";
        const show = selectedYear === "all" || selectedYear === rowYear;
        row.style.display = show ? "" : "none";
        if (show) visible += 1;
      });

      if (recordsEmpty) {
        recordsEmpty.style.display = visible ? "none" : "block";
      }
    }

    headers.forEach((header) => {
      header.addEventListener("click", () => {
        const columnIndex = Number(header.dataset.column);
        const type = header.dataset.type || "text";

        if (currentColumn === columnIndex) {
          currentDirection = currentDirection === "asc" ? "desc" : "asc";
        } else {
          currentColumn = columnIndex;
          currentDirection = columnIndex === 1 ? "asc" : columnIndex === 2 ? "desc" : "asc";
        }

        sortTable(columnIndex, type, currentDirection);
        applyYearFilter();
      });
    });

    yearFilter?.addEventListener("change", applyYearFilter);

    sortTable(currentColumn, "score", currentDirection);
    applyYearFilter();
  </script>
  <PlayerModal profiles={playerProfiles} />
</SiteLayout>
