---
import SiteLayout from "../../layouts/SiteLayout.astro";
import PlayerLink from "../../components/PlayerLink.astro";
import PlayerModal from "../../components/PlayerModal.astro";
import { getHandicaps, getPlayerProfiles } from "../../lib/data";

const rows = getHandicaps();
const playerProfiles = getPlayerProfiles();
---

<SiteLayout title="Handicaps & Tags" showBrandBar={true}>
  <style is:global>
    :root {
      --bg: #f5f7fb;
      --card: #ffffff;
      --text: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --line-soft: #eef2f7;
      --header: #f8fafc;
      --hover: #f9fbff;
      --accent: #2563eb;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      --radius: 22px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 24px;
      font-family: Inter, Arial, Helvetica, sans-serif;
      background: linear-gradient(180deg, #f8fafc 0%, var(--bg) 100%);
      color: var(--text);
    }

    .wrap {
      width: 100%;
      max-width: none;
      margin: 0;
    }

    .handicaps-tags-page {
      overflow-x: hidden;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .card-header {
      padding: 22px 24px 12px;
    }

    .toolbar {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
      margin-top: 12px;
    }

    .search-wrap {
      position: relative;
      width: min(360px, 100%);
    }

    .search-input {
      width: 100%;
      padding: 11px 42px 11px 13px;
      border: 1px solid var(--line-soft);
      border-radius: 9px;
      background: var(--card);
      color: var(--text);
      font: inherit;
    }

    .search-clear {
      position: absolute;
      top: 50%;
      right: 9px;
      transform: translateY(-50%);
      width: 26px;
      height: 26px;
      border: 1px solid var(--line-soft);
      border-radius: 999px;
      background: var(--card);
      color: #94a3b8;
      font-size: 0.95rem;
      line-height: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s ease, color 0.15s ease, background 0.15s ease;
    }

    .search-wrap.has-value .search-clear {
      opacity: 1;
      pointer-events: auto;
    }

    .search-clear:hover {
      color: var(--text);
      background: var(--header);
    }

    .click-note {
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.35;
    }

    h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
    }

    .table-wrap {
      padding: 0 10px 8px;
      overflow-x: visible;
      overflow-y: auto;
      max-height: calc(100vh - 250px);
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: fixed;
      min-width: 0;
    }

    col.name-col {
      width: 40%;
    }

    col.hcp-col,
    col.tag-col,
    col.rounds-col,
    col.pb-col {
      width: 15%;
    }

    thead th {
      position: sticky;
      top: 0;
      z-index: 5;
      background: var(--header);
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      padding: 10px 5px;
      border-bottom: 1px solid var(--line);
      user-select: none;
      text-align: center;
      white-space: normal;
      line-height: 1.08;
    }

    thead th.sortable {
      cursor: pointer;
      transition: background 0.15s ease, color 0.15s ease;
    }

    thead th.sortable:hover {
      background: #f1f5f9;
      color: var(--text);
    }

    thead th:first-child {
      border-top-left-radius: 14px;
      text-align: left;
    }

    thead th:last-child {
      border-top-right-radius: 14px;
    }

    .th-inner {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      width: 100%;
    }

    thead th:first-child .th-inner {
      justify-content: flex-start;
    }

    .sort-indicator {
      display: inline-block;
      width: 10px;
      color: #94a3b8;
      font-size: 0.72rem;
      flex: 0 0 10px;
    }

    tbody td {
      padding: 8px 5px;
      border-bottom: 1px solid var(--line-soft);
      font-size: 0.88rem;
      text-align: center;
      vertical-align: middle;
      line-height: 1.1;
      white-space: normal;
    }

    tbody tr:nth-child(even) td {
      background: #fcfdff;
    }

    tbody tr:hover td {
      background: var(--hover);
    }

    tbody td:first-child {
      text-align: left;
      font-weight: 600;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    tbody td:not(:first-child) {
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .round-modal[hidden] {
      display: none;
    }

    .round-modal {
      position: fixed;
      inset: 0;
      z-index: 1000;
    }

    .round-modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(15, 23, 42, 0.45);
      backdrop-filter: blur(2px);
    }

    .round-modal-panel {
      position: relative;
      z-index: 1;
      width: min(92vw, 460px);
      margin: 6vh auto 0;
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-radius: 22px;
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.22);
      padding: 18px 18px 16px;
      max-height: 88vh;
      overflow-y: auto;
    }

    .round-modal-close {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 36px;
      height: 36px;
      border: 1px solid var(--line-soft);
      border-radius: 999px;
      background: var(--card);
      color: var(--muted);
      font-size: 1.15rem;
      line-height: 1;
      cursor: pointer;
    }

    .round-modal-close:hover {
      color: var(--text);
      background: var(--header);
    }

    .round-modal-title {
      margin: 0 42px 12px 0;
      font-size: 1.12rem;
      line-height: 1.2;
      font-weight: 800;
    }

    .round-section-label {
      margin: 0 0 8px;
      font-size: 0.84rem;
      font-weight: 800;
      line-height: 1.2;
      color: var(--muted);
    }

    .round-history-table {
      width: 100%;
      border-collapse: collapse;
      margin: 0 0 12px;
    }

    .round-history-table th,
    .round-history-table td {
      padding: 10px 0;
      border-bottom: 1px solid var(--line-soft);
      font-size: 0.98rem;
      text-align: left;
    }

    .round-history-table thead th {
      position: static;
      background: transparent;
      border-bottom: 1px solid var(--line-soft);
      color: var(--text);
      font-size: 0.82rem;
      text-transform: none;
      letter-spacing: 0;
      padding-top: 0;
      padding-bottom: 8px;
    }

    .round-history-table th:last-child,
    .round-history-table td:last-child {
      text-align: right;
    }

    .round-summary {
      display: grid;
      gap: 4px;
    }

    .round-summary--after-table {
      margin-top: 2px;
      margin-bottom: 24px;
    }

    .round-summary--average {
      margin-top: 10px;
    }

    .round-summary-row {
      font-size: 0.98rem;
      line-height: 1.3;
      color: var(--text);
    }

    .round-summary-row strong {
      font-weight: 800;
    }

    .round-chart-shell {
      margin-top: 0;
      padding: 12px 12px 10px;
      border: 1px solid var(--line-soft);
      border-radius: 14px;
      background: var(--header);
    }

    .round-chart-svg {
      display: block;
      width: 100%;
      height: 180px;
      overflow: visible;
    }

    .chart-grid {
      stroke: var(--line);
      stroke-width: 1;
      opacity: 0.8;
    }

    .chart-axis-label {
      fill: var(--muted);
      font-size: 10px;
      font-family: Inter, Arial, Helvetica, sans-serif;
    }

    .chart-line-player {
      fill: none;
      stroke: var(--accent);
      stroke-width: 2.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      vector-effect: non-scaling-stroke;
    }

    .chart-line-trend {
      fill: none;
      stroke: var(--muted);
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 5 5;
      opacity: 0.5;
      vector-effect: non-scaling-stroke;
    }

    .round-muted {
      color: var(--muted);
      font-weight: 600;
    }

    .round-note {
      margin: 12px 0 0;
      color: var(--muted);
      font-size: 0.83rem;
      line-height: 1.35;
    }

    @media (max-width: 700px) {
      body {
        padding: 8px;
      }

      .card {
        border-radius: 10px;
      }

      .card-header {
        padding: 12px 12px 8px;
      }

      h1 {
        font-size: 2rem;
      }

      .toolbar {
        margin-top: 10px;
      }

      .search-wrap {
        width: 100%;
      }

      .search-input {
        width: 100%;
        padding: 10px 40px 10px 12px;
      }

      .click-note {
        font-size: 0.82rem;
      }

      .table-wrap {
        padding: 0 2px 6px;
        overflow-y: auto;
        max-height: calc(100vh - 190px);
      }

      col.name-col {
        width: 36%;
      }

      col.hcp-col,
      col.tag-col,
      col.rounds-col,
      col.pb-col {
        width: 16%;
      }

      thead th {
        font-size: 0.58rem;
        padding: 6px 2px;
        letter-spacing: 0;
        line-height: 1.04;
      }

      tbody td {
        font-size: 0.76rem;
        padding: 6px 2px;
        line-height: 1.06;
        vertical-align: top;
      }

      .sort-indicator {
        width: 8px;
        font-size: 0.62rem;
        flex-basis: 8px;
      }

      .round-modal-panel {
        width: min(94vw, 460px);
        margin-top: 4vh;
        padding: 16px 14px 14px;
        border-radius: 20px;
      }

      .round-modal-title {
        font-size: 1.05rem;
        margin-bottom: 10px;
      }

      .round-chart-svg {
        height: 150px;
      }

      .round-history-table th,
      .round-history-table td {
        font-size: 0.92rem;
        padding: 9px 0;
      }
    }

    @media (max-width: 420px) {
      h1 {
        font-size: 1.9rem;
      }

      col.name-col {
        width: 35%;
      }

      col.hcp-col,
      col.tag-col,
      col.rounds-col,
      col.pb-col {
        width: 16.25%;
      }

      thead th {
        font-size: 0.54rem;
        padding: 6px 2px;
      }

      tbody td {
        font-size: 0.74rem;
        padding: 6px 2px;
      }
    }
  </style>

  <div class="wrap handicaps-tags-page">
    <div class="card">
      <div class="card-header">
        <h1>Handicaps &amp; Tags</h1>
        <div class="toolbar">
          <div id="searchWrap" class="search-wrap">
            <input
              id="playerSearch"
              class="search-input"
              type="text"
              placeholder="Search player"
              aria-label="Search player"
              autocomplete="off"
              autocapitalize="off"
              spellcheck="false"
            />
            <button
              id="clearSearch"
              class="search-clear"
              type="button"
              aria-label="Clear search"
              title="Clear search"
            >
              ×
            </button>
          </div>

          <div class="click-note">Click a player name to view more details.</div>
        </div>
      </div>

       <div id="handicapsTableWrap" class="table-wrap">
        <table id="sortable-table">
          <colgroup>
            <col class="name-col" />
            <col class="hcp-col" />
            <col class="tag-col" />
            <col class="rounds-col" />
            <col class="pb-col" />
          </colgroup>

          <thead>
            <tr>
              <th class="sortable" data-column="0" data-type="text">
                <span class="th-inner">Name <span class="sort-indicator"></span></span>
              </th>
              <th class="sortable" data-column="1" data-type="number">
                <span class="th-inner">Hcp <span class="sort-indicator"></span></span>
              </th>
              <th class="sortable" data-column="2" data-type="tag">
                <span class="th-inner">Tag <span class="sort-indicator"></span></span>
              </th>
              <th class="sortable" data-column="3" data-type="number">
                <span class="th-inner">Rounds <span class="sort-indicator"></span></span>
              </th>
              <th class="sortable" data-column="4" data-type="number">
                <span class="th-inner">PB <span class="sort-indicator"></span></span>
              </th>
            </tr>
          </thead>

          <tbody>
            {rows.map((row) => (
              <tr>
                <td><PlayerLink name={row.name} /></td>
                <td>{row.hcp}</td>
                <td>{row.tag}</td>
                <td>{row.rounds}</td>
                <td>{row.best}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  
  <script>
    const tableWrap = document.getElementById("handicapsTableWrap");
    const siteGoTop = document.querySelector(".site-go-top");
    const table = document.getElementById("sortable-table");
    const tbody = table ? table.querySelector("tbody") : null;
    const headers = table ? table.querySelectorAll("thead th.sortable") : [];
    const playerSearch = document.getElementById("playerSearch");
    const searchWrap = document.getElementById("searchWrap");
    const clearSearch = document.getElementById("clearSearch");

    let currentColumn = 1;
    let currentDirection = "asc";

    function getCellValue(row, columnIndex) {
      return row.children[columnIndex] && row.children[columnIndex].textContent
        ? row.children[columnIndex].textContent.trim()
        : "";
    }

    function compareValues(a, b, type, direction) {
      const emptyA = a === "";
      const emptyB = b === "";

      if (emptyA && emptyB) return 0;
      if (emptyA) return 1;
      if (emptyB) return -1;

      let result = 0;

      if (type === "number") {
        result = Number(a) - Number(b);
      } else {
        result = a.localeCompare(b, undefined, { sensitivity: "base" });
      }

      return direction === "asc" ? result : -result;
    }

    function compareTagValues(a, b, direction) {
      const normalize = (value) => String(value ?? "").trim();

      const getRank = (value) => {
        const v = normalize(value);

        if (v === "") return { bucket: 2, num: Infinity, text: "" };
        if (/^tbd$/i.test(v)) return { bucket: 1, num: Infinity, text: "TBD" };

        const num = Number(v);
        if (!Number.isNaN(num)) return { bucket: 0, num, text: "" };

        return { bucket: 1, num: Infinity, text: v.toLowerCase() };
      };

      const rankA = getRank(a);
      const rankB = getRank(b);

      let result = 0;

      if (rankA.bucket !== rankB.bucket) {
        result = rankA.bucket - rankB.bucket;
      } else if (rankA.bucket === 0) {
        result = rankA.num - rankB.num;
      } else {
        result = rankA.text.localeCompare(rankB.text, undefined, {
          sensitivity: "base",
        });
      }

      return direction === "asc" ? result : -result;
    }

    function updateIndicators(activeColumn, direction) {
      headers.forEach((header) => {
        const indicator = header.querySelector(".sort-indicator");
        const col = Number(header.dataset.column);

        if (!indicator) return;

        if (col === activeColumn) {
          indicator.textContent = direction === "asc" ? "▲" : "▼";
          indicator.style.color = "#2563eb";
        } else {
          indicator.textContent = "";
          indicator.style.color = "#94a3b8";
        }
      });
    }

    function sortTable(columnIndex, type, direction) {
      if (!tbody) return;

      const sortedRows = Array.from(tbody.querySelectorAll("tr")).sort((rowA, rowB) => {
        const valueA = getCellValue(rowA, columnIndex);
        const valueB = getCellValue(rowB, columnIndex);

        if (type === "tag") {
          return compareTagValues(valueA, valueB, direction);
        }

        return compareValues(valueA, valueB, type, direction);
      });

      tbody.append(...sortedRows);
      updateIndicators(columnIndex, direction);
    }

    function updateSearchClear() {
      if (!searchWrap || !playerSearch) return;
      searchWrap.classList.toggle("has-value", !!playerSearch.value.trim());
    }

    function applySearchFilter() {
      if (!tbody) return;

      const query = playerSearch && playerSearch.value
        ? playerSearch.value.trim().toLowerCase()
        : "";

      Array.from(tbody.querySelectorAll("tr")).forEach((row) => {
        const name = row.children[0] && row.children[0].textContent
          ? row.children[0].textContent.trim().toLowerCase()
          : "";

        row.style.display = !query || name.includes(query) ? "" : "none";
      });

      updateSearchClear();
    }

    headers.forEach((header) => {
      header.addEventListener("click", () => {
        const columnIndex = Number(header.dataset.column);
        const type = header.dataset.type || "text";

        if (currentColumn === columnIndex) {
          currentDirection = currentDirection === "asc" ? "desc" : "asc";
        } else {
          currentColumn = columnIndex;
          currentDirection = columnIndex === 3 ? "desc" : "asc";
        }

        sortTable(columnIndex, type, currentDirection);
      });
    });

    if (playerSearch) {
      playerSearch.addEventListener("input", applySearchFilter);
    }

    if (clearSearch) {
      clearSearch.addEventListener("click", () => {
        if (!playerSearch) return;
        playerSearch.value = "";
        applySearchFilter();
        playerSearch.focus();
      });
    }

    const initialHeader = table
      ? table.querySelector(`thead th[data-column="${currentColumn}"]`)
      : null;
if (siteGoTop) {
      siteGoTop.addEventListener("click", (event) => {
        if (tableWrap && "scrollTo" in tableWrap) {
          event.preventDefault();
          tableWrap.scrollTo({ top: 0, behavior: "smooth" });
          window.scrollTo({ top: 0, behavior: "smooth" });

          const pageTop = document.getElementById("site-page-top");
          if (pageTop) {
            pageTop.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        }
      });
    }
    sortTable(
      currentColumn,
      initialHeader?.dataset.type || "text",
      currentDirection
    );
    applySearchFilter();
    updateSearchClear();
  </script>
  <PlayerModal profiles={playerProfiles} />
</SiteLayout>
