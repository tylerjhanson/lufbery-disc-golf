---
import { getHandicaps } from "../../lib/data";

const rows = getHandicaps();
import SiteLayout from "../../layouts/SiteLayout.astro";
---

<SiteLayout title="Handicaps & Tags" showBrandBar={true}>
<style>

      :root {
        --bg: #f5f7fb;
        --card: #ffffff;
        --text: #111827;
        --muted: #6b7280;
        --line: #e5e7eb;
        --line-soft: #eef2f7;
        --header: #f8fafc;
        --hover: #f9fbff;
        --accent: #2563eb;
        --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
        --radius: 22px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 24px;
        font-family: Inter, Arial, Helvetica, sans-serif;
        background: linear-gradient(180deg, #f8fafc 0%, var(--bg) 100%);
        color: var(--text);
      }

      .wrap {
        width: 100%;
        max-width: none;
        margin: 0;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--line-soft);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .card-header {
        padding: 26px 28px 14px;
      }

      .toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-top: 14px;
      }

      .search-input {
        width: min(360px, 100%);
        padding: 11px 13px;
        border: 1px solid var(--line-soft);
        border-radius: 9px;
        background: var(--card);
        color: var(--text);
        font: inherit;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1.05;
        letter-spacing: -0.03em;
      }

      .table-wrap {
        padding: 0 20px 10px;
      }

      table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        table-layout: fixed;
      }

      col.name-col {
        width: 52%;
      }

      col.hcp-col,
      col.tag-col,
      col.pb-col {
        width: 16%;
      }

      thead th {
        position: sticky;
        top: 0;
        background: var(--header);
        color: var(--muted);
        font-size: 0.86rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 14px 16px;
        border-bottom: 1px solid var(--line);
        user-select: none;
        text-align: center;
      }

      thead th.sortable {
        cursor: pointer;
        transition: background 0.15s ease, color 0.15s ease;
      }

      thead th.sortable:hover {
        background: #f1f5f9;
        color: var(--text);
      }

      thead th:first-child {
        border-top-left-radius: 14px;
        text-align: left;
      }

      thead th:last-child {
        border-top-right-radius: 14px;
      }

      .th-inner {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
      }

      thead th:first-child .th-inner {
        justify-content: flex-start;
      }

      .sort-indicator {
        display: inline-block;
        width: 12px;
        color: #94a3b8;
        font-size: 0.8rem;
        flex: 0 0 12px;
      }

      tbody td {
        padding: 15px 16px;
        border-bottom: 1px solid var(--line-soft);
        font-size: 1rem;
        text-align: center;
        vertical-align: middle;
      }

      tbody tr:nth-child(even) td {
        background: #fcfdff;
      }

      tbody tr:hover td {
        background: var(--hover);
      }

      tbody td:first-child {
        text-align: left;
        font-weight: 600;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      .footer-link {
        padding: 18px 28px 26px;
      }

      .footer-link a {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
      }

      .footer-link a:hover {
        text-decoration: underline;
      }

      @media (max-width: 700px) {
        body {
          padding: 10px;
        }

        .card-header {
          padding: 18px 16px 10px;
        }

        h1 {
          font-size: 2.1rem;
        }

        .table-wrap {
          padding: 0 8px 8px;
        }

        col.name-col {
          width: 46%;
        }

        col.hcp-col,
        col.tag-col,
        col.pb-col {
          width: 18%;
        }

        thead th {
          font-size: 0.72rem;
          letter-spacing: 0.02em;
          padding: 10px 6px;
        }

        tbody td {
          font-size: 0.9rem;
          padding: 10px 6px;
        }

        .sort-indicator {
          width: 10px;
          font-size: 0.7rem;
        }

        .footer-link {
          padding: 14px 16px 18px;
        }
      }

      @media (max-width: 420px) {
        h1 {
          font-size: 1.95rem;
        }

        thead th {
          font-size: 0.68rem;
          padding: 9px 4px;
        }

        tbody td {
          font-size: 0.86rem;
          padding: 9px 4px;
        }
      }
    
</style>

<div class="wrap">
      <div class="card">
        <div class="card-header">
          <h1>Handicaps &amp; Tags</h1>
          <div class="toolbar">
            <input id="playerSearch" class="search-input" type="search" placeholder="Search player" aria-label="Search player" />
          </div>
        </div>

        <div class="table-wrap">
          <table id="sortable-table">
            <colgroup>
              <col class="name-col" />
              <col class="hcp-col" />
              <col class="tag-col" />
              <col class="pb-col" />
            </colgroup>

            <thead>
              <tr>
                <th class="sortable" data-column="0" data-type="text">
                  <span class="th-inner">Name <span class="sort-indicator"></span></span>
                </th>
                <th class="sortable" data-column="1" data-type="number">
                  <span class="th-inner">Hcp <span class="sort-indicator"></span></span>
                </th>
                <th class="sortable" data-column="2" data-type="number">
                  <span class="th-inner">Tag <span class="sort-indicator"></span></span>
                </th>
                <th class="sortable" data-column="3" data-type="number">
                  <span class="th-inner">PB <span class="sort-indicator"></span></span>
                </th>
              </tr>
            </thead>

            <tbody>
              {rows.map((row) => (
                <tr>
                  <td>{row.name}</td>
                  <td>{row.hcp}</td>
                  <td>{row.tag}</td>
                  <td>{row.best}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="footer-link">
          <a href="/singles/">← Back to Singles</a>
        </div>
      </div>
    </div>

    <script>
      const table = document.getElementById("sortable-table");
      const tbody = table.querySelector("tbody");
      const headers = table.querySelectorAll("thead th.sortable");
      const playerSearch = document.getElementById("playerSearch");

      let currentColumn = 1;
      let currentDirection = "asc";

      function getCellValue(row, columnIndex) {
        return row.children[columnIndex]?.textContent?.trim() ?? "";
      }

      function compareValues(a, b, type, direction) {
        const emptyA = a === "";
        const emptyB = b === "";

        if (emptyA && emptyB) return 0;
        if (emptyA) return 1;
        if (emptyB) return -1;

        let result = 0;

        if (type === "number") {
          result = Number(a) - Number(b);
        } else {
          result = a.localeCompare(b, undefined, { sensitivity: "base" });
        }

        return direction === "asc" ? result : -result;
      }

      function updateIndicators(activeColumn, direction) {
        headers.forEach((header) => {
          const indicator = header.querySelector(".sort-indicator");
          const col = Number(header.dataset.column);

          if (!indicator) return;

          if (col === activeColumn) {
            indicator.textContent = direction === "asc" ? "▲" : "▼";
            indicator.style.color = "#2563eb";
          } else {
            indicator.textContent = "";
            indicator.style.color = "#94a3b8";
          }
        });
      }

      function sortTable(columnIndex, type, direction) {
        const sortedRows = Array.from(tbody.querySelectorAll("tr")).sort((rowA, rowB) => {
          const valueA = getCellValue(rowA, columnIndex);
          const valueB = getCellValue(rowB, columnIndex);
          return compareValues(valueA, valueB, type, direction);
        });

        tbody.append(...sortedRows);
        updateIndicators(columnIndex, direction);
      }

      function applySearchFilter() {
        const query = (playerSearch?.value || "").trim().toLowerCase();
        Array.from(tbody.querySelectorAll("tr")).forEach((row) => {
          const name = row.children[0]?.textContent?.trim().toLowerCase() || "";
          row.style.display = !query || name.includes(query) ? "" : "none";
        });
      }

      headers.forEach((header) => {
        header.addEventListener("click", () => {
          const columnIndex = Number(header.dataset.column);
          const type = header.dataset.type || "text";

          if (currentColumn === columnIndex) {
            currentDirection = currentDirection === "asc" ? "desc" : "asc";
          } else {
            currentColumn = columnIndex;
            currentDirection = "asc";
          }

          sortTable(columnIndex, type, currentDirection);
        });
      });

      playerSearch?.addEventListener("input", applySearchFilter);
      sortTable(currentColumn, "number", currentDirection);
      applySearchFilter();
    </script>
</SiteLayout>
