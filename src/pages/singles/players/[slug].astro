---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import courseStats from "../../../data/course-stats.generated.json";
import { getPlayerProfiles, getWeeklyResults, getWeeklyResultsAnchorId } from "../../../lib/data";
import {
  parseDisplayYear,
  formatScoreWithPar,
  formatAverage,
  formatRounds,
  yearAverages,
  yearlyBest,
  lowestHandicap,
  chartHtml,
  courseStatsForPlayer,
  buildCourseViews,
  droppedRecentRoundIndex,
} from "../../../lib/playerProfilePage.js";

const WEEKLY_RESULTS_PAGE_PATH = "/singles/weekly-results";
const DEFAULT_PARS = [3,3,4,3,3,3,3,3,3,3,3,3,3,4,3,3,3,3];

function extractEventDate(value) {
  const match = String(value || "").trim().match(/^(\d{1,2}\/\d{1,2}\/\d{2,4})/);
  return match ? match[1] : "";
}

function toFullYearUsDate(value) {
  const match = String(value || "").trim().match(/(\d{1,2})\/(\d{1,2})\/(\d{2,4})/);
  if (!match) return String(value || "").trim();
  const month = Number(match[1]);
  const day = Number(match[2]);
  let year = Number(match[3]);
  if (year < 100) year += 2000;
  return `${month}/${day}/${year}`;
}

function toShortUsDate(value) {
  const match = toFullYearUsDate(value).match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})$/);
  return match ? `${match[1]}/${match[2]}/${match[3].slice(-2)}` : String(value || "");
}

function normalizeDateKey(value) {
  const text = String(value || "").replace(/\s+/g, " ").trim();
  const match = text.match(/^(\d{1,2}\/\d{1,2}\/\d{2,4})(.*)$/);
  if (!match) return text;
  const suffix = String(match[2] || "").replace(/\s+/g, " ").trim();
  return `${toFullYearUsDate(match[1])}${suffix ? ` ${suffix}` : ""}`;
}

const weeklyResultHrefByDate = new Map();
for (const event of getWeeklyResults()) {
  const eventDate = toFullYearUsDate(extractEventDate(event.title));
  if (!eventDate) continue;
  weeklyResultHrefByDate.set(
    normalizeDateKey(eventDate),
    `${WEEKLY_RESULTS_PAGE_PATH}#${getWeeklyResultsAnchorId(event.title)}`
  );
}

function getWeeklyResultsHrefForProfileDate(value) {
  const dateOnly = extractEventDate(value) || value;
  const fullDate = toFullYearUsDate(dateOnly);
  return weeklyResultHrefByDate.get(normalizeDateKey(fullDate)) || "";
}

function formatToPar(value) {
  const number = Number(value);
  if (!Number.isFinite(number)) return "—";
  if (number === 0) return "E";
  return number > 0 ? `+${number}` : String(number);
}

function scoreClass(score, par) {
  const diff = Number(score) - Number(par);
  if (!Number.isFinite(diff)) return "par";
  if (diff <= -2) return "ace";
  if (diff === -1) return "birdie";
  if (diff === 0) return "par";
  if (diff === 1) return "bogey";
  if (diff === 2) return "double";
  return "triple";
}

export function getStaticPaths() {
  const toSlug = (value) => String(value || "")
    .replace(/\s+/g, " ")
    .trim()
    .toLowerCase()
    .replace(/&/g, " and ")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

  const seen = new Set();
  return Object.values(getPlayerProfiles())
    .map((profile) => ({ profile, slug: toSlug(profile.name) }))
    .filter(({ slug }) => {
      if (!slug || seen.has(slug)) return false;
      seen.add(slug);
      return true;
    })
    .map(({ profile, slug }) => ({ params: { slug }, props: { profile } }));
}

const { profile } = Astro.props;
const name = String(profile.name || "Player");
const allRounds = Array.isArray(profile.allRounds) ? profile.allRounds : [];
const recentRounds = Array.isArray(profile.recentRounds) ? profile.recentRounds : [];
const recentRoundsWithLinks = recentRounds.map((round) => ({ ...round, href: getWeeklyResultsHrefForProfileDate(round.date) }));
const handicapHistory = Array.isArray(profile.handicapHistory) ? profile.handicapHistory.filter((row) => parseDisplayYear(row.date) >= 2023) : [];
const tagHistory = Array.isArray(profile.tagHistory) ? profile.tagHistory.filter((row) => parseDisplayYear(row.date) >= 2023) : [];
const weeklyWins = Array.isArray(profile.weeklyWins) ? profile.weeklyWins : [];
const bestOverallWins = Array.isArray(profile.bestOverallWins) ? profile.bestOverallWins : [];
const aces = Array.isArray(profile.aces) ? profile.aces : [];
const personalBests = Array.isArray(profile.personalBests) && profile.personalBests.length ? profile.personalBests : profile.personalBest ? [profile.personalBest] : [];
const personalBestTitle = personalBests.length > 1 ? "Personal Bests" : "Personal Best";
const lowestHandicapValue = lowestHandicap(handicapHistory, profile.handicap);
const lowestHandicapDisplay = lowestHandicapValue === "" ? "—" : String(lowestHandicapValue);
const playerCourseStats = courseStatsForPlayer(courseStats, name);
const courseViews = buildCourseViews(playerCourseStats);
const coursePars = Array.isArray(courseStats?.source?.holePars) && courseStats.source.holePars.length >= 18 ? courseStats.source.holePars.slice(0, 18) : DEFAULT_PARS;
const roundHistory = (Array.isArray(playerCourseStats?.roundHistory) ? playerCourseStats.roundHistory : []).map((round) => {
  const scores = Array.isArray(round.scores) ? round.scores.slice(0, 18).map((score) => Number(score)) : [];
  const total = Number.isFinite(Number(round.total)) ? Number(round.total) : scores.reduce((sum, score) => sum + (Number.isFinite(score) ? score : 0), 0);
  const toPar = Number.isFinite(Number(round.toPar)) ? Number(round.toPar) : total - coursePars.reduce((sum, par) => sum + Number(par || 0), 0);
  const date = toFullYearUsDate(round.date || extractEventDate(round.title));
  const href = getWeeklyResultsHrefForProfileDate(date) || String(round.url || "");
  return {
    ...round,
    date,
    displayDate: toShortUsDate(date),
    href,
    scores,
    total,
    toPar,
    toParLabel: formatToPar(toPar),
    holes: scores.map((score, index) => ({ hole: index + 1, score, par: Number(coursePars[index] || 3), className: scoreClass(score, coursePars[index] || 3) })),
  };
});
const scoreAverages = yearAverages(allRounds);
const bestHandicaps = yearlyBest(handicapHistory, "handicap", 2023);
const bestTags = yearlyBest(tagHistory, "tag", 2023);
const droppedIndex = droppedRecentRoundIndex(recentRounds);
const scoreChart = chartHtml(allRounds.map((round) => ({ value: Number(round.score), label: String(round.date || ""), detail: `${round.date} — ${formatScoreWithPar(round.score)}` })));
const handicapValues = handicapHistory.map((row) => Number(row.handicap)).filter((value) => Number.isFinite(value));
const handicapChart = chartHtml(handicapHistory.map((row) => ({ value: Number(row.handicap), label: String(row.date || ""), detail: `${row.date} — ${row.handicap}` })), { step: 1, min: handicapValues.length ? Math.floor(Math.min(...handicapValues)) - 1 : 0 });
const tagChart = chartHtml(tagHistory.map((row) => ({ value: Number(row.tag), label: String(row.date || ""), detail: `${row.date} — #${row.tag}` })), { step: 5, min: 0 });
---

<SiteLayout title={`${name} Player Profile`} description={`League player profile and history for ${name}.`} showBrandBar={true}>
  <style is:global>
    body { margin: 0; padding: 24px; background: linear-gradient(180deg, #f8fafc 0%, var(--bg, #f5f7fb) 100%); color: var(--text, #111827); font-family: Inter, Arial, Helvetica, sans-serif; }
    .player-profile-wrap { width: 100%; max-width: none; margin: 0; overflow-anchor: none; }
    .profile-card, .profile-header { border: 1px solid var(--line-soft, #eef2f7); border-radius: 22px; background: var(--card, #fff); box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08); }
    .profile-header { margin-bottom: 18px; padding: 24px; }
    .profile-title { margin: 0; font-size: clamp(2.1rem, 5vw, 4rem); line-height: 0.98; letter-spacing: -0.045em; }
    .profile-summary-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; margin-top: 22px; }
    .profile-stat { padding: 14px; border: 1px solid var(--line-soft, #eef2f7); border-radius: 16px; background: var(--header, #f8fafc); min-width: 0; }
    .profile-stat + .profile-stat { margin-top: 10px; }
    .profile-stat-label { display: block; margin-bottom: 5px; color: var(--muted, #6b7280); font-size: 0.72rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; }
    .profile-stat-value { font-size: 1.25rem; font-weight: 850; line-height: 1.05; }
    .profile-content-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(300px, 0.34fr); gap: 18px; align-items: start; }
    .profile-stack { display: grid; gap: 18px; }
    .profile-bottom-stack { margin-top: 18px; }
    .profile-card { overflow: hidden; overflow-anchor: none; }
    .profile-card-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 18px 20px 10px; }
    .profile-card-body { padding: 0 20px 18px; }
    .profile-section-title { margin: 0; font-size: 0.9rem; font-weight: 850; letter-spacing: 0.04em; line-height: 1.2; text-transform: uppercase; }
    .profile-mobile-toggle { display: none; }
    .profile-card.is-collapsed .profile-card-body { display: none; }
    .profile-card.is-collapsed .profile-mobile-toggle { transform: rotate(-90deg); }
    .profile-card[data-default-collapsed] .profile-mobile-toggle { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; flex: 0 0 34px; border: 0; background: transparent; color: var(--muted, #6b7280); font-size: 1.1rem; font-weight: 900; line-height: 1; padding: 0; }
    .profile-card[data-default-collapsed] .profile-card-header { cursor: pointer; }
    .profile-year-stats, .profile-link-list { display: grid; gap: 8px; margin: 0; padding: 0; list-style: none; }
    .profile-year-stats { grid-template-columns: 1fr; justify-items: start; }
    .profile-year-pill { padding: 0; border: 0; border-radius: 0; background: transparent; color: var(--text, #111827); font-size: 0.93rem; font-weight: 650; text-align: left; }
    .profile-subheading { margin: 12px 0 7px; color: var(--muted, #6b7280); font-size: 0.78rem; font-weight: 850; letter-spacing: 0.04em; text-transform: uppercase; }
    .profile-table { width: 100%; border-collapse: collapse; }
    .profile-table th, .profile-table td { padding: 10px 0; border-bottom: 1px solid var(--line-soft, #eef2f7); text-align: left; font-size: 0.94rem; vertical-align: top; }
    .profile-table th:last-child, .profile-table td:last-child { text-align: right; }
    .profile-table th { color: var(--muted, #6b7280); font-size: 0.78rem; font-weight: 800; }
    .profile-dropped-round td { color: var(--muted, #6b7280); text-decoration: line-through; text-decoration-thickness: 1.5px; }
    .profile-link { color: var(--accent, #2563eb); font-weight: 700; text-decoration: none; }
    .profile-link:hover { text-decoration: underline; }
    .profile-muted, .profile-course-summary, .profile-round-hint { color: var(--muted, #6b7280); font-size: 0.92rem; font-weight: 650; }
    .profile-chart-shell { position: relative; margin-bottom: 12px; padding: 10px; border: 1px solid var(--line-soft, #eef2f7); border-radius: 14px; background: var(--header, #f8fafc); touch-action: pan-y; user-select: none; -webkit-tap-highlight-color: transparent; }
    .profile-chart { display: block; width: 100%; height: 210px; overflow: visible; }
    .profile-chart-grid { stroke: var(--line-soft, #e5e7eb); stroke-width: 1; }
    .profile-chart-axis { fill: var(--muted, #6b7280); font: 12px Inter, Arial, sans-serif; }
    .profile-chart-line { fill: none; stroke: var(--accent, #2563eb); stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; vector-effect: non-scaling-stroke; }
    .profile-chart-trend { stroke: #9ca3af; stroke-width: 2; stroke-dasharray: 4 5; opacity: 0.42; vector-effect: non-scaling-stroke; }
    .profile-chart-guide { stroke: var(--muted, #6b7280); stroke-width: 2; stroke-dasharray: 4 4; opacity: 0.85; vector-effect: non-scaling-stroke; pointer-events: none; }
    .profile-chart-hotspot { fill: transparent; cursor: crosshair; outline: none; -webkit-tap-highlight-color: transparent; }
    .profile-chart-tooltip { position: fixed; z-index: 9999; pointer-events: none; max-width: calc(100vw - 24px); padding: 7px 9px; border-radius: 9px; background: rgba(15, 23, 42, 0.93); color: #fff; font-size: 0.78rem; font-weight: 800; opacity: 0; transform: translate(0, -120%); transition: opacity 0.12s ease; white-space: nowrap; }
    .profile-chart-tooltip.is-visible { opacity: 1; }
    .profile-course-filter { min-width: 118px; border: 1px solid var(--line-soft, #e5e7eb); border-radius: 999px; background: var(--card, #fff); color: var(--text, #111827); font: inherit; font-size: 0.84rem; font-weight: 800; padding: 7px 28px 7px 10px; }
    .profile-course-panel[hidden] { display: none; }
    .profile-course-grid { display: grid; gap: 8px; }
    .profile-course-hole { padding: 9px; border: 1px solid var(--line-soft, #eef2f7); border-radius: 13px; background: var(--card, #ffffff); }
    .profile-course-hole-header { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; margin-bottom: 7px; }
    .profile-course-hole-title { margin: 0; font-size: 0.95rem; font-weight: 850; line-height: 1.2; }
    .profile-course-hole-title span { margin-left: 5px; color: var(--muted, #6b7280); font-size: 0.8rem; font-weight: 600; }
    .profile-course-meta { display: inline-flex; gap: 8px; white-space: nowrap; color: var(--muted, #6b7280); font-size: 0.78rem; font-weight: 700; }
    .profile-course-meta strong { color: var(--text, #111827); font-weight: 850; }
    .profile-course-bar { display: grid; min-height: 20px; overflow: hidden; border: 2px solid #cfe0ef; border-radius: 9px; background: var(--card, #ffffff); }
    .profile-course-segment { min-width: 0; position: relative; cursor: help; }
    .profile-course-segment + .profile-course-segment { box-shadow: inset 1px 0 0 rgba(15, 23, 42, 0.1); }
    .profile-course-segment span { position: absolute; inset: 0; display: grid; place-items: center; font-size: 0.72rem; font-weight: 850; line-height: 1; }
    .profile-course-segment--ace, .profile-round-score--ace { background: #2f6fb6; color: #fff; }
    .profile-course-segment--birdie, .profile-round-score--birdie { background: #6c9bd1; color: #fff; }
    .profile-course-segment--par, .profile-round-score--par { background: var(--card, #ffffff); color: var(--text, #111827); }
    .profile-course-segment--bogey, .profile-round-score--bogey { background: #f2d8c8; color: #1f2937; }
    .profile-course-segment--double, .profile-round-score--double { background: #efb286; color: #1f2937; }
    .profile-course-segment--triple, .profile-round-score--triple { background: #eb7b3c; color: #1f2937; }
    .profile-course-segment--bogey span, .profile-course-segment--double span, .profile-course-segment--triple span { color: #1f2937 !important; text-shadow: none; }
    .profile-round-desktop-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .profile-round-table { min-width: 1120px; border-collapse: collapse; width: 100%; }
    .profile-round-table th, .profile-round-table td { padding: 8px 9px; border-bottom: 1px solid var(--line-soft, #eef2f7); text-align: center; white-space: nowrap; }
    .profile-round-table th:first-child, .profile-round-table td:first-child { position: sticky; left: 0; z-index: 1; background: var(--card, #fff); text-align: left; }
    .profile-round-table th { color: var(--muted, #6b7280); font-size: 0.73rem; font-weight: 850; }
    .profile-round-sort { border: 0; background: transparent; color: inherit; cursor: pointer; font: inherit; font-weight: 850; padding: 0; }
    .profile-round-score { display: inline-grid; place-items: center; min-width: 28px; height: 28px; padding: 0 7px; border-radius: 999px; font-weight: 850; }
    .profile-round-mobile { display: none; }
    .profile-round-mobile-controls { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px; }
    .profile-round-mobile-controls .profile-round-sort { border: 1px solid var(--line-soft, #e5e7eb); border-radius: 999px; padding: 7px 10px; background: var(--header, #f8fafc); color: var(--text, #111827); }
    .profile-round-mobile-list { display: grid; gap: 8px; }
    .profile-round-card { border: 1px solid var(--line-soft, #eef2f7); border-radius: 14px; background: var(--card, #fff); overflow: hidden; }
    .profile-round-mobile-summary { display: grid; grid-template-columns: 1fr 72px 72px 22px; gap: 8px; align-items: center; width: 100%; padding: 11px 12px; cursor: pointer; font-weight: 850; }
    .profile-round-mobile-detail { display: none; padding: 0 12px 12px; }
    .profile-round-card.is-expanded .profile-round-mobile-detail { display: block; }
    .profile-round-panels { display: flex; gap: 10px; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; }
    .profile-round-panel { min-width: 100%; scroll-snap-align: start; }
    .profile-round-panel-grid { display: grid; grid-template-columns: repeat(9, minmax(0, 1fr)); gap: 5px; align-items: end; }
    .profile-round-panel-cell { display: grid; gap: 4px; justify-items: center; color: var(--muted, #6b7280); font-size: 0.69rem; font-weight: 800; }

    html[data-theme="dark"] .profile-chart-shell, html[data-theme="dark"] .profile-stat, html[data-theme="dark"] .profile-year-pill, html[data-theme="dark"] .profile-round-mobile-controls .profile-round-sort { background: var(--header, #111827); }
    html[data-theme="dark"] .profile-chart-grid { stroke: #334155; }
    html[data-theme="dark"] .profile-chart-axis { fill: var(--muted, #94a3b8); }
    html[data-theme="dark"] .profile-chart-guide { stroke: #cbd5e1; }
    html[data-theme="dark"] .profile-chart-trend { stroke: #cbd5e1; opacity: 0.32; }
    html[data-theme="dark"] .profile-course-bar { border-color: #334155; }
    html[data-theme="dark"] .profile-course-segment + .profile-course-segment { box-shadow: inset 1px 0 0 rgba(248, 250, 252, 0.16); }
    html[data-theme="dark"] .profile-round-table th:first-child, html[data-theme="dark"] .profile-round-table td:first-child { background: var(--card, #0b1220); }
    @media (prefers-color-scheme: dark) {
      html[data-theme="system"] .profile-chart-shell, html[data-theme="system"] .profile-stat, html[data-theme="system"] .profile-year-pill, html[data-theme="system"] .profile-round-mobile-controls .profile-round-sort { background: var(--header, #111827); }
      html[data-theme="system"] .profile-chart-grid { stroke: #334155; }
      html[data-theme="system"] .profile-chart-axis { fill: var(--muted, #94a3b8); }
      html[data-theme="system"] .profile-chart-guide { stroke: #cbd5e1; }
      html[data-theme="system"] .profile-chart-trend { stroke: #cbd5e1; opacity: 0.32; }
      html[data-theme="system"] .profile-course-bar { border-color: #334155; }
      html[data-theme="system"] .profile-course-segment + .profile-course-segment { box-shadow: inset 1px 0 0 rgba(248, 250, 252, 0.16); }
      html[data-theme="system"] .profile-round-table th:first-child, html[data-theme="system"] .profile-round-table td:first-child { background: var(--card, #0b1220); }
    }

    @media (max-width: 900px) {
      body { padding: 14px; }
      .site-go-top { display: none !important; }
      .profile-header { padding: 18px 14px; }
      .profile-summary-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
      .profile-stat-group { display: grid; grid-template-columns: 1fr; gap: 8px; }
      .profile-stat { padding: 10px 11px; border-radius: 14px; }
      .profile-stat + .profile-stat { margin-top: 0; }
      .profile-stat-label { font-size: 0.67rem; }
      .profile-stat-value { font-size: 1.08rem; }
      .profile-content-grid { display: flex; flex-direction: column; gap: 14px; }
      .profile-sidebar { order: -1; width: 100%; }
      .profile-main { width: 100%; }
      .profile-card-header { min-height: 62px; padding: 0 14px; cursor: pointer; align-items: center; }
      .profile-section-title { line-height: 1; }
      .profile-card-body { padding: 0 14px 14px; }
      .profile-chart { height: 172px; }
      .profile-course-hole-title { font-size: 0.88rem; white-space: nowrap; }
      .profile-course-hole-title span, .profile-course-meta { font-size: 0.72rem; }
      .profile-course-meta { gap: 5px; }
      .profile-mobile-toggle { display: inline-flex; align-items: center; justify-content: center; align-self: center; width: 34px; height: 34px; flex: 0 0 34px; border: 0; background: transparent; color: var(--muted, #6b7280); font-size: 1.1rem; font-weight: 900; line-height: 1; padding: 0; }
      .profile-round-desktop { display: none; }
      .profile-round-mobile { display: block; }
    }
  </style>

  <main class="player-profile-wrap">
    <header class="profile-header">
      <h1 class="profile-title">{name}</h1>
      <div class="profile-summary-grid">
        <div class="profile-stat-group">
          <div class="profile-stat"><span class="profile-stat-label">Current handicap</span><span class="profile-stat-value">{profile.handicap || "—"}</span></div>
          <div class="profile-stat"><span class="profile-stat-label">Lowest handicap</span><span class="profile-stat-value">{lowestHandicapDisplay}</span></div>
        </div>
        <div class="profile-stat-group">
          <div class="profile-stat"><span class="profile-stat-label">Current tag</span><span class="profile-stat-value">{profile.hasTag ? profile.currentTag || "TBD" : "—"}</span></div>
          <div class="profile-stat"><span class="profile-stat-label">Best tag</span><span class="profile-stat-value">{profile.bestTagEver || "—"}</span></div>
        </div>
      </div>
    </header>

    <div class="profile-content-grid">
      <div class="profile-stack profile-main">
        <section class="profile-card" data-mobile-collapse data-default-open>
          <div class="profile-card-header"><h2 class="profile-section-title">Score History</h2><button class="profile-mobile-toggle" type="button" aria-label="Toggle section">⌄</button></div>
          <div class="profile-card-body">{scoreChart ? <Fragment set:html={scoreChart} /> : <p class="profile-muted">No score history found.</p>}{scoreAverages.length ? <div><h3 class="profile-subheading">Average score by year</h3><div class="profile-year-stats">{scoreAverages.map((row) => <span class="profile-year-pill"><strong>{row.year}:</strong> {row.value}</span>)}</div></div> : null}</div>
        </section>
        <section class="profile-card" data-mobile-collapse>
          <div class="profile-card-header"><h2 class="profile-section-title">Handicap History</h2><button class="profile-mobile-toggle" type="button" aria-label="Toggle section">⌄</button></div>
          <div class="profile-card-body">{handicapChart ? <Fragment set:html={handicapChart} /> : <p class="profile-muted">No handicap history found.</p>}{bestHandicaps.length ? <div><h3 class="profile-subheading">Best handicap by year</h3><div class="profile-year-stats">{bestHandicaps.map((row) => <span class="profile-year-pill"><strong>{row.year}:</strong> {row.value}</span>)}</div></div> : null}</div>
        </section>
        <section class="profile-card" data-mobile-collapse>
          <div class="profile-card-header"><h2 class="profile-section-title">Tag History</h2><button class="profile-mobile-toggle" type="button" aria-label="Toggle section">⌄</button></div>
          <div class="profile-card-body">{tagChart ? <Fragment set:html={tagChart} /> : <p class="profile-muted">No tag history found.</p>}{bestTags.length ? <div><h3 class="profile-subheading">Best tag by year</h3><div class="profile-year-stats">{bestTags.map((row) => <span class="profile-year-pill"><strong>{row.year}:</strong> #{row.value}</span>)}</div></div> : null}</div>
        </section>
      </div>

      <aside class="profile-stack profile-sidebar">
        <section class="profile-card" data-mobile-collapse data-default-open>
          <div class="profile-card-header"><h2 class="profile-section-title">Rounds Counting Towards Handicap</h2><button class="profile-mobile-toggle" type="button" aria-label="Toggle section">⌄</button></div>
          <div class="profile-card-body"><table class="profile-table"><thead><tr><th>Date</th><th>Score</th></tr></thead><tbody>{recentRoundsWithLinks.length ? recentRoundsWithLinks.map((round, index) => <tr class={index === droppedIndex ? "profile-dropped-round" : ""}><td>{round.href ? <a class="profile-link" href={round.href}>{round.date}</a> : round.date}</td><td>{formatScoreWithPar(round.score)}</td></tr>) : <tr><td colspan="2" class="profile-muted">No handicap rounds found.</td></tr>}</tbody></table></div>
        </section>
        <section class="profile-card" data-mobile-collapse data-default-open data-profile-personal-best>
          <div class="profile-card-header"><h2 class="profile-section-title">{personalBestTitle}</h2><button class="profile-mobile-toggle" type="button" aria-label="Toggle section">⌄</button></div>
          <div class="profile-card-body">{personalBests.length ? <ul class="profile-link-list">{personalBests.map((item) => <li><strong>{item.score}</strong> <a class="profile-link" href={item.href}>{item.date}</a></li>)}</ul> : <p class="profile-muted">No personal best found.</p>}</div>
        </section>
        <section class="profile-card" data-mobile-collapse>
          <div class="profile-card-header"><h2 class="profile-section-title">Weekly Wins</h2><button class="profile-mobile-toggle" type="button" aria-label="Toggle section">⌄</button></div>
          <div class="profile-card-body">{weeklyWins.length ? <ul class="profile-link-list">{weeklyWins.map((item) => <li><a class="profile-link" href={item.href}>{item.date}</a> — {item.label} • {item.score}</li>)}</ul> : <p class="profile-muted">No weekly wins recorded.</p>}</div>
        </section>
        <section class="profile-card" data-mobile-collapse>
          <div class="profile-card-header"><h2 class="profile-section-title">Best Overall</h2><button class="profile-mobile-toggle" type="button" aria-label="Toggle section">⌄</button></div>
          <div class="profile-card-body">{bestOverallWins.length ? <ul class="profile-link-list">{bestOverallWins.map((item) => <li><a class="profile-link" href={item.href}>{item.date}</a> — {item.label} • {item.score}{item.isTie ? " • Tie" : ""}</li>)}</ul> : <p class="profile-muted">No best overall wins recorded.</p>}</div>
        </section>
        <section class="profile-card" data-mobile-collapse>
          <div class="profile-card-header"><h2 class="profile-section-title">Aces</h2><button class="profile-mobile-toggle" type="button" aria-label="Toggle section">⌄</button></div>
          <div class="profile-card-body">{aces.length ? <ul class="profile-link-list">{aces.map((item) => <li><a class="profile-link" href={item.href}>{item.date}</a> — {item.label ? `${item.label} • ` : ""}{item.hole ? `Hole ${item.hole}` : "Ace"}</li>)}</ul> : <p class="profile-muted">No aces recorded.</p>}</div>
        </section>
      </aside>
    </div>

    <div class="profile-stack profile-bottom-stack">
      <section class="profile-card is-collapsed" data-round-history-card data-mobile-collapse data-default-collapsed>
        <div class="profile-card-header"><h2 class="profile-section-title">Round History</h2><button class="profile-mobile-toggle" type="button" aria-label="Toggle section">⌄</button></div>
        <div class="profile-card-body">
          {roundHistory.length ? <>
            <p class="profile-round-hint">{formatRounds(roundHistory.length)} • Original Layout • Tap a date to view the weekly result.</p>
            <div class="profile-round-desktop profile-round-desktop-wrap">
              <table class="profile-round-table" data-round-table>
                <thead>
                  <tr><th><button class="profile-round-sort" type="button" data-round-sort="date">Date</button></th><th><button class="profile-round-sort" type="button" data-round-sort="toPar">Total</button></th>{coursePars.map((_par, index) => <th><button class="profile-round-sort" type="button" data-round-sort={`h${index + 1}`}>{index + 1}</button></th>)}<th><button class="profile-round-sort" type="button" data-round-sort="total">Round</button></th></tr>
                  <tr><th>Par</th><th>{formatToPar(0)}</th>{coursePars.map((par) => <th>{par}</th>)}<th>{coursePars.reduce((sum, par) => sum + Number(par || 0), 0)}</th></tr>
                </thead>
                <tbody data-round-list="desktop">{roundHistory.map((round) => <tr data-round-item data-sort-date={round.dateKey} data-sort-to-par={round.toPar} data-sort-total={round.total} {...Object.fromEntries(round.scores.map((score, index) => [`data-sort-h${index + 1}`, score]))}><td>{round.href ? <a class="profile-link" href={round.href}>{round.displayDate}</a> : round.displayDate}</td><td>{round.toParLabel}</td>{round.holes.map((hole) => <td><span class={`profile-round-score profile-round-score--${hole.className}`}>{hole.score}</span></td>)}<td>{round.total}</td></tr>)}</tbody>
              </table>
            </div>
            <div class="profile-round-mobile">
              <div class="profile-round-mobile-controls" aria-label="Sort round history"><button class="profile-round-sort" type="button" data-round-sort="date">Date</button><button class="profile-round-sort" type="button" data-round-sort="toPar">Total</button><button class="profile-round-sort" type="button" data-round-sort="total">Round</button></div>
              <div class="profile-round-mobile-list" data-round-list="mobile">{roundHistory.map((round) => <article class="profile-round-card" data-round-item data-sort-date={round.dateKey} data-sort-to-par={round.toPar} data-sort-total={round.total} {...Object.fromEntries(round.scores.map((score, index) => [`data-sort-h${index + 1}`, score]))}><div class="profile-round-mobile-summary" role="button" tabindex="0" aria-expanded="false"><span>{round.href ? <a class="profile-link" href={round.href}>{round.displayDate}</a> : round.displayDate}</span><span>{round.toParLabel}</span><span>{round.total}</span><span>⌄</span></div><div class="profile-round-mobile-detail"><div class="profile-round-panels"><div class="profile-round-panel"><div class="profile-round-panel-grid">{round.holes.slice(0, 9).map((hole) => <div class="profile-round-panel-cell"><span>H{hole.hole}</span><span>Par {hole.par}</span><span class={`profile-round-score profile-round-score--${hole.className}`}>{hole.score}</span></div>)}</div></div><div class="profile-round-panel"><div class="profile-round-panel-grid">{round.holes.slice(9, 18).map((hole) => <div class="profile-round-panel-cell"><span>H{hole.hole}</span><span>Par {hole.par}</span><span class={`profile-round-score profile-round-score--${hole.className}`}>{hole.score}</span></div>)}</div></div></div></div></article>)}</div>
            </div>
          </> : <p class="profile-muted">No UDisc round history found.</p>}
        </div>
      </section>
      {courseViews.length ? <section class="profile-card" data-course-stats-card data-mobile-collapse data-default-open><div class="profile-card-header"><h2 class="profile-section-title">Course Stats</h2>{courseViews.length > 1 ? <select class="profile-course-filter" aria-label="Filter player course stats by year">{courseViews.map((view) => <option value={view.value}>{view.label}</option>)}</select> : null}<button class="profile-mobile-toggle" type="button" aria-label="Toggle section">⌄</button></div><div class="profile-card-body">{courseViews.map((view, index) => <div class="profile-course-panel" data-course-panel={view.value} hidden={index !== 0}><p class="profile-course-summary">{formatRounds(view.rounds)} • Original Layout</p><div class="profile-course-grid">{view.holes.map((hole) => <article class="profile-course-hole"><div class="profile-course-hole-header"><h3 class="profile-course-hole-title">Hole {hole.hole} <span>Par {hole.par}</span></h3><div class="profile-course-meta"><span>Diff. <strong>{hole.difficultyRank || "—"}</strong></span><span>Avg <strong>{formatAverage(hole.average)}</strong></span></div></div><div class="profile-course-bar" style={hole.barStyle}>{hole.segments.map((segment) => <div class={`profile-course-segment profile-course-segment--${segment.className}`} data-course-tip={`${segment.label}: ${segment.count} (${segment.pctNumber.toFixed(1)}%)`} title={`${segment.label}: ${segment.count} (${segment.pctNumber.toFixed(1)}%)`}>{segment.pctNumber >= 11 ? <span>{segment.count}</span> : null}</div>)}</div></article>)}</div></div>)}</div></section> : null}
    </div>
    <div class="profile-chart-tooltip" aria-hidden="true"></div>
  </main>

  <script is:inline>
    (() => {
      const isMobile = window.matchMedia("(max-width: 900px)").matches;
      if (isMobile) {
        const mainStack = document.querySelector(".profile-main");
        const personalBestCard = document.querySelector("[data-profile-personal-best]");
        if (mainStack && personalBestCard) personalBestCard.insertAdjacentElement("afterend", mainStack);
      }

      document.querySelectorAll("[data-mobile-collapse]").forEach((card) => {
        const header = card.querySelector(".profile-card-header");
        if (card.hasAttribute("data-default-collapsed")) card.classList.add("is-collapsed");
        if (isMobile && !card.hasAttribute("data-default-open") && !card.hasAttribute("data-default-collapsed")) card.classList.add("is-collapsed");
        if (!header) return;
        header.addEventListener("click", (event) => {
          if (!isMobile && !card.hasAttribute("data-default-collapsed")) return;
          if (event.target.closest("select")) return;
          const topBefore = header.getBoundingClientRect().top;
          card.classList.toggle("is-collapsed");
          window.requestAnimationFrame(() => {
            const topAfter = header.getBoundingClientRect().top;
            window.scrollBy(0, topAfter - topBefore);
          });
        });
      });

      document.querySelectorAll("[data-course-stats-card]").forEach((card) => {
        const select = card.querySelector(".profile-course-filter");
        if (!select) return;
        const panels = Array.from(card.querySelectorAll("[data-course-panel]"));
        select.addEventListener("change", () => panels.forEach((panel) => { panel.hidden = panel.dataset.coursePanel !== select.value; }));
      });

      const roundCard = document.querySelector("[data-round-history-card]");
      let roundSort = { key: "date", direction: "desc" };
      function roundValue(item, key) {
        if (key === "date") return item.dataset.sortDate || "";
        const attr = key === "toPar" ? "sortToPar" : key === "total" ? "sortTotal" : `sort${key.charAt(0).toUpperCase()}${key.slice(1)}`;
        const value = Number(item.dataset[attr]);
        return Number.isFinite(value) ? value : 9999;
      }
      function sortRoundList(key) {
        if (!roundCard) return;
        roundSort.direction = roundSort.key === key && roundSort.direction === "asc" ? "desc" : "asc";
        roundSort.key = key;
        roundCard.querySelectorAll("[data-round-list]").forEach((list) => {
          const items = Array.from(list.querySelectorAll("[data-round-item]"));
          items.sort((a, b) => {
            const av = roundValue(a, key);
            const bv = roundValue(b, key);
            const result = typeof av === "string" ? av.localeCompare(bv) : av - bv;
            return roundSort.direction === "asc" ? result : -result;
          });
          items.forEach((item) => list.appendChild(item));
        });
      }
      roundCard?.querySelectorAll("[data-round-sort]").forEach((button) => button.addEventListener("click", (event) => { event.stopPropagation(); sortRoundList(button.dataset.roundSort || "date"); }));
      roundCard?.querySelectorAll(".profile-round-mobile-summary").forEach((summary) => {
        summary.addEventListener("click", (event) => {
          if (event.target.closest("a")) return;
          const card = summary.closest(".profile-round-card");
          card?.classList.toggle("is-expanded");
          summary.setAttribute("aria-expanded", card?.classList.contains("is-expanded") ? "true" : "false");
        });
        summary.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          event.preventDefault();
          summary.click();
        });
      });

      const tooltip = document.querySelector(".profile-chart-tooltip");
      let courseTipTimer;
      function findHotspotFromPoint(shell, clientX) {
        const items = Array.from(shell.querySelectorAll(".profile-chart-hotspot"));
        if (!items.length) return null;
        let best = items[0];
        let bestDistance = Infinity;
        items.forEach((item) => {
          const rect = item.getBoundingClientRect();
          const centerX = rect.left + rect.width / 2;
          const distance = Math.abs(centerX - clientX);
          if (distance < bestDistance) { best = item; bestDistance = distance; }
        });
        return best;
      }
      function placeTooltip(x, y) {
        if (!tooltip) return;
        const margin = 10;
        const width = tooltip.offsetWidth || 0;
        const height = tooltip.offsetHeight || 0;
        const nextX = Math.min(Math.max(x, margin), Math.max(margin, window.innerWidth - width - margin));
        const nextY = Math.min(Math.max(y, margin + height), Math.max(margin + height, window.innerHeight - margin));
        tooltip.style.left = `${nextX}px`;
        tooltip.style.top = `${nextY}px`;
      }
      function show(target, clientX) {
        if (!tooltip || !target) return;
        const text = target.dataset.chartTip;
        if (!text) return;
        const svg = target.closest("svg");
        const guide = svg?.querySelector(".profile-chart-guide");
        const chartX = target.dataset.chartX;
        if (guide && chartX) {
          guide.setAttribute("x1", chartX);
          guide.setAttribute("x2", chartX);
          guide.style.display = "block";
        }
        const rect = target.getBoundingClientRect();
        tooltip.textContent = text;
        tooltip.classList.add("is-visible");
        placeTooltip(clientX || rect.left + rect.width / 2, rect.top);
      }
      function showCourseTip(segment, clientX, clientY) {
        if (!tooltip || !segment) return;
        const text = segment.dataset.courseTip;
        if (!text) return;
        const rect = segment.getBoundingClientRect();
        clearTimeout(courseTipTimer);
        tooltip.textContent = text;
        tooltip.classList.add("is-visible");
        placeTooltip(clientX || rect.left + rect.width / 2, clientY || rect.top);
      }
      function hide() {
        clearTimeout(courseTipTimer);
        if (tooltip) tooltip.classList.remove("is-visible");
        document.querySelectorAll(".profile-chart-guide").forEach((guide) => { guide.style.display = "none"; });
      }
      function getCourseSegment(event) {
        return event.target?.closest?.(".profile-course-segment") || null;
      }
      document.addEventListener("mouseover", (event) => {
        if (event.target?.classList?.contains("profile-chart-hotspot")) show(event.target, event.clientX);
        const segment = getCourseSegment(event);
        if (segment) showCourseTip(segment, event.clientX, event.clientY);
      });
      document.addEventListener("mousemove", (event) => {
        const segment = getCourseSegment(event);
        if (segment) showCourseTip(segment, event.clientX, event.clientY);
      });
      document.addEventListener("mouseout", (event) => {
        if (event.target?.classList?.contains("profile-chart-hotspot")) hide();
        const segment = getCourseSegment(event);
        if (segment && !segment.contains(event.relatedTarget)) hide();
      });
      document.addEventListener("pointerdown", (event) => {
        const segment = getCourseSegment(event);
        if (!segment) return;
        showCourseTip(segment, event.clientX, event.clientY);
        if (event.pointerType !== "mouse") courseTipTimer = setTimeout(hide, 2500);
      });
      document.querySelectorAll(".profile-chart-shell").forEach((shell) => {
        shell.addEventListener("pointerdown", (event) => { const target = findHotspotFromPoint(shell, event.clientX); show(target, event.clientX); });
        shell.addEventListener("pointermove", (event) => { if (event.pointerType === "mouse" && event.buttons === 0) return; const target = findHotspotFromPoint(shell, event.clientX); show(target, event.clientX); });
        shell.addEventListener("pointerleave", hide);
        shell.addEventListener("pointercancel", hide);
        shell.addEventListener("pointerup", hide);
      });
      window.addEventListener("scroll", hide, { passive: true });
    })();
  </script>
</SiteLayout>
