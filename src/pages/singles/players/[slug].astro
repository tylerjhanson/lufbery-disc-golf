---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import courseStats from "../../../data/course-stats.generated.json";
import { getPlayerProfiles } from "../../../lib/data";

const HANDICAP_PAR = 56;
const SEGMENT_CLASSES: Record<string, string> = {
  ace: "ace",
  birdie: "birdie",
  par: "par",
  bogey: "bogey",
  double: "double",
  triple: "triple",
};

type AnyProfile = Record<string, any>;

type ChartPoint = {
  label: string;
  value: number;
  detail?: string;
};

function cleanName(value: string) {
  return String(value || "").replace(/\s+/g, " ").trim();
}

function playerSlug(value: string) {
  return cleanName(value)
    .toLowerCase()
    .replace(/&/g, " and ")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function normalizePlayerKey(value: string) {
  return cleanName(value).toLowerCase();
}

function parseDisplayYear(value: string) {
  const parts = String(value || "").split("/");
  let year = Number(parts[2] || 0);
  if (year < 100) year += 2000;
  return year;
}

function formatScoreWithPar(score: number | string) {
  const numericScore = Number(score);
  if (!Number.isFinite(numericScore)) return "—";
  const diff = numericScore - HANDICAP_PAR;
  if (diff === 0) return `${numericScore} (E)`;
  return `${numericScore} (${diff > 0 ? "+" : ""}${diff})`;
}

function formatAverage(value: number | string) {
  const number = Number(value || 0);
  return Number.isFinite(number) ? number.toFixed(2) : "—";
}

function formatRounds(rounds: number | string) {
  const count = Number(rounds || 0);
  return `${new Intl.NumberFormat("en-US").format(count)} round${count === 1 ? "" : "s"}`;
}

function buildYearlyScoreAverages(rounds: any[]) {
  const buckets = new Map<number, number[]>();
  rounds.forEach((round) => {
    const year = parseDisplayYear(round?.date);
    const score = Number(round?.score);
    if (!Number.isFinite(year) || year < 2021 || !Number.isFinite(score)) return;
    const bucket = buckets.get(year) || [];
    bucket.push(score);
    buckets.set(year, bucket);
  });

  return Array.from(buckets.entries())
    .sort((a, b) => a[0] - b[0])
    .map(([year, scores]) => ({
      year: String(year),
      value: (scores.reduce((sum, score) => sum + score, 0) / scores.length).toFixed(1),
    }));
}

function buildEffectiveHandicapHistory(history: any[], currentHandicap: string) {
  const baseHistory = Array.isArray(history)
    ? history
        .map((row) => ({ date: String(row?.date || ""), handicap: Number(row?.handicap) }))
        .filter((row) => row.date && Number.isFinite(row.handicap))
    : [];

  const current = Number(currentHandicap);
  if (!Number.isFinite(current)) return baseHistory;
  if (!baseHistory.length) return [{ date: "Current", handicap: current }];

  const lastPoint = baseHistory[baseHistory.length - 1];
  if (Number(lastPoint?.handicap) === current) return baseHistory;
  return [...baseHistory, { date: "Current", handicap: current }];
}

function getLowestHandicap(history: any[], currentHandicap: string) {
  const values = Array.isArray(history)
    ? history.map((row) => Number(row?.handicap)).filter((value) => Number.isFinite(value))
    : [];
  const current = Number(currentHandicap);
  if (Number.isFinite(current)) values.push(current);
  return values.length ? String(Math.min(...values)) : "";
}

function buildYearlyBestHandicaps(history: any[]) {
  const bestByYear = new Map<number, number>();
  history.forEach((row) => {
    const year = parseDisplayYear(row?.date);
    const handicap = Number(row?.handicap);
    if (!Number.isFinite(year) || year < 2023 || !Number.isFinite(handicap)) return;
    const current = bestByYear.get(year);
    if (current == null || handicap < current) bestByYear.set(year, handicap);
  });
  return Array.from(bestByYear.entries())
    .sort((a, b) => a[0] - b[0])
    .map(([year, value]) => ({ year: String(year), value: String(value) }));
}

function buildYearlyBestTags(history: any[]) {
  const bestByYear = new Map<number, number>();
  history.forEach((row) => {
    const year = parseDisplayYear(row?.date);
    const tag = Number(row?.tag);
    if (!Number.isFinite(year) || year < 2023 || !Number.isFinite(tag)) return;
    const current = bestByYear.get(year);
    if (current == null || tag < current) bestByYear.set(year, tag);
  });
  return Array.from(bestByYear.entries())
    .sort((a, b) => a[0] - b[0])
    .map(([year, value]) => ({ year: String(year), value: String(value) }));
}

function buildLineChart(points: ChartPoint[], lowerIsBetter = true, options: { step?: number; min?: number; showTrend?: boolean } = {}) {
  const cleanPoints = points.filter((point) => Number.isFinite(point.value));
  if (!cleanPoints.length) return "";

  const values = cleanPoints.map((point) => point.value);
  const width = 640;
  const height = 210;
  const padTop = 12;
  const padRight = 10;
  const padBottom = 14;
  const padLeft = 42;
  const innerWidth = width - padLeft - padRight;
  const innerHeight = height - padTop - padBottom;

  const fixedStep = Number(options.step);
  const useFixedStep = Number.isFinite(fixedStep) && fixedStep > 0;
  let chartMin = Math.min(...values);
  let chartMax = Math.max(...values);

  if (useFixedStep) {
    const minBase = Number.isFinite(Number(options.min)) ? Number(options.min) : 0;
    chartMin = Math.min(minBase, chartMin);
    chartMin = Math.floor(chartMin / fixedStep) * fixedStep;
    chartMax = Math.ceil(chartMax / fixedStep) * fixedStep;
    if (chartMax <= chartMin) chartMax = chartMin + fixedStep;
  } else {
    if (chartMin === chartMax) chartMax = chartMin + 1;
    const range = chartMax - chartMin;
    const step = range <= 10 ? 1 : range <= 30 ? 5 : 10;
    chartMin = Math.max(1, Math.floor(chartMin / step) * step);
    chartMax = Math.ceil(chartMax / step) * step;
    if (chartMin === chartMax) chartMax = chartMin + step;
  }

  const tickStep = useFixedStep ? fixedStep : chartMax - chartMin <= 10 ? 1 : chartMax - chartMin <= 30 ? 5 : 10;
  const ticks = [];
  for (let value = chartMin; value <= chartMax; value += tickStep) ticks.push(value);

  const getX = (index: number) => cleanPoints.length === 1 ? padLeft + innerWidth / 2 : padLeft + (index / (cleanPoints.length - 1)) * innerWidth;
  const getY = (value: number) => lowerIsBetter
    ? padTop + ((value - chartMin) / (chartMax - chartMin)) * innerHeight
    : padTop + ((chartMax - value) / (chartMax - chartMin)) * innerHeight;

  const polyline = cleanPoints.map((point, index) => `${getX(index)},${getY(point.value)}`).join(" ");
  const dots = cleanPoints
    .map((point, index) => `<circle class="profile-chart-dot" cx="${getX(index)}" cy="${getY(point.value)}" r="3"><title>${point.detail || `${point.label}: ${point.value}`}</title></circle>`)
    .join("");
  const grid = ticks
    .map((tick) => {
      const y = getY(tick);
      return `<line class="profile-chart-grid" x1="${padLeft}" y1="${y}" x2="${width - padRight}" y2="${y}" /><text class="profile-chart-axis" x="${padLeft - 8}" y="${y + 4}" text-anchor="end">${Math.round(tick)}</text>`;
    })
    .join("");

  return `<div class="profile-chart-shell"><svg class="profile-chart" viewBox="0 0 ${width} ${height}" preserveAspectRatio="none">${grid}<polyline class="profile-chart-line" points="${polyline}" />${dots}</svg></div>`;
}

function getCourseStatsForPlayer(name: string) {
  const players = (courseStats as any)?.players || {};
  const aliases = (courseStats as any)?.source?.aliases || {};
  const key = normalizePlayerKey(name);
  const aliasKey = aliases[key] || key;
  return players[aliasKey] || players[key] || null;
}

function courseBarStyle(segments: any[]) {
  const visible = Array.isArray(segments) ? segments.filter((segment) => Number(segment?.count || 0) > 0) : [];
  if (!visible.length) return "grid-template-columns:1fr;";
  return `grid-template-columns:${visible.map((segment) => `${Math.max(1, Number(segment.count || 0))}fr`).join(" ")};`;
}

export function getStaticPaths() {
  const profiles = Object.values(getPlayerProfiles()) as AnyProfile[];
  const seen = new Set<string>();
  return profiles
    .map((profile) => ({ profile, slug: playerSlug(String(profile.name || "")) }))
    .filter(({ slug }) => {
      if (!slug || seen.has(slug)) return false;
      seen.add(slug);
      return true;
    })
    .map(({ profile, slug }) => ({ params: { slug }, props: { profile } }));
}

const { profile } = Astro.props as { profile: AnyProfile };
const name = String(profile?.name || "Player");
const allRounds = Array.isArray(profile?.allRounds) ? profile.allRounds : [];
const recentRounds = Array.isArray(profile?.recentRounds) ? profile.recentRounds : [];
const handicapHistory = Array.isArray(profile?.handicapHistory)
  ? profile.handicapHistory.filter((row) => parseDisplayYear(row?.date) >= 2023)
  : [];
const tagHistory = Array.isArray(profile?.tagHistory)
  ? profile.tagHistory.filter((row) => parseDisplayYear(row?.date) >= 2023)
  : [];
const weeklyWins = Array.isArray(profile?.weeklyWins) ? profile.weeklyWins : [];
const bestOverallWins = Array.isArray(profile?.bestOverallWins) ? profile.bestOverallWins : [];
const aces = Array.isArray(profile?.aces) ? profile.aces : [];
const personalBests = Array.isArray(profile?.personalBests) && profile.personalBests.length
  ? profile.personalBests
  : profile?.personalBest
    ? [profile.personalBest]
    : [];
const effectiveHandicapHistory = buildEffectiveHandicapHistory(handicapHistory, String(profile?.handicap || ""));
const courseStatsForPlayer = getCourseStatsForPlayer(name);
const courseHoles = courseStatsForPlayer?.holes ? [...courseStatsForPlayer.holes].sort((a: any, b: any) => Number(a.hole) - Number(b.hole)) : [];
---

<SiteLayout title={`${name} Player Profile`} description={`League player profile and history for ${name}.`} showBrandBar={true}>
  <style is:global>
    :root {
      --bg: #f5f7fb;
      --card: #ffffff;
      --text: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --line-soft: #eef2f7;
      --header: #f8fafc;
      --accent: #2563eb;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      --radius: 22px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      padding: 24px;
      font-family: Inter, Arial, Helvetica, sans-serif;
      background: linear-gradient(180deg, #f8fafc 0%, var(--bg) 100%);
      color: var(--text);
    }

    .player-profile-wrap {
      width: min(1180px, 100%);
      margin: 0 auto;
    }

    .profile-back-link {
      display: inline-flex;
      margin-bottom: 14px;
      color: var(--muted);
      font-size: 0.9rem;
      font-weight: 700;
      text-decoration: none;
    }

    .profile-back-link:hover { color: var(--accent); }

    .profile-header {
      margin-bottom: 18px;
      padding: 24px;
      border: 1px solid var(--line-soft);
      border-radius: var(--radius);
      background: var(--card);
      box-shadow: var(--shadow);
    }

    .profile-kicker {
      margin: 0 0 8px;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-size: clamp(2.1rem, 5vw, 4rem);
      line-height: 0.98;
      letter-spacing: -0.045em;
    }

    .profile-summary-grid {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 12px;
      margin-top: 22px;
    }

    .profile-stat {
      padding: 14px;
      border: 1px solid var(--line-soft);
      border-radius: 16px;
      background: var(--header);
      min-width: 0;
    }

    .profile-stat-label {
      display: block;
      margin-bottom: 5px;
      color: var(--muted);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .profile-stat-value {
      font-size: 1.25rem;
      font-weight: 850;
      line-height: 1.05;
      word-break: break-word;
    }

    .profile-content-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(300px, 0.42fr);
      gap: 18px;
      align-items: start;
    }

    .profile-stack {
      display: grid;
      gap: 18px;
    }

    .profile-card {
      border: 1px solid var(--line-soft);
      border-radius: var(--radius);
      background: var(--card);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .profile-card-header {
      padding: 18px 20px 10px;
    }

    .profile-section-title {
      margin: 0;
      font-size: 0.9rem;
      font-weight: 850;
      letter-spacing: 0.04em;
      line-height: 1.2;
      text-transform: uppercase;
    }

    .profile-card-body {
      padding: 0 20px 18px;
    }

    .profile-chart-shell {
      margin-top: 0;
      margin-bottom: 12px;
      padding: 12px;
      border: 1px solid var(--line-soft);
      border-radius: 14px;
      background: var(--header);
    }

    .profile-chart {
      display: block;
      width: 100%;
      height: 210px;
      overflow: visible;
    }

    .profile-chart-grid {
      stroke: var(--line);
      stroke-width: 1;
      opacity: 0.8;
    }

    .profile-chart-axis {
      fill: var(--muted);
      font-family: Inter, Arial, Helvetica, sans-serif;
      font-size: 12px;
    }

    .profile-chart-line {
      fill: none;
      stroke: var(--accent);
      stroke-width: 2.5;
      stroke-linecap: round;
      stroke-linejoin: round;
      vector-effect: non-scaling-stroke;
    }

    .profile-chart-dot {
      fill: var(--card);
      stroke: var(--accent);
      stroke-width: 2;
      vector-effect: non-scaling-stroke;
    }

    .profile-year-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }

    .profile-year-pill {
      padding: 7px 10px;
      border: 1px solid var(--line-soft);
      border-radius: 999px;
      background: var(--card);
      color: var(--text);
      font-size: 0.88rem;
      font-weight: 750;
    }

    .profile-table {
      width: 100%;
      border-collapse: collapse;
    }

    .profile-table th,
    .profile-table td {
      padding: 10px 0;
      border-bottom: 1px solid var(--line-soft);
      text-align: left;
      font-size: 0.94rem;
      vertical-align: top;
    }

    .profile-table th:last-child,
    .profile-table td:last-child {
      text-align: right;
    }

    .profile-table th {
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 800;
    }

    .profile-link-list {
      display: grid;
      gap: 9px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .profile-link-list li {
      line-height: 1.35;
      font-size: 0.95rem;
    }

    .profile-link {
      color: var(--accent);
      font-weight: 700;
      text-decoration: none;
    }

    .profile-link:hover { text-decoration: underline; }

    .profile-muted {
      color: var(--muted);
      font-size: 0.92rem;
      font-weight: 650;
    }

    .profile-course-summary {
      margin: 0 0 10px;
      color: var(--muted);
      font-size: 0.9rem;
      font-weight: 800;
    }

    .profile-course-grid {
      display: grid;
      gap: 8px;
    }

    .profile-course-hole {
      padding: 9px;
      border: 1px solid var(--line-soft);
      border-radius: 13px;
      background: var(--card);
    }

    .profile-course-hole-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 7px;
    }

    .profile-course-hole-title {
      margin: 0;
      font-size: 0.95rem;
      font-weight: 850;
      line-height: 1.2;
    }

    .profile-course-hole-title span {
      margin-left: 5px;
      color: var(--muted);
      font-size: 0.8rem;
      font-weight: 600;
    }

    .profile-course-meta {
      display: inline-flex;
      gap: 8px;
      white-space: nowrap;
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 700;
    }

    .profile-course-meta strong {
      color: var(--text);
      font-size: 1.05em;
      font-weight: 850;
    }

    .profile-course-bar {
      display: grid;
      min-height: 20px;
      overflow: hidden;
      border: 2px solid #cfe0ef;
      border-radius: 9px;
      background: var(--card);
    }

    .profile-course-segment { min-width: 0; position: relative; }
    .profile-course-segment + .profile-course-segment { box-shadow: inset 1px 0 0 rgba(15, 23, 42, 0.1); }
    .profile-course-segment span {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      font-size: 0.72rem;
      font-weight: 850;
      line-height: 1;
    }

    .profile-course-segment--ace { background: #2f6fb6; color: #fff; }
    .profile-course-segment--birdie { background: #6c9bd1; color: #fff; }
    .profile-course-segment--par { background: var(--card); color: var(--text); }
    .profile-course-segment--bogey { background: #f2d8c8; color: #2e3440; }
    .profile-course-segment--double { background: #efb286; color: #2e3440; }
    .profile-course-segment--triple { background: #eb7b3c; color: #fff; }

    @media (prefers-color-scheme: dark) {
      :root:not([data-theme="light"]) .profile-course-bar { border-color: #334155; }
      :root:not([data-theme="light"]) .profile-course-segment + .profile-course-segment { box-shadow: inset 1px 0 0 rgba(248, 250, 252, 0.16); }
    }

    [data-theme="dark"] .profile-course-bar { border-color: #334155; }
    [data-theme="dark"] .profile-course-segment + .profile-course-segment { box-shadow: inset 1px 0 0 rgba(248, 250, 252, 0.16); }

    @media (max-width: 900px) {
      body { padding: 14px; }
      .profile-summary-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .profile-content-grid { grid-template-columns: 1fr; }
      .profile-header { padding: 20px 16px; }
      .profile-card-header { padding: 16px 16px 10px; }
      .profile-card-body { padding: 0 16px 16px; }
    }

    @media (max-width: 460px) {
      .profile-summary-grid { grid-template-columns: 1fr; }
      .profile-course-hole-header { gap: 6px; }
      .profile-course-hole-title { font-size: 0.88rem; white-space: nowrap; }
      .profile-course-hole-title span { font-size: 0.72rem; }
      .profile-course-meta { gap: 5px; font-size: 0.7rem; }
      .profile-chart { height: 170px; }
    }
  </style>

  <main class="player-profile-wrap">
    <a class="profile-back-link" href="/singles/handicaps-tags/">← Back to Handicaps & Tags</a>

    <header class="profile-header">
      <p class="profile-kicker">Player Profile</p>
      <h1>{name}</h1>

      <div class="profile-summary-grid">
        <div class="profile-stat"><span class="profile-stat-label">Current handicap</span><span class="profile-stat-value">{profile?.handicap || "—"}</span></div>
        <div class="profile-stat"><span class="profile-stat-label">Current tag</span><span class="profile-stat-value">{profile?.hasTag ? profile?.currentTag || "TBD" : "—"}</span></div>
        <div class="profile-stat"><span class="profile-stat-label">Average score</span><span class="profile-stat-value">{profile?.average || "—"}</span></div>
        <div class="profile-stat"><span class="profile-stat-label">Best tag</span><span class="profile-stat-value">{profile?.bestTagEver || "—"}</span></div>
        <div class="profile-stat"><span class="profile-stat-label">Lowest handicap</span><span class="profile-stat-value">{getLowestHandicap(handicapHistory, String(profile?.handicap || "")) || "—"}</span></div>
        <div class="profile-stat"><span class="profile-stat-label">Course stats</span><span class="profile-stat-value">{courseStatsForPlayer ? formatRounds(courseStatsForPlayer.rounds) : "—"}</span></div>
      </div>
    </header>

    <div class="profile-content-grid">
      <div class="profile-stack">
        <section class="profile-card">
          <div class="profile-card-header"><h2 class="profile-section-title">Score History</h2></div>
          <div class="profile-card-body">
            {allRounds.length ? <Fragment set:html={buildLineChart(allRounds.map((round: any) => ({ value: Number(round.score), label: String(round.date || ""), detail: `${round.date} — ${formatScoreWithPar(round.score)}` })), true)} /> : <p class="profile-muted">No score history found.</p>}
            {buildYearlyScoreAverages(allRounds).length ? (
              <div class="profile-year-stats">
                {buildYearlyScoreAverages(allRounds).map((row) => <span class="profile-year-pill"><strong>{row.year}:</strong> {row.value}</span>)}
              </div>
            ) : null}
          </div>
        </section>

        <section class="profile-card">
          <div class="profile-card-header"><h2 class="profile-section-title">Handicap History</h2></div>
          <div class="profile-card-body">
            {effectiveHandicapHistory.length ? <Fragment set:html={buildLineChart(effectiveHandicapHistory.map((row: any) => ({ value: Number(row.handicap), label: String(row.date || ""), detail: `${row.date} — ${row.handicap}` })), true, { step: 1, min: Math.floor(Math.min(...effectiveHandicapHistory.map((row: any) => Number(row.handicap)))) - 1 })} /> : <p class="profile-muted">No handicap history found.</p>}
            {buildYearlyBestHandicaps(effectiveHandicapHistory).length ? (
              <div class="profile-year-stats">
                {buildYearlyBestHandicaps(effectiveHandicapHistory).map((row) => <span class="profile-year-pill"><strong>{row.year}:</strong> {row.value}</span>)}
              </div>
            ) : null}
          </div>
        </section>

        <section class="profile-card">
          <div class="profile-card-header"><h2 class="profile-section-title">Tag History</h2></div>
          <div class="profile-card-body">
            {tagHistory.length ? <Fragment set:html={buildLineChart(tagHistory.map((row: any) => ({ value: Number(row.tag), label: String(row.date || ""), detail: `${row.date} — #${row.tag}` })), true, { step: 5, min: 0 })} /> : <p class="profile-muted">No tag history found.</p>}
            {buildYearlyBestTags(tagHistory).length ? (
              <div class="profile-year-stats">
                {buildYearlyBestTags(tagHistory).map((row) => <span class="profile-year-pill"><strong>{row.year}:</strong> #{row.value}</span>)}
              </div>
            ) : null}
          </div>
        </section>

        {courseStatsForPlayer ? (
          <section class="profile-card">
            <div class="profile-card-header"><h2 class="profile-section-title">Course Stats</h2></div>
            <div class="profile-card-body">
              <p class="profile-course-summary">{formatRounds(courseStatsForPlayer.rounds)} • Original Layout</p>
              <div class="profile-course-grid">
                {courseHoles.map((hole: any) => (
                  <article class="profile-course-hole">
                    <div class="profile-course-hole-header">
                      <h3 class="profile-course-hole-title">Hole {hole.hole} <span>Par {hole.par}</span></h3>
                      <div class="profile-course-meta">
                        <span>Diff. <strong>{hole.difficultyRank || "—"}</strong></span>
                        <span>Avg <strong>{formatAverage(hole.average)}</strong></span>
                      </div>
                    </div>
                    <div class="profile-course-bar" style={courseBarStyle(hole.segments)}>
                      {(hole.segments || []).filter((segment: any) => Number(segment?.count || 0) > 0).map((segment: any) => {
                        const kind = SEGMENT_CLASSES[String(segment.kind || "par")] || "par";
                        const pct = Number(segment.pct || 0);
                        return <div class={`profile-course-segment profile-course-segment--${kind}`} title={`${segment.label}: ${segment.count} (${pct.toFixed(1)}%)`}>{pct >= 11 ? <span>{segment.count}</span> : null}</div>;
                      })}
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </section>
        ) : null}
      </div>

      <aside class="profile-stack">
        <section class="profile-card">
          <div class="profile-card-header"><h2 class="profile-section-title">Rounds Counting Towards Handicap</h2></div>
          <div class="profile-card-body">
            <table class="profile-table">
              <thead><tr><th>Date</th><th>Score</th></tr></thead>
              <tbody>
                {recentRounds.length ? recentRounds.map((round: any) => (
                  <tr><td>{round.date}</td><td>{formatScoreWithPar(round.score)}</td></tr>
                )) : <tr><td colspan="2" class="profile-muted">No handicap rounds found.</td></tr>}
              </tbody>
            </table>
          </div>
        </section>

        <section class="profile-card">
          <div class="profile-card-header"><h2 class="profile-section-title">Personal Best</h2></div>
          <div class="profile-card-body">
            {personalBests.length ? (
              <ul class="profile-link-list">
                {personalBests.map((item: any) => <li><strong>{item.score}</strong> <a class="profile-link" href={item.href}>{item.date}</a></li>)}
              </ul>
            ) : <p class="profile-muted">No personal best found.</p>}
          </div>
        </section>

        <section class="profile-card">
          <div class="profile-card-header"><h2 class="profile-section-title">Weekly Wins</h2></div>
          <div class="profile-card-body">
            {weeklyWins.length ? (
              <ul class="profile-link-list">
                {weeklyWins.map((item: any) => <li><a class="profile-link" href={item.href}>{item.date}</a> — {item.label} • {item.score}</li>)}
              </ul>
            ) : <p class="profile-muted">No weekly wins recorded.</p>}
          </div>
        </section>

        <section class="profile-card">
          <div class="profile-card-header"><h2 class="profile-section-title">Best Overall</h2></div>
          <div class="profile-card-body">
            {bestOverallWins.length ? (
              <ul class="profile-link-list">
                {bestOverallWins.map((item: any) => <li><a class="profile-link" href={item.href}>{item.date}</a> — {item.label} • {item.score}{item.isTie ? " • Tie" : ""}</li>)}
              </ul>
            ) : <p class="profile-muted">No best overall wins recorded.</p>}
          </div>
        </section>

        <section class="profile-card">
          <div class="profile-card-header"><h2 class="profile-section-title">Aces</h2></div>
          <div class="profile-card-body">
            {aces.length ? (
              <ul class="profile-link-list">
                {aces.map((item: any) => <li><a class="profile-link" href={item.href}>{item.date}</a> — {item.label ? `${item.label} • ` : ""}{item.hole ? `Hole ${item.hole}` : "Ace"}</li>)}
              </ul>
            ) : <p class="profile-muted">No aces recorded.</p>}
          </div>
        </section>
      </aside>
    </div>
  </main>
</SiteLayout>
