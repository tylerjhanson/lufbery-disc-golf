---
const sheetId = "1FlsTEEik9UUMZQmjTOVkP7dOqGho9_GRFDC5PIVgXPo";
const sheetGid = "0";

const udiscUrl = "https://udisc.com/leagues/lufbery-league";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="Lost & Found" showBrandBar={true}>
  <style>
    :root {
      --bg: #f5f7fb;
      --card: #ffffff;
      --text: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --line-soft: #eef2f7;
      --header: #f8fafc;
      --hover: #f9fbff;
      --accent: #2563eb;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      --radius: 22px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 24px;
      font-family: Inter, Arial, Helvetica, sans-serif;
      background: linear-gradient(180deg, #f8fafc 0%, var(--bg) 100%);
      color: var(--text);
    }

    .wrap {
      width: 100%;
      max-width: none;
      margin: 0;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-radius: 12px;
      box-shadow: var(--shadow);
      padding: 28px 28px 22px;
    }

    h1 {
      margin: 0 0 18px;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
    }

    h2 {
      margin: 0;
      font-size: 1rem;
      line-height: 1.2;
    }

    p {
      margin: 0 0 18px;
      font-size: 1rem;
      line-height: 1.6;
    }

    .link {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
    }

    .link:hover {
      text-decoration: underline;
    }

    .bullet-list {
      margin: 0 0 18px 0;
      padding-left: 20px;
    }

    .bullet-list li {
      margin-bottom: 8px;
      line-height: 1.5;
    }

    .inventory-section {
      margin-top: 22px;
      padding-top: 14px;
      border-top: 1px solid var(--line-soft);
    }

    .inventory-header {
      padding: 0 0 10px;
    }

    .table-wrap {
      padding: 0;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      border: 1px solid var(--line-soft);
      border-radius: 10px;
      background: var(--card);
    }

    table.inventory-table {
      width: 100%;
      min-width: 520px;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: fixed;
    }

    table.inventory-table col.col-date {
      width: 15%;
    }

    table.inventory-table col.col-name {
      width: 17%;
    }

    table.inventory-table col.col-brand {
      width: 21%;
    }

    table.inventory-table col.col-color {
      width: 13%;
    }

    table.inventory-table col.col-last4 {
      width: 14%;
    }

    table.inventory-table col.col-deadline {
      width: 14%;
    }

    table.inventory-table thead th {
      background: var(--header);
      color: var(--muted);
      font-size: 0.66rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.02em;
      padding: 8px 4px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      white-space: normal;
      line-height: 1.05;
      user-select: none;
      cursor: pointer;
    }

    table.inventory-table thead th:first-child {
      border-top-left-radius: 10px;
    }

    table.inventory-table thead th:last-child {
      border-top-right-radius: 10px;
    }

    table.inventory-table thead th:hover {
      background: #f3f7fc;
    }

    table.inventory-table tbody td {
      padding: 7px 4px;
      border-bottom: 1px solid var(--line-soft);
      font-size: 0.82rem;
      text-align: left;
      vertical-align: top;
      line-height: 1.08;
      white-space: normal;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    table.inventory-table tbody tr:nth-child(even) td {
      background: #fcfdff;
    }

    table.inventory-table tbody tr:hover td {
      background: var(--hover);
    }

    table.inventory-table tbody td:first-child,
    table.inventory-table tbody td:nth-child(6) {
      white-space: nowrap;
    }

    .inventory-th-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 4px;
      width: 100%;
    }

    .inventory-sort-indicator {
      color: var(--muted);
      font-size: 0.66rem;
      line-height: 1;
      min-width: 0.75em;
      text-align: right;
      flex: 0 0 auto;
    }

    .inventory-empty {
      color: var(--muted);
      text-align: center;
      padding: 18px 12px;
    }

    @media (max-width: 700px) {
      body {
        padding: 10px;
      }

      .card {
        padding: 20px 18px 16px;
      }

      p,
      .bullet-list li {
        font-size: 0.96rem;
      }

      .inventory-section {
        margin-top: 18px;
        padding-top: 12px;
      }

      table.inventory-table {
        min-width: 500px;
      }

      table.inventory-table thead th {
        font-size: 0.58rem;
        padding: 6px 3px;
        letter-spacing: 0;
      }

      table.inventory-table tbody td {
        font-size: 0.76rem;
        padding: 6px 3px;
        line-height: 1.05;
      }

      .inventory-sort-indicator {
        font-size: 0.58rem;
      }
    }

    @media (max-width: 420px) {
      h1 {
        font-size: 1.9rem;
      }

      table.inventory-table {
        min-width: 480px;
      }

      table.inventory-table thead th {
        font-size: 0.54rem;
        padding: 6px 2px;
      }

      table.inventory-table tbody td {
        font-size: 0.72rem;
        padding: 5px 2px;
      }

      .inventory-sort-indicator {
        font-size: 0.54rem;
      }
    }
  </style>

  <div class="wrap">
    <div class="card">
      <h1>Lost &amp; Found</h1>

      <p>
        Lost discs are available for pick up before and after our weekly league rounds.
        Please check
        <a class="link" href={udiscUrl} target="_blank" rel="noopener">UDisc</a>
        for dates and times:
      </p>

      <ul class="bullet-list">
        <li>Sundays, 9 a.m., year round</li>
        <li>Thursday evenings April-September</li>
      </ul>

      <p>Discs not picked up within 60 days will be donated.</p>

      <div class="inventory-section">
        <div class="inventory-header">
          <h2>Current Inventory</h2>
        </div>

        <div class="table-wrap">
          <table class="inventory-table" id="inventoryTable">
            <colgroup>
              <col class="col-date" />
              <col class="col-name" />
              <col class="col-brand" />
              <col class="col-color" />
              <col class="col-last4" />
              <col class="col-deadline" />
            </colgroup>
            <thead id="inventoryHead"></thead>
            <tbody id="inventoryBody">
              <tr>
                <td class="inventory-empty" colspan="6">Loading inventory…</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ sheetId, sheetGid }}>
    const inventoryHead = document.getElementById("inventoryHead");
    const inventoryBody = document.getElementById("inventoryBody");

    const state = {
      labels: [],
      rows: [],
      sortIndex: 0,
      sortDir: "asc",
    };

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function formatDateValue(date) {
      const month = String(date.getMonth() + 1).padStart(2, "0");
      const day = String(date.getDate()).padStart(2, "0");
      return `${month}/${day}`;
    }

    function tryParseDate(value) {
      if (!value) return null;
      if (value instanceof Date && !Number.isNaN(value.getTime())) return value;

      const text = String(value).trim();
      if (!text) return null;

      const direct = new Date(text);
      if (!Number.isNaN(direct.getTime()) && /[\/\-]/.test(text)) return direct;

      const mmddyyyy = text.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/);
      if (mmddyyyy) {
        let [, m, d, y] = mmddyyyy;
        let year = Number(y);
        if (year < 100) year += 2000;
        const parsed = new Date(year, Number(m) - 1, Number(d));
        if (!Number.isNaN(parsed.getTime())) return parsed;
      }

      return null;
    }

    function displayCell(cell, colIndex = -1) {
      if (!cell) return "";

      const isDateColumn = colIndex === 0 || colIndex === 5;

      if (isDateColumn) {
        if (cell.v instanceof Date) return formatDateValue(cell.v);

        const formatted = cell.f !== null && cell.f !== undefined && cell.f !== ""
          ? String(cell.f).trim()
          : String(cell.v ?? "").trim();

        const parsed = tryParseDate(formatted);
        return parsed ? formatDateValue(parsed) : formatted;
      }

      if (cell.f !== null && cell.f !== undefined && cell.f !== "") return String(cell.f);
      if (cell.v === null || cell.v === undefined) return "";
      return String(cell.v);
    }

    function isReturnedTrue(cell) {
      if (!cell) return false;

      const raw = cell.v;
      if (raw === true) return true;

      const text = String(
        raw !== null && raw !== undefined ? raw : ""
      ).trim().toLowerCase();

      return text === "true";
    }

    function isBlankDisplayValue(value) {
      return String(value ?? "").trim() === "";
    }

    function isDisplayableRow(row) {
      const visibleCells = row.slice(0, 6);
      const returnedCell = row[6];

      const allBlank = visibleCells.every((cell, index) =>
        isBlankDisplayValue(displayCell(cell, index))
      );

      if (allBlank) return false;
      if (isReturnedTrue(returnedCell)) return false;

      return true;
    }

    function getCellSortValue(cell, colIndex) {
      if (!cell) return { type: "empty", value: "" };

      const raw = cell.v;
      const text = displayCell(cell, colIndex).trim();

      if (colIndex === 0 || colIndex === 5) {
        const parsedDate = tryParseDate(raw) || tryParseDate(text);
        if (parsedDate) return { type: "number", value: parsedDate.getTime() };
        return { type: "text", value: text.toLowerCase() };
      }

      if (colIndex === 4) {
        const digits = text.replace(/\s+/g, "");
        if (/^\d{1,4}$/.test(digits)) {
          return { type: "number", value: Number(digits) };
        }
        return { type: "text", value: text.toLowerCase() };
      }

      if (typeof raw === "number") return { type: "number", value: raw };
      if (typeof raw === "boolean") return { type: "number", value: raw ? 1 : 0 };

      const numeric = Number(text.replaceAll(",", "").replaceAll("$", "").replaceAll("%", ""));
      if (text !== "" && !Number.isNaN(numeric) && /^-?\d+(\.\d+)?$/.test(text.replaceAll(",", "").replaceAll("$", "").replaceAll("%", ""))) {
        return { type: "number", value: numeric };
      }

      return { type: "text", value: text.toLowerCase() };
    }

    function compareRows(a, b) {
      const left = getCellSortValue(a[state.sortIndex], state.sortIndex);
      const right = getCellSortValue(b[state.sortIndex], state.sortIndex);

      if (left.type !== right.type) {
        if (left.type === "number" && right.type !== "number") {
          return state.sortDir === "asc" ? -1 : 1;
        }
        if (left.type !== "number" && right.type === "number") {
          return state.sortDir === "asc" ? 1 : -1;
        }
      }

      if (left.value < right.value) return state.sortDir === "asc" ? -1 : 1;
      if (left.value > right.value) return state.sortDir === "asc" ? 1 : -1;
      return 0;
    }

    function renderHead() {
      const indicatorFor = (index) => {
        if (index !== state.sortIndex) return "";
        return state.sortDir === "asc" ? "▲" : "▼";
      };

      inventoryHead.innerHTML = `
        <tr>
          ${state.labels
            .map(
              (label, index) => `
                <th
                  scope="col"
                  data-index="${index}"
                  tabindex="0"
                  aria-label="Sort by ${escapeHtml(label)}"
                >
                  <div class="inventory-th-inner">
                    <span>${escapeHtml(label)}</span>
                    <span class="inventory-sort-indicator">${indicatorFor(index)}</span>
                  </div>
                </th>
              `
            )
            .join("")}
        </tr>
      `;
    }

    function renderBody() {
      if (!state.rows.length) {
        inventoryBody.innerHTML = `
          <tr>
            <td class="inventory-empty" colspan="6">No inventory rows found.</td>
          </tr>
        `;
        return;
      }

      const sortedRows = [...state.rows].sort(compareRows);

      inventoryBody.innerHTML = sortedRows
        .map(
          (row) => `
            <tr>
              ${row
                .slice(0, 6)
                .map((cell, index) => `<td>${escapeHtml(displayCell(cell, index)) || "&nbsp;"}</td>`)
                .join("")}
            </tr>
          `
        )
        .join("");
    }

    function renderTable() {
      renderHead();
      renderBody();
    }

    async function loadInventory() {
      try {
        const tq = encodeURIComponent("select A,B,C,D,E,F,G");
        const url = `https://docs.google.com/spreadsheets/d/${sheetId}/gviz/tq?gid=${sheetGid}&tq=${tq}`;

        const response = await fetch(url);
        const text = await response.text();

        const prefix = "google.visualization.Query.setResponse(";
        const start = text.indexOf(prefix);
        const end = text.lastIndexOf(");");

        if (start === -1 || end === -1) {
          throw new Error("Unable to read sheet response.");
        }

        const payload = text.slice(start + prefix.length, end).trim();
        const parsed = Function(`"use strict"; return (${payload});`)();

        const cols = (parsed?.table?.cols || []).slice(0, 6);
        const rows = (parsed?.table?.rows || [])
          .map((row) => {
            const cells = Array.isArray(row?.c) ? row.c.slice(0, 7) : [];
            while (cells.length < 7) cells.push(null);
            return cells;
          })
          .filter(isDisplayableRow);

        state.labels = cols.map((col, i) => col?.label || `Column ${String.fromCharCode(65 + i)}`);
        state.rows = rows;

        renderTable();
      } catch (error) {
        console.error(error);
        inventoryBody.innerHTML = `
          <tr>
            <td class="inventory-empty" colspan="6">
              Unable to load inventory right now.
            </td>
          </tr>
        `;
      }
    }

    function handleSort(index) {
      if (Number.isNaN(index)) return;

      if (state.sortIndex === index) {
        state.sortDir = state.sortDir === "asc" ? "desc" : "asc";
      } else {
        state.sortIndex = index;
        state.sortDir = "asc";
      }

      renderTable();
    }

    inventoryHead?.addEventListener("click", (event) => {
      const th = event.target.closest("th[data-index]");
      if (!th) return;

      const index = Number(th.getAttribute("data-index"));
      handleSort(index);
    });

    inventoryHead?.addEventListener("keydown", (event) => {
      const th = event.target.closest("th[data-index]");
      if (!th) return;

      if (event.key !== "Enter" && event.key !== " ") return;
      event.preventDefault();

      const index = Number(th.getAttribute("data-index"));
      handleSort(index);
    });

    loadInventory();
  </script>
</SiteLayout>
