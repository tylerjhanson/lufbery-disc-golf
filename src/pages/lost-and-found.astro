---
const inventoryUrl =
  "https://docs.google.com/spreadsheets/d/1cqzS2KMiIjmDRGe3kG1kPlG8yqgegC2rsp7i0HcS420/edit?usp=sharing";

const udiscUrl = "https://udisc.com/leagues/lufbery-league";
const facebookUrl = "https://www.facebook.com/groups/1155484787825669";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="Lost & Found" showBrandBar={true}>
<style>

      :root {
        --bg: #f5f7fb;
        --card: #ffffff;
        --text: #111827;
        --muted: #6b7280;
        --line-soft: #eef2f7;
        --accent: #2563eb;
        --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
        --radius: 22px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 24px;
        font-family: Inter, Arial, Helvetica, sans-serif;
        background: linear-gradient(180deg, #f8fafc 0%, var(--bg) 100%);
        color: var(--text);
      }

      .wrap {
        width: 100%;
        max-width: none;
        margin: 0;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--line-soft);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 28px 28px 24px;
      }

      h1 {
        margin: 0 0 18px;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1.05;
        letter-spacing: -0.03em;
      }

      p {
        margin: 0 0 18px;
        font-size: 1rem;
        line-height: 1.6;
      }

      .button {
        display: inline-block;
        margin-bottom: 24px;
        padding: 13px 18px;
        border-radius: 12px;
        background: var(--accent);
        color: #fff;
        text-decoration: none;
        font-weight: 700;
      }

      .button:hover {
        text-decoration: none;
        filter: brightness(0.96);
      }

      .link {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
      }

      .link:hover {
        text-decoration: underline;
      }

      .bullet-list {
        margin: 0 0 18px 0;
        padding-left: 20px;
      }

      .bullet-list li {
        margin-bottom: 8px;
        line-height: 1.5;
      }

      .footer-link {
        margin-top: 22px;
      }

      .footer-link a {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
      }

      .footer-link a:hover {
        text-decoration: underline;
      }

      @media (max-width: 700px) {
        body {
          padding: 10px;
        }

        .card {
          padding: 20px 18px 18px;
        }

        p,
        .bullet-list li {
          font-size: 0.96rem;
        }
      }
    
</style>

<div class="wrap">
      <div class="card">
        <h1>Lost &amp; Found</h1>

        <p>
          <a class="button" href={inventoryUrl} target="_blank" rel="noopener">
            Current Lost and Found Inventory
          </a>
        </p>

        <p>
          Lost discs are available for pick up before and after our weekly league rounds.
          Please check
          <a class="link" href={udiscUrl} target="_blank" rel="noopener">UDisc</a>
          for dates and times:
        </p>

        <ul class="bullet-list">
          <li>Sundays, 9 a.m., year round</li>
          <li>Thursday evenings April-September</li>
        </ul>

        <p>Discs not picked up within 60 days will be donated.</p>

        <p>
          <a class="link" href={facebookUrl} target="_blank" rel="noopener">
            Lufbery Park Disc Golf Leagues on Facebook
          </a>
        </p>

        <div class="footer-link">
          <a href="/">← Back to Home</a>
        </div>
      </div>
    </div>
</SiteLayout>
