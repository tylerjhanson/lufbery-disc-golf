---
const sheetId = "1FlsTEEik9UUMZQmjTOVkP7dOqGho9_GRFDC5PIVgXPo";
const sheetGid = "0";

const udiscUrl = "https://udisc.com/leagues/lufbery-league";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="Lost & Found" showBrandBar={true}>
  <style is:global>
    :root {
      --bg: #f5f7fb;
      --card: #ffffff;
      --text: #111827;
      --muted: #6b7280;
      --line: #e5e7eb;
      --line-soft: #eef2f7;
      --header: #f8fafc;
      --hover: #f9fbff;
      --accent: #2563eb;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      --radius: 22px;
    }

    .lost-found-page * {
      box-sizing: border-box;
    }

    .lost-found-page {
      width: 100%;
      max-width: none;
      margin: 0;
    }

    .lost-found-page .lf-card {
      background: var(--card) !important;
      border: 1px solid var(--line-soft) !important;
      border-radius: 10px !important;
      box-shadow: var(--shadow) !important;
      overflow: hidden;
      padding: 28px 28px 22px;
    }

    .lost-found-page h1 {
      margin: 0 0 18px;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--text);
    }

    .lost-found-page p {
      margin: 0 0 18px;
      font-size: 1rem;
      line-height: 1.6;
      color: var(--text);
    }

    .lost-found-page .link {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
    }

    .lost-found-page .link:hover {
      text-decoration: underline;
    }

    .lost-found-page .bullet-list {
      margin: 0 0 18px 0;
      padding-left: 20px;
    }

    .lost-found-page .bullet-list li {
      margin-bottom: 8px;
      line-height: 1.5;
      color: var(--text);
    }

    .lost-found-page .inventory-section {
      padding: 0;
      margin: 0;
    }

    .lost-found-page .inventory-heading {
      margin: 4px 0 10px;
      padding-left: 0;
      font-size: 0.96rem;
      color: var(--text);
      font-weight: 700;
      line-height: 1.2;
    }

    .lost-found-page .inventory-controls {
      margin: 0 0 12px;
      padding: 0;
    }

    .lost-found-page .inventory-search-wrap {
      position: relative;
      width: min(360px, 100%);
    }

    .lost-found-page .inventory-search {
      width: 100%;
      max-width: 360px;
      height: 40px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #fff;
      color: var(--text);
      font-size: 0.95rem;
      padding: 0 42px 0 12px;
      outline: none;
      box-shadow: none;
      transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }

    .lost-found-page .inventory-search::placeholder {
      color: var(--muted);
    }

    .lost-found-page .inventory-search:focus {
      border-color: rgba(37, 99, 235, 0.5);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
    }

    .lost-found-page .inventory-search-clear {
      position: absolute;
      top: 50%;
      right: 9px;
      transform: translateY(-50%);
      width: 26px;
      height: 26px;
      border: 1px solid var(--line-soft);
      border-radius: 999px;
      background: #fff;
      color: #94a3b8;
      font-size: 0.95rem;
      line-height: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s ease, color 0.15s ease, background 0.15s ease;
    }

    .lost-found-page .inventory-search-wrap.has-value .inventory-search-clear {
      opacity: 1;
      pointer-events: auto;
    }

    .lost-found-page .inventory-search-clear:hover {
      color: var(--text);
      background: #f8fafc;
    }

    .lost-found-page .table-wrap {
      padding: 0;
      margin: 0;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .lost-found-page table.inventory-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: fixed;
      min-width: 520px;
      background: transparent;
      margin: 0;
    }

    .lost-found-page table.inventory-table col.col-deadline {
      width: 18%;
    }

    .lost-found-page table.inventory-table col.col-name {
      width: 19%;
    }

    .lost-found-page table.inventory-table col.col-brand {
      width: 29%;
    }

    .lost-found-page table.inventory-table col.col-color {
      width: 12%;
    }

    .lost-found-page table.inventory-table col.col-last4 {
      width: 12%;
    }

    .lost-found-page table.inventory-table thead th {
      background: var(--header);
      color: var(--muted);
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      padding: 8px 5px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      white-space: normal;
      line-height: 1.1;
      user-select: none;
      cursor: pointer;
    }

    .lost-found-page table.inventory-table thead th:first-child {
      border-top-left-radius: 14px;
      padding-left: 0;
    }

    .lost-found-page table.inventory-table thead th:last-child {
      border-top-right-radius: 14px;
    }

    .lost-found-page table.inventory-table tbody td {
      padding: 8px 5px;
      border-bottom: 1px solid var(--line-soft);
      font-size: 0.84rem;
      text-align: left;
      vertical-align: middle;
      line-height: 1.1;
      white-space: normal;
      overflow-wrap: anywhere;
      word-break: break-word;
      background: transparent;
    }

    .lost-found-page table.inventory-table tbody td:first-child {
      padding-left: 0;
      white-space: nowrap;
    }

    .lost-found-page table.inventory-table tbody td:nth-child(4),
    .lost-found-page table.inventory-table tbody td:nth-child(5) {
      white-space: nowrap;
    }

    .lost-found-page table.inventory-table tbody tr:nth-child(even) td {
      background: #fcfdff !important;
    }

    .lost-found-page table.inventory-table tbody tr:nth-child(odd) td {
      background: transparent !important;
    }

    .lost-found-page table.inventory-table tbody tr:hover td {
      background: var(--hover) !important;
    }

    .lost-found-page .inventory-th-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 4px;
      width: 100%;
    }

    .lost-found-page .inventory-sort-indicator {
      color: var(--muted);
      font-size: 0.66rem;
      line-height: 1;
      min-width: 0.8em;
      text-align: right;
      flex: 0 0 auto;
    }

    .lost-found-page .inventory-empty {
      color: var(--muted);
      text-align: center;
      padding: 18px 12px;
    }

    @media (max-width: 700px) {
      .lost-found-page .lf-card {
        padding: 20px 14px 16px;
      }

      .lost-found-page p,
      .lost-found-page .bullet-list li {
        font-size: 0.96rem;
      }

      .lost-found-page .inventory-heading {
        margin: 4px 0 8px;
        padding-left: 0;
        font-size: 0.96rem;
      }

      .lost-found-page .inventory-controls {
        margin: 0 0 10px;
      }

      .lost-found-page .inventory-search-wrap {
        width: 100%;
      }

      .lost-found-page .inventory-search {
        max-width: none;
        height: 38px;
        font-size: 0.92rem;
        padding: 0 40px 0 10px;
      }

      .lost-found-page .table-wrap {
        padding: 0;
        margin: 0;
      }

      .lost-found-page table.inventory-table {
        min-width: 500px;
      }

      .lost-found-page table.inventory-table thead th {
        font-size: 0.58rem !important;
        padding: 6px 2px !important;
        letter-spacing: 0 !important;
        line-height: 1.05 !important;
      }

      .lost-found-page table.inventory-table thead th:first-child {
        padding-left: 0 !important;
      }

      .lost-found-page table.inventory-table tbody td {
        font-size: 0.76rem !important;
        padding: 6px 2px !important;
        line-height: 1.06 !important;
      }

      .lost-found-page table.inventory-table tbody td:first-child {
        padding-left: 0 !important;
      }

      .lost-found-page .inventory-sort-indicator {
        font-size: 0.56rem !important;
      }
    }

    @media (max-width: 420px) {
      .lost-found-page h1 {
        font-size: 1.9rem;
      }

      .lost-found-page .lf-card {
        padding: 18px 10px 14px;
      }

      .lost-found-page .inventory-search {
        height: 36px;
        font-size: 0.9rem;
      }

      .lost-found-page table.inventory-table {
        min-width: 480px;
      }

      .lost-found-page table.inventory-table thead th {
        font-size: 0.54rem !important;
        padding: 5px 2px !important;
      }

      .lost-found-page table.inventory-table thead th:first-child {
        padding-left: 0 !important;
      }

      .lost-found-page table.inventory-table tbody td {
        font-size: 0.72rem !important;
        padding: 5px 2px !important;
      }

      .lost-found-page table.inventory-table tbody td:first-child {
        padding-left: 0 !important;
      }

      .lost-found-page .inventory-sort-indicator {
        font-size: 0.52rem !important;
      }
    }

    html[data-theme="dark"] .lost-found-page .lf-card {
      background: var(--card) !important;
      border-color: var(--line-soft) !important;
    }

    html[data-theme="dark"] .lost-found-page .inventory-heading {
      color: var(--text) !important;
    }

    html[data-theme="dark"] .lost-found-page .inventory-search {
      background: #111827 !important;
      color: var(--text) !important;
      border-color: var(--line) !important;
    }

    html[data-theme="dark"] .lost-found-page .inventory-search::placeholder {
      color: var(--muted) !important;
    }

    html[data-theme="dark"] .lost-found-page .inventory-search-clear {
      background: #0f172a !important;
      border-color: var(--line) !important;
      color: #94a3b8 !important;
    }

    html[data-theme="dark"] .lost-found-page .inventory-search-clear:hover {
      background: #1e293b !important;
      color: var(--text) !important;
    }

    html[data-theme="dark"] .lost-found-page table.inventory-table thead th {
      background: #162033 !important;
      color: var(--muted) !important;
      border-bottom-color: var(--line) !important;
    }

    html[data-theme="dark"] .lost-found-page table.inventory-table tbody td {
      color: var(--text) !important;
      border-bottom-color: var(--line-soft) !important;
      background: transparent !important;
    }

    html[data-theme="dark"] .lost-found-page table.inventory-table tbody tr:nth-child(odd) td {
      background: transparent !important;
    }

    html[data-theme="dark"] .lost-found-page table.inventory-table tbody tr:nth-child(even) td {
      background: rgba(255, 255, 255, 0.03) !important;
    }

    html[data-theme="dark"] .lost-found-page table.inventory-table tbody tr:hover td {
      background: rgba(255, 255, 255, 0.06) !important;
    }

    @media (prefers-color-scheme: dark) {
      html[data-theme="system"] .lost-found-page .lf-card {
        background: var(--card) !important;
        border-color: var(--line-soft) !important;
      }

      html[data-theme="system"] .lost-found-page .inventory-heading {
        color: var(--text) !important;
      }

      html[data-theme="system"] .lost-found-page .inventory-search {
        background: #111827 !important;
        color: var(--text) !important;
        border-color: var(--line) !important;
      }

      html[data-theme="system"] .lost-found-page .inventory-search::placeholder {
        color: var(--muted) !important;
      }

      html[data-theme="system"] .lost-found-page .inventory-search-clear {
        background: #0f172a !important;
        border-color: var(--line) !important;
        color: #94a3b8 !important;
      }

      html[data-theme="system"] .lost-found-page .inventory-search-clear:hover {
        background: #1e293b !important;
        color: var(--text) !important;
      }

      html[data-theme="system"] .lost-found-page table.inventory-table thead th {
        background: #162033 !important;
        color: var(--muted) !important;
        border-bottom-color: var(--line) !important;
      }

      html[data-theme="system"] .lost-found-page table.inventory-table tbody td {
        color: var(--text) !important;
        border-bottom-color: var(--line-soft) !important;
        background: transparent !important;
      }

      html[data-theme="system"] .lost-found-page table.inventory-table tbody tr:nth-child(odd) td {
        background: transparent !important;
      }

      html[data-theme="system"] .lost-found-page table.inventory-table tbody tr:nth-child(even) td {
        background: rgba(255, 255, 255, 0.03) !important;
      }

      html[data-theme="system"] .lost-found-page table.inventory-table tbody tr:hover td {
        background: rgba(255, 255, 255, 0.06) !important;
      }
    }
  </style>

  <div class="wrap lost-found-page">
    <div class="lf-card">
      <h1>Lost &amp; Found</h1>

      <p>
        Lost discs are available for pick up before and after our weekly league rounds.
        Please check
        <a class="link" href={udiscUrl} target="_blank" rel="noopener">UDisc</a>
        for dates and times:
      </p>

      <ul class="bullet-list">
        <li>Sundays, 9 a.m., year round</li>
        <li>Thursday evenings April-September</li>
      </ul>

      <p>Discs not picked up within 60 days will be donated.</p>

      <div class="inventory-section">
        <div class="inventory-controls">
          <div id="inventorySearchWrap" class="inventory-search-wrap">
            <input
              id="inventorySearch"
              class="inventory-search"
              type="text"
              placeholder="Search inventory..."
              autocomplete="off"
              spellcheck="false"
              aria-label="Search inventory"
            />
            <button
              id="inventoryClearSearch"
              class="inventory-search-clear"
              type="button"
              aria-label="Clear search"
              title="Clear search"
            >
              ×
            </button>
          </div>
        </div>

        <div class="table-wrap">
          <table class="inventory-table" id="inventoryTable">
            <colgroup>
              <col class="col-deadline" />
              <col class="col-name" />
              <col class="col-brand" />
              <col class="col-color" />
              <col class="col-last4" />
            </colgroup>
            <thead id="inventoryHead"></thead>
            <tbody id="inventoryBody">
              <tr>
                <td class="inventory-empty" colspan="5">Loading inventory…</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ sheetId, sheetGid }}>
    const inventoryHead = document.getElementById("inventoryHead");
    const inventoryBody = document.getElementById("inventoryBody");
    const inventorySearch = document.getElementById("inventorySearch");
    const inventorySearchWrap = document.getElementById("inventorySearchWrap");
    const inventoryClearSearch = document.getElementById("inventoryClearSearch");

    const RETURNED_INDEX = 6;
    const VISIBLE_SOURCE_INDICES = [5, 1, 2, 3, 4];

    const state = {
      labels: [],
      rows: [],
      sortIndex: 0,
      sortDir: "asc",
      searchQuery: "",
    };

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function formatDateValue(date) {
      const month = date.getMonth() + 1;
      const day = date.getDate();
      const year = String(date.getFullYear()).slice(-2);
      return `${month}/${day}/${year}`;
    }

    function tryParseDate(value) {
      if (!value) return null;
      if (value instanceof Date && !Number.isNaN(value.getTime())) return value;

      const text = String(value).trim();
      if (!text) return null;

      const direct = new Date(text);
      if (!Number.isNaN(direct.getTime()) && /[\/\-]/.test(text)) return direct;

      const mmddyyyy = text.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/);
      if (mmddyyyy) {
        let [, m, d, y] = mmddyyyy;
        let year = Number(y);
        if (year < 100) year += 2000;
        const parsed = new Date(year, Number(m) - 1, Number(d));
        if (!Number.isNaN(parsed.getTime())) return parsed;
      }

      return null;
    }

    function getVisibleCells(row) {
      return VISIBLE_SOURCE_INDICES.map((sourceIndex) => row[sourceIndex] ?? null);
    }

    function displayCell(cell, visibleColIndex = -1) {
      if (!cell) return "";

      const isDateColumn = visibleColIndex === 0;

      if (isDateColumn) {
        if (cell.v instanceof Date) return formatDateValue(cell.v);

        const formatted =
          cell.f !== null && cell.f !== undefined && cell.f !== ""
            ? String(cell.f).trim()
            : String(cell.v ?? "").trim();

        const parsed = tryParseDate(formatted);
        return parsed ? formatDateValue(parsed) : formatted;
      }

      if (cell.f !== null && cell.f !== undefined && cell.f !== "") return String(cell.f);
      if (cell.v === null || cell.v === undefined) return "";
      return String(cell.v);
    }

    function isReturnedTrue(cell) {
      if (!cell) return false;

      const raw = cell.v;
      if (raw === true) return true;

      const text = String(raw ?? "").trim().toLowerCase();
      return text === "true";
    }

    function isBlankDisplayValue(value) {
      return String(value ?? "").trim() === "";
    }

    function isDisplayableRow(row) {
      const visibleCells = getVisibleCells(row);
      const returnedCell = row[RETURNED_INDEX];

      const allBlank = visibleCells.every((cell, index) =>
        isBlankDisplayValue(displayCell(cell, index))
      );

      if (allBlank) return false;
      if (isReturnedTrue(returnedCell)) return false;

      return true;
    }

    function getCellSortValue(cell, visibleColIndex) {
      if (!cell) return { type: "empty", value: "" };

      const raw = cell.v;
      const text = displayCell(cell, visibleColIndex).trim();

      if (visibleColIndex === 0) {
        const parsedDate = tryParseDate(raw) || tryParseDate(text);
        if (parsedDate) return { type: "number", value: parsedDate.getTime() };
        return { type: "text", value: text.toLowerCase() };
      }

      if (visibleColIndex === 4) {
        const digits = text.replace(/\s+/g, "");
        if (/^\d{1,4}$/.test(digits)) {
          return { type: "number", value: Number(digits) };
        }
        return { type: "text", value: text.toLowerCase() };
      }

      if (typeof raw === "number") return { type: "number", value: raw };
      if (typeof raw === "boolean") return { type: "number", value: raw ? 1 : 0 };

      const stripped = text.replaceAll(",", "").replaceAll("$", "").replaceAll("%", "");
      const numeric = Number(stripped);
      if (text !== "" && !Number.isNaN(numeric) && /^-?\d+(\.\d+)?$/.test(stripped)) {
        return { type: "number", value: numeric };
      }

      return { type: "text", value: text.toLowerCase() };
    }

    function compareRows(a, b) {
      const leftCell = getVisibleCells(a)[state.sortIndex];
      const rightCell = getVisibleCells(b)[state.sortIndex];

      const left = getCellSortValue(leftCell, state.sortIndex);
      const right = getCellSortValue(rightCell, state.sortIndex);

      if (left.type !== right.type) {
        if (left.type === "number" && right.type !== "number") {
          return state.sortDir === "asc" ? -1 : 1;
        }
        if (left.type !== "number" && right.type === "number") {
          return state.sortDir === "asc" ? 1 : -1;
        }
      }

      if (left.value < right.value) return state.sortDir === "asc" ? -1 : 1;
      if (left.value > right.value) return state.sortDir === "asc" ? 1 : -1;
      return 0;
    }

    function rowMatchesSearch(row) {
      const query = state.searchQuery.trim().toLowerCase();
      if (!query) return true;

      return getVisibleCells(row).some((cell, index) =>
        displayCell(cell, index).toLowerCase().includes(query)
      );
    }

    function updateSearchClear() {
      if (!inventorySearchWrap || !inventorySearch) return;
      inventorySearchWrap.classList.toggle("has-value", !!inventorySearch.value.trim());
    }

    function renderHead() {
      const indicatorFor = (index) => {
        if (index !== state.sortIndex) return "";
        return state.sortDir === "asc" ? "▲" : "▼";
      };

      inventoryHead.innerHTML = `
        <tr>
          ${state.labels
            .map(
              (label, index) => `
                <th
                  scope="col"
                  data-index="${index}"
                  tabindex="0"
                  aria-label="Sort by ${escapeHtml(label)}"
                >
                  <div class="inventory-th-inner">
                    <span>${escapeHtml(label)}</span>
                    <span class="inventory-sort-indicator">${indicatorFor(index)}</span>
                  </div>
                </th>
              `
            )
            .join("")}
        </tr>
      `;
    }

    function renderBody() {
      if (!state.rows.length) {
        inventoryBody.innerHTML = `
          <tr>
            <td class="inventory-empty" colspan="5">No inventory rows found.</td>
          </tr>
        `;
        return;
      }

      const filteredRows = state.rows.filter(rowMatchesSearch);

      if (!filteredRows.length) {
        inventoryBody.innerHTML = `
          <tr>
            <td class="inventory-empty" colspan="5">No matching inventory items found.</td>
          </tr>
        `;
        return;
      }

      const sortedRows = [...filteredRows].sort(compareRows);

      inventoryBody.innerHTML = sortedRows
        .map((row) => {
          const visibleCells = getVisibleCells(row);
          return `
            <tr>
              ${visibleCells
                .map((cell, index) => `<td>${escapeHtml(displayCell(cell, index)) || "&nbsp;"}</td>`)
                .join("")}
            </tr>
          `;
        })
        .join("");
    }

    function renderTable() {
      renderHead();
      renderBody();
    }

    async function loadInventory() {
      try {
        const tq = encodeURIComponent("select A,B,C,D,E,F,G");
        const url = `https://docs.google.com/spreadsheets/d/${sheetId}/gviz/tq?gid=${sheetGid}&tq=${tq}`;

        const response = await fetch(url);
        const text = await response.text();

        const prefix = "google.visualization.Query.setResponse(";
        const start = text.indexOf(prefix);
        const end = text.lastIndexOf(");");

        if (start === -1 || end === -1) {
          throw new Error("Unable to read sheet response.");
        }

        const payload = text.slice(start + prefix.length, end).trim();
        const parsed = Function(`"use strict"; return (${payload});`)();

        const cols = parsed?.table?.cols || [];
        const rows = (parsed?.table?.rows || [])
          .map((row) => {
            const cells = Array.isArray(row?.c) ? row.c.slice(0, 7) : [];
            while (cells.length < 7) cells.push(null);
            return cells;
          })
          .filter(isDisplayableRow);

        state.labels = VISIBLE_SOURCE_INDICES.map((sourceIndex, i) => {
          const col = cols[sourceIndex];
          return col?.label || `Column ${i + 1}`;
        });

        state.rows = rows;

        renderTable();
      } catch (error) {
        console.error(error);
        inventoryBody.innerHTML = `
          <tr>
            <td class="inventory-empty" colspan="5">
              Unable to load inventory right now.
            </td>
          </tr>
        `;
      }
    }

    function handleSort(index) {
      if (Number.isNaN(index)) return;

      if (state.sortIndex === index) {
        state.sortDir = state.sortDir === "asc" ? "desc" : "asc";
      } else {
        state.sortIndex = index;
        state.sortDir = "asc";
      }

      renderTable();
    }

    inventoryHead?.addEventListener("click", (event) => {
      const th = event.target.closest("th[data-index]");
      if (!th) return;

      const index = Number(th.getAttribute("data-index"));
      handleSort(index);
    });

    inventoryHead?.addEventListener("keydown", (event) => {
      const th = event.target.closest("th[data-index]");
      if (!th) return;

      if (event.key !== "Enter" && event.key !== " ") return;
      event.preventDefault();

      const index = Number(th.getAttribute("data-index"));
      handleSort(index);
    });

    inventorySearch?.addEventListener("input", (event) => {
      state.searchQuery = event.target.value || "";
      renderBody();
      updateSearchClear();
    });

    inventoryClearSearch?.addEventListener("click", () => {
      if (!inventorySearch) return;
      inventorySearch.value = "";
      state.searchQuery = "";
      renderBody();
      updateSearchClear();
      inventorySearch.focus();
    });

    loadInventory();
    updateSearchClear();
  </script>
</SiteLayout>
