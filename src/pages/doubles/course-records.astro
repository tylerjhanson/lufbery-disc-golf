---
import { getDoublesRecords, getPlayerProfiles } from "../../lib/data";
import PlayerModal from "../../components/PlayerModal.astro";

const sections = getDoublesRecords();
const playerProfiles = getPlayerProfiles();
import SiteLayout from "../../layouts/SiteLayout.astro";

function cleanName(value: string) {
  return String(value || "").replace(/\s+/g, " ").trim();
}

function getPlayerKey(value: string) {
  return cleanName(value).toLowerCase();
}

function cleanTeamModalName(value: string) {
  return cleanName(value).replace(/\s*\((?:modified\s+)?cali\)\s*$/i, "").trim();
}

function splitTeamPlayers(value: string) {
  return String(value || "")
    .split(/\s*\/\s*/)
    .map((part) => {
      const label = cleanName(part);
      const modalName = cleanTeamModalName(part);

      return label && modalName
        ? { label, modalName, key: getPlayerKey(modalName) }
        : null;
    })
    .filter(
      (
        value
      ): value is {
        label: string;
        modalName: string;
        key: string;
      } => Boolean(value)
    );
}

function isUdiscUrl(value: string) {
  return /(^https?:\/\/)?(www\.)?udisc\.com\b/i.test(String(value || "").trim());
}
---

<SiteLayout title="Doubles Records" showBrandBar={true}>
<style>

      :root {
        --bg: #f5f7fb;
        --card: #ffffff;
        --text: #111827;
        --muted: #6b7280;
        --line: #e5e7eb;
        --line-soft: #eef2f7;
        --header: #f8fafc;
        --hover: #f9fbff;
        --accent: #2563eb;
        --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
        --radius: 22px;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 24px;
        font-family: Inter, Arial, Helvetica, sans-serif;
        background: linear-gradient(180deg, #f8fafc 0%, var(--bg) 100%);
        color: var(--text);
      }

      .wrap {
        width: 100%;
        max-width: none;
        margin: 0;
      }

      .page-header {
        margin-bottom: 18px;
      }

      h1 {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1.05;
        letter-spacing: -0.03em;
      }

      .sections {
        display: grid;
        gap: 18px;
      }

      .card {
        background: var(--card);
        border: 1px solid var(--line-soft);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .card-header {
        padding: 22px 24px 12px;
      }

      .card-title {
        margin: 0;
        font-size: 1.15rem;
        line-height: 1.25;
      }

      .table-wrap {
        padding: 0 16px 10px;
      }

      table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        table-layout: fixed;
      }

      col.name-col { width: 48%; }
      col.score-col { width: 20%; }
      col.date-col { width: 32%; }

      thead th {
        background: var(--header);
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 13px 14px;
        border-bottom: 1px solid var(--line);
        text-align: center;
        user-select: none;
      }

      thead th.sortable {
        cursor: pointer;
        transition: background 0.15s ease, color 0.15s ease;
      }

      thead th.sortable:hover {
        background: #f1f5f9;
        color: var(--text);
      }

      thead th:first-child {
        text-align: left;
        border-top-left-radius: 14px;
      }

      thead th:last-child {
        border-top-right-radius: 14px;
      }

      .th-inner {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
      }

      thead th:first-child .th-inner {
        justify-content: flex-start;
      }

      .sort-indicator {
        display: inline-block;
        width: 12px;
        color: #94a3b8;
        font-size: 0.8rem;
        flex: 0 0 12px;
      }

      tbody td {
        padding: 14px 14px;
        border-bottom: 1px solid var(--line-soft);
        font-size: 0.98rem;
        text-align: center;
        vertical-align: middle;
      }

      tbody tr:nth-child(even) td {
        background: #fcfdff;
      }

      tbody tr:hover td {
        background: var(--hover);
      }

      tbody td:first-child {
        text-align: left;
        font-weight: 600;
        overflow-wrap: anywhere;
        word-break: break-word;
        line-height: 1.3;
      }

      .date-link {
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
      }

      .date-link:hover {
        text-decoration: underline;
      }

      .date-link-inline {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }

      .udisc-icon {
        height: 0.82em;
        width: auto;
        display: inline-block;
        vertical-align: middle;
        flex: 0 0 auto;
        opacity: 0.98;
        transform: translateY(-0.11em);
      }

      .udisc-icon--dark {
        display: none;
      }

      :global(html.dark) .udisc-icon--light,
      :global(html[data-theme="dark"]) .udisc-icon--light,
      :global(body.dark) .udisc-icon--light,
      :global(body[data-theme="dark"]) .udisc-icon--light {
        display: none;
      }

      :global(html.dark) .udisc-icon--dark,
      :global(html[data-theme="dark"]) .udisc-icon--dark,
      :global(body.dark) .udisc-icon--dark,
      :global(body[data-theme="dark"]) .udisc-icon--dark {
        display: inline-block;
      }

      @media (prefers-color-scheme: dark) {
        .udisc-icon--light {
          display: none;
        }

        .udisc-icon--dark {
          display: inline-block;
        }
      }

      @media (max-width: 700px) {
        body {
          padding: 10px;
        }

        .card-header {
          padding: 18px 16px 10px;
        }

        .card-title {
          font-size: 1.02rem;
        }

        .table-wrap {
          padding: 0 8px 8px;
        }

        col.name-col { width: 42%; }
        col.score-col { width: 22%; }
        col.date-col { width: 36%; }

        thead th {
          font-size: 0.7rem;
          letter-spacing: 0.02em;
          padding: 10px 6px;
        }

        tbody td {
          font-size: 0.88rem;
          padding: 10px 6px;
        }
      }

      @media (max-width: 420px) {
        thead th {
          font-size: 0.66rem;
          padding: 9px 4px;
        }

        tbody td {
          font-size: 0.84rem;
          padding: 9px 4px;
        }
      }

</style>

<div class="wrap">
      <div class="page-header">
        <h1>Doubles Records</h1>
      </div>

      <div class="sections">
        {sections.map((section) => (
          <section class="card">
            <div class="card-header">
              <h2 class="card-title">{section.title}</h2>
            </div>

            <div class="table-wrap">
              <table class="sortable-table" data-default-column="1" data-default-direction="asc">
                <colgroup>
                  <col class="name-col" />
                  <col class="score-col" />
                  <col class="date-col" />
                </colgroup>

                <thead>
                  <tr>
                    <th class="sortable" data-column="0" data-type="text">
                      <span class="th-inner">Name <span class="sort-indicator"></span></span>
                    </th>
                    <th class="sortable" data-column="1" data-type="score">
                      <span class="th-inner">Score <span class="sort-indicator"></span></span>
                    </th>
                    <th class="sortable" data-column="2" data-type="date">
                      <span class="th-inner">Date <span class="sort-indicator"></span></span>
                    </th>
                  </tr>
                </thead>

                <tbody>
                  {section.rows.map((row) => (
                    <tr>
                      <td>
                        <div class="player-link-stack">
                          {splitTeamPlayers(row.name).map((player) => (
                            <button
                              type="button"
                              class="player-button"
                              data-player-key={player.key}
                              data-player-name={player.modalName}
                              aria-label={`View player details for ${player.modalName}`}
                            >
                              {player.label}
                            </button>
                          ))}
                        </div>
                      </td>
                      <td>{row.score}</td>
                      <td>
                        {row.url ? (
                          <a
                            class={`date-link${isUdiscUrl(row.url) ? " date-link-inline" : ""}`}
                            href={row.url}
                            target="_blank"
                            rel="noopener"
                          >
                            <span>{row.date}</span>
                            {isUdiscUrl(row.url) && (
                              <>
                                <img
                                  class="udisc-icon udisc-icon--light"
                                  src="https://lufberydiscgolf.com/udisc-icon.png"
                                  alt="UDisc"
                                  loading="lazy"
                                  decoding="async"
                                />
                                <img
                                  class="udisc-icon udisc-icon--dark"
                                  src="https://lufberydiscgolf.com/udisc-icon-white.png"
                                  alt="UDisc"
                                  loading="lazy"
                                  decoding="async"
                                />
                              </>
                            )}
                          </a>
                        ) : (
                          row.date
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        ))}
      </div>

    </div>

    <script>
      const tables = document.querySelectorAll(".sortable-table");

      function getCellValue(row, columnIndex) {
        return row.children[columnIndex]?.textContent?.trim() ?? "";
      }

      function parseUsDate(value) {
        const parts = value.split("/");
        if (parts.length !== 3) return new Date(0).getTime();

        let month = Number(parts[0]);
        let day = Number(parts[1]);
        let year = Number(parts[2]);

        if (year < 100) year += 2000;

        return new Date(year, month - 1, day).getTime();
      }

      function parseScore(value) {
        const match = value.match(/-?\d+(\.\d+)?/);
        if (!match) return 9999;
        return Number(match[0]);
      }

      function compareValues(a, b, type, direction) {
        const emptyA = a === "";
        const emptyB = b === "";

        if (emptyA && emptyB) return 0;
        if (emptyA) return 1;
        if (emptyB) return -1;

        let result = 0;

        if (type === "date") {
          result = parseUsDate(a) - parseUsDate(b);
        } else if (type === "score") {
          result = parseScore(a) - parseScore(b);
        } else {
          result = a.localeCompare(b, undefined, { sensitivity: "base", numeric: true });
        }

        return direction === "asc" ? result : -result;
      }

      tables.forEach((table) => {
        const tbody = table.querySelector("tbody");
        const headers = table.querySelectorAll("thead th.sortable");

        let currentColumn = Number(table.dataset.defaultColumn || 1);
        let currentDirection = table.dataset.defaultDirection || "asc";

        function updateIndicators(activeColumn, direction) {
          headers.forEach((header) => {
            const indicator = header.querySelector(".sort-indicator");
            const col = Number(header.dataset.column);

            if (!indicator) return;

            if (col === activeColumn) {
              indicator.textContent = direction === "asc" ? "▲" : "▼";
              indicator.style.color = "#2563eb";
            } else {
              indicator.textContent = "";
              indicator.style.color = "#94a3b8";
            }
          });
        }

        function sortTable(columnIndex, type, direction) {
          const sortedRows = Array.from(tbody.querySelectorAll("tr")).sort((rowA, rowB) => {
            const valueA = getCellValue(rowA, columnIndex);
            const valueB = getCellValue(rowB, columnIndex);
            return compareValues(valueA, valueB, type, direction);
          });

          tbody.append(...sortedRows);
          updateIndicators(columnIndex, direction);
        }

        headers.forEach((header) => {
          header.addEventListener("click", () => {
            const columnIndex = Number(header.dataset.column);
            const type = header.dataset.type || "text";

            if (currentColumn === columnIndex) {
              currentDirection = currentDirection === "asc" ? "desc" : "asc";
            } else {
              currentColumn = columnIndex;
              currentDirection = columnIndex === 1 ? "asc" : columnIndex === 2 ? "desc" : "asc";
            }

            sortTable(columnIndex, type, currentDirection);
          });
        });

        sortTable(currentColumn, "score", currentDirection);
      });
    </script>
  <PlayerModal profiles={playerProfiles} />
</SiteLayout>
