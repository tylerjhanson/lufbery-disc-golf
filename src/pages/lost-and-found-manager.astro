---
import SiteLayout from "../layouts/SiteLayout.astro";

const apiUrl = "https://script.google.com/macros/s/AKfycbyOVn9a5mphmeROGJPmHDD4Rpz-SeRpT50Cbk5qbuxn3BBCi1iaiHHU2fUrPg5Ccr9c/exec";
const messageText =
  "Your disc was returned to the Lufbery lost and found. Please visit https://lufberydiscgolf.com/lost-and-found/ for our current lost disc inventory and pick-up instructions. Discs not picked up within 60 days will be donated.";
---

<SiteLayout title="Lost & Found Manager" showBrandBar={true} noindex={true}>
  <style is:global>
    .lost-found-manager-page * { box-sizing: border-box; }
    .lost-found-manager-page { width: 100%; max-width: none; margin: 0; overflow-x: hidden; }
    .lost-found-manager-page .lfm-stack,
    .lost-found-manager-page .lfm-card,
    .lost-found-manager-page .lfm-grid,
    .lost-found-manager-page .lfm-grid > *,
    .lost-found-manager-page .lfm-section-head,
    .lost-found-manager-page .lfm-table-wrap,
    .lost-found-manager-page .lfm-actions { min-width: 0; }

    .lost-found-manager-page .lfm-card {
      background: var(--card) !important;
      border: 1px solid var(--line-soft) !important;
      border-radius: 10px !important;
      box-shadow: var(--shadow) !important;
      overflow: hidden;
      padding: 22px 22px 18px;
    }

    .lost-found-manager-page .lfm-stack { display: grid; gap: 16px; }
    .lost-found-manager-page h1 {
      margin: 0 0 14px;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--text);
    }

    .lost-found-manager-page h2 {
      margin: 0;
      font-size: 0.98rem;
      line-height: 1.2;
      color: var(--text);
      font-weight: 700;
    }

    .lost-found-manager-page p {
      margin: 0;
      font-size: 1rem;
      line-height: 1.6;
      color: var(--text);
    }

    .lost-found-manager-page .lfm-muted {
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.45;
    }

    .lost-found-manager-page .lfm-login {
      max-width: 520px;
      margin: 0 auto;
    }

    .lost-found-manager-page .lfm-password-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 10px;
      margin-top: 12px;
    }

    .lost-found-manager-page .lfm-grid { display: grid; gap: 10px; }
    .lost-found-manager-page .lfm-grid-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }

    .lost-found-manager-page input,
    .lost-found-manager-page button { font: inherit; }

    .lost-found-manager-page input {
      width: 100%;
      min-width: 0;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #fff;
      color: var(--text);
      min-height: 40px;
      padding: 0 12px;
      outline: none;
      transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }

    .lost-found-manager-page input:focus {
      border-color: rgba(37, 99, 235, 0.5);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
    }

    .lost-found-manager-page .lfm-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .lost-found-manager-page .lfm-button,
    .lost-found-manager-page .lfm-link-button,
    .lost-found-manager-page .lfm-filter-button {
      transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
    }

    .lost-found-manager-page .lfm-button,
    .lost-found-manager-page .lfm-filter-button {
      min-height: 40px;
      padding: 0 14px;
      font-weight: 600;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--text);
      border-radius: 10px;
      cursor: pointer;
    }

    .lost-found-manager-page .lfm-button:hover,
    .lost-found-manager-page .lfm-filter-button:hover {
      background: #f8fafc;
      border-color: var(--line-soft);
    }

    .lost-found-manager-page .lfm-button:active,
    .lost-found-manager-page .lfm-filter-button:active { transform: translateY(1px); }

    .lost-found-manager-page .lfm-button-primary {
      background: #111827;
      color: #fff;
      border-color: #111827;
    }

    .lost-found-manager-page .lfm-button-primary:hover {
      background: #1f2937;
      border-color: #1f2937;
    }

    .lost-found-manager-page .lfm-button-danger {
      background: #fff5f5;
      border-color: #fecaca;
      color: #991b1b;
    }

    .lost-found-manager-page .lfm-button-danger:hover {
      background: #fee2e2;
      border-color: #fca5a5;
    }

    .lost-found-manager-page .lfm-button-restore {
      background: #f0fdf4;
      border-color: #bbf7d0;
      color: #166534;
    }

    .lost-found-manager-page .lfm-button-restore:hover {
      background: #dcfce7;
      border-color: #86efac;
    }

    .lost-found-manager-page .lfm-button-donated {
      background: #fff7ed;
      border-color: #fdba74;
      color: #9a3412;
    }

    .lost-found-manager-page .lfm-button-donated:hover {
      background: #ffedd5;
      border-color: #fb923c;
    }

    .lost-found-manager-page .lfm-button-sold {
      background: #f5f3ff;
      border-color: #c4b5fd;
      color: #5b21b6;
    }

    .lost-found-manager-page .lfm-button-sold:hover {
      background: #ede9fe;
      border-color: #a78bfa;
    }

    .lost-found-manager-page .lfm-button-light {
      background: #fff;
      color: var(--text);
      border-color: var(--line);
    }

    .lost-found-manager-page .lfm-link-button {
      border: 0;
      background: transparent;
      padding: 0;
      color: var(--accent);
      cursor: pointer;
      font-size: 0.95rem;
      font-weight: 600;
      text-decoration: none;
    }

    .lost-found-manager-page .lfm-link-button:hover { text-decoration: underline; }

    .lost-found-manager-page .lfm-filter-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .lost-found-manager-page .lfm-filter-button.is-active {
      background: #111827;
      color: #fff;
      border-color: #111827;
    }

    .lost-found-manager-page .lfm-status {
      min-height: 22px;
      font-size: 0.94rem;
      color: var(--muted);
      margin-top: 10px;
    }

    .lost-found-manager-page .lfm-status.is-error { color: #b91c1c; }
    .lost-found-manager-page .lfm-status.is-success { color: #166534; }

    .lost-found-manager-page .lfm-section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 8px;
    }

    .lost-found-manager-page .lfm-table-wrap {
      padding: 0;
      margin: 0;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .lost-found-manager-page .lfm-bulk-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin: 0 0 10px;
      padding: 10px 12px;
      border: 1px solid var(--line, #e5e7eb);
      border-radius: 14px;
      background: var(--header, #f8fafc);
    }

    .lost-found-manager-page .lfm-bulk-meta,
    .lost-found-manager-page .lfm-bulk-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .lost-found-manager-page .lfm-bulk-count {
      color: var(--muted);
      font-size: 0.84rem;
      white-space: nowrap;
    }

    .lost-found-manager-page .lfm-select-cell input {
      width: 16px;
      height: 16px;
      accent-color: var(--accent);
      cursor: pointer;
    }

    .lost-found-manager-page table.lfm-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: fixed;
      min-width: 0;
      background: transparent;
      margin: 0;
    }

    .lost-found-manager-page table.lfm-table col.col-select { width: 3.2rem; }
    .lost-found-manager-page table.lfm-table col.col-name { width: 7.5ch; }
    .lost-found-manager-page table.lfm-table col.col-disc { width: 8.5ch; }
    .lost-found-manager-page table.lfm-table col.col-color { width: 5.5ch; }
    .lost-found-manager-page table.lfm-table col.col-phone { width: 9ch; }
    .lost-found-manager-page table.lfm-table col.col-actions { width: 7ch; }

    .lost-found-manager-page table.lfm-table thead th {
      background: var(--header, #f8fafc);
      color: var(--muted);
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      padding: 8px 5px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      white-space: normal;
      line-height: 1.1;
    }

    .lost-found-manager-page .lfm-select-th,
    .lost-found-manager-page .lfm-select-cell {
      text-align: center !important;
      width: 3.2rem;
    }

    .lost-found-manager-page table.lfm-table thead th:first-child {
      border-top-left-radius: 14px;
      padding-left: 0;
    }

    .lost-found-manager-page table.lfm-table thead th:last-child {
      border-top-right-radius: 14px;
    }

    .lost-found-manager-page .lfm-th-button {
      width: 100%;
      border: 0;
      background: transparent;
      color: inherit;
      font: inherit;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 4px;
      cursor: pointer;
      text-transform: inherit;
      letter-spacing: inherit;
      line-height: inherit;
    }

    .lost-found-manager-page .lfm-th-button:hover { color: var(--text); }

    .lost-found-manager-page .lfm-sort-indicator {
      color: var(--muted);
      font-size: 0.66rem;
      line-height: 1;
      min-width: 0.8em;
      text-align: right;
      flex: 0 0 auto;
    }

    .lost-found-manager-page table.lfm-table tbody td {
      padding: 8px 5px;
      border-bottom: 1px solid var(--line-soft);
      font-size: 0.84rem;
      text-align: left;
      vertical-align: middle;
      line-height: 1.1;
      white-space: normal;
      overflow-wrap: anywhere;
      word-break: break-word;
      background: transparent;
    }

    .lost-found-manager-page table.lfm-table tbody td:first-child { padding-left: 0; }
    .lost-found-manager-page table.lfm-table tbody td:nth-child(2) { padding-left: 0; }
    .lost-found-manager-page table.lfm-table tbody tr:nth-child(even) td { background: #fcfdff !important; }
    .lost-found-manager-page table.lfm-table tbody tr:nth-child(odd) td { background: transparent !important; }
    .lost-found-manager-page table.lfm-table tbody tr:hover td { background: var(--hover, #f9fbff) !important; }

    .lost-found-manager-page .lfm-phone-link {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
    }

    .lost-found-manager-page .lfm-phone-link:hover { text-decoration: underline; }

    .lost-found-manager-page .lfm-row-actions {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 6px;
      flex-wrap: wrap;
    }

    .lost-found-manager-page .lfm-row-actions .lfm-button {
      min-height: 32px;
      padding: 0 10px;
      font-size: 0.8rem;
    }

    .lost-found-manager-page .lfm-empty {
      color: var(--muted);
      text-align: center;
      padding: 18px 12px;
    }

    .lost-found-manager-page [hidden] { display: none !important; }

    .lost-found-manager-page .lfm-modal-layer {
      position: fixed;
      inset: 0;
      z-index: 110;
      display: grid;
      place-items: center;
      padding: 16px;
    }

    .lost-found-manager-page .lfm-modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(15, 23, 42, 0.4);
    }

    .lost-found-manager-page .lfm-modal-card {
      position: relative;
      width: min(100%, 560px);
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-radius: 14px;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.18);
      padding: 18px 18px 16px;
    }

    .lost-found-manager-page .lfm-modal-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .lost-found-manager-page .lfm-modal-close {
      width: 36px;
      height: 36px;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--text);
      border-radius: 10px;
      cursor: pointer;
      font-size: 1.15rem;
      line-height: 1;
    }

    .lost-found-manager-page .lfm-modal-grid {
      display: grid;
      gap: 10px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .lost-found-manager-page .lfm-modal-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 14px;
    }

    .lost-found-manager-page .lfm-busy-overlay {
      position: fixed;
      inset: 0;
      z-index: 200;
      display: grid;
      place-items: center;
      background: rgba(15, 23, 42, 0.42);
      backdrop-filter: blur(2px);
      padding: 16px;
    }

    .lost-found-manager-page .lfm-busy-card {
      width: min(100%, 320px);
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-radius: 14px;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.18);
      padding: 18px 18px 16px;
      display: grid;
      gap: 12px;
      place-items: center;
      text-align: center;
    }

    .lost-found-manager-page .lfm-spinner {
      width: 28px;
      height: 28px;
      border-radius: 999px;
      border: 3px solid rgba(37, 99, 235, 0.2);
      border-top-color: var(--accent);
      animation: lfm-spin 0.9s linear infinite;
    }

    .lost-found-manager-page .lfm-busy-text {
      color: var(--text);
      font-size: 0.95rem;
      line-height: 1.4;
      font-weight: 600;
    }

    @keyframes lfm-spin { to { transform: rotate(360deg); } }

    html[data-theme="dark"] .lost-found-manager-page .lfm-card,
    html[data-theme="dark"] .lost-found-manager-page .lfm-modal-card,
    html[data-theme="dark"] .lost-found-manager-page .lfm-busy-card {
      background: var(--card) !important;
      border-color: var(--line-soft) !important;
    }

    html[data-theme="dark"] .lost-found-manager-page input,
    html[data-theme="dark"] .lost-found-manager-page .lfm-button,
    html[data-theme="dark"] .lost-found-manager-page .lfm-filter-button,
    html[data-theme="dark"] .lost-found-manager-page .lfm-modal-close {
      background: #0f172a !important;
      color: var(--text) !important;
      border-color: var(--line) !important;
    }

    html[data-theme="dark"] .lost-found-manager-page .lfm-button-primary,
    html[data-theme="dark"] .lost-found-manager-page .lfm-filter-button.is-active {
      background: #e5e7eb !important;
      color: #111827 !important;
      border-color: #e5e7eb !important;
    }

    html[data-theme="dark"] .lost-found-manager-page .lfm-button-danger {
      background: rgba(127, 29, 29, 0.22) !important;
      border-color: rgba(248, 113, 113, 0.35) !important;
      color: #fecaca !important;
    }

    html[data-theme="dark"] .lost-found-manager-page .lfm-button-restore {
      background: rgba(20, 83, 45, 0.22) !important;
      border-color: rgba(134, 239, 172, 0.35) !important;
      color: #bbf7d0 !important;
    }

    html[data-theme="dark"] .lost-found-manager-page .lfm-button-donated {
      background: rgba(154, 52, 18, 0.22) !important;
      border-color: rgba(251, 146, 60, 0.35) !important;
      color: #fdba74 !important;
    }

    html[data-theme="dark"] .lost-found-manager-page .lfm-button-sold {
      background: rgba(91, 33, 182, 0.22) !important;
      border-color: rgba(167, 139, 250, 0.35) !important;
      color: #ddd6fe !important;
    }

    html[data-theme="dark"] .lost-found-manager-page table.lfm-table thead th {
      background: #162033 !important;
      color: var(--muted) !important;
      border-bottom-color: var(--line) !important;
    }

    html[data-theme="dark"] .lost-found-manager-page table.lfm-table tbody td {
      color: var(--text) !important;
      border-bottom-color: var(--line-soft) !important;
      background: transparent !important;
    }

    html[data-theme="dark"] .lost-found-manager-page table.lfm-table tbody tr:nth-child(odd) td { background: transparent !important; }
    html[data-theme="dark"] .lost-found-manager-page table.lfm-table tbody tr:nth-child(even) td { background: rgba(255, 255, 255, 0.03) !important; }
    html[data-theme="dark"] .lost-found-manager-page table.lfm-table tbody tr:hover td { background: rgba(255, 255, 255, 0.06) !important; }

    @media (prefers-color-scheme: dark) {
      html[data-theme="system"] .lost-found-manager-page .lfm-card,
      html[data-theme="system"] .lost-found-manager-page .lfm-modal-card,
      html[data-theme="system"] .lost-found-manager-page .lfm-busy-card {
        background: var(--card) !important;
        border-color: var(--line-soft) !important;
      }

      html[data-theme="system"] .lost-found-manager-page input,
      html[data-theme="system"] .lost-found-manager-page .lfm-button,
      html[data-theme="system"] .lost-found-manager-page .lfm-filter-button,
      html[data-theme="system"] .lost-found-manager-page .lfm-modal-close {
        background: #0f172a !important;
        color: var(--text) !important;
        border-color: var(--line) !important;
      }

      html[data-theme="system"] .lost-found-manager-page .lfm-button-primary,
      html[data-theme="system"] .lost-found-manager-page .lfm-filter-button.is-active {
        background: #e5e7eb !important;
        color: #111827 !important;
        border-color: #e5e7eb !important;
      }

      html[data-theme="system"] .lost-found-manager-page .lfm-button-danger {
        background: rgba(127, 29, 29, 0.22) !important;
        border-color: rgba(248, 113, 113, 0.35) !important;
        color: #fecaca !important;
      }

      html[data-theme="system"] .lost-found-manager-page .lfm-button-restore {
        background: rgba(20, 83, 45, 0.22) !important;
        border-color: rgba(134, 239, 172, 0.35) !important;
        color: #bbf7d0 !important;
      }

      html[data-theme="system"] .lost-found-manager-page .lfm-button-donated {
        background: rgba(154, 52, 18, 0.22) !important;
        border-color: rgba(251, 146, 60, 0.35) !important;
        color: #fdba74 !important;
      }

      html[data-theme="system"] .lost-found-manager-page .lfm-button-sold {
        background: rgba(91, 33, 182, 0.22) !important;
        border-color: rgba(167, 139, 250, 0.35) !important;
        color: #ddd6fe !important;
      }

      html[data-theme="system"] .lost-found-manager-page table.lfm-table thead th {
        background: #162033 !important;
        color: var(--muted) !important;
        border-bottom-color: var(--line) !important;
      }

      html[data-theme="system"] .lost-found-manager-page table.lfm-table tbody td {
        color: var(--text) !important;
        border-bottom-color: var(--line-soft) !important;
        background: transparent !important;
      }

      html[data-theme="system"] .lost-found-manager-page table.lfm-table tbody tr:nth-child(odd) td { background: transparent !important; }
      html[data-theme="system"] .lost-found-manager-page table.lfm-table tbody tr:nth-child(even) td { background: rgba(255, 255, 255, 0.03) !important; }
      html[data-theme="system"] .lost-found-manager-page table.lfm-table tbody tr:hover td { background: rgba(255, 255, 255, 0.06) !important; }
    }

    @media (max-width: 700px) {
      .lost-found-manager-page .lfm-card { padding: 18px 14px 16px; }
      .lost-found-manager-page .lfm-password-row,
      .lost-found-manager-page .lfm-grid-4,
      .lost-found-manager-page .lfm-modal-grid { grid-template-columns: 1fr; }

      .lost-found-manager-page .lfm-section-head {
        align-items: flex-start;
        flex-direction: column;
      }

      .lost-found-manager-page table.lfm-table col.col-name { width: 6.5ch; }
      .lost-found-manager-page table.lfm-table col.col-disc { width: 7.5ch; }
      .lost-found-manager-page table.lfm-table col.col-color { width: 5ch; }
      .lost-found-manager-page table.lfm-table col.col-phone { width: 8ch; }
      .lost-found-manager-page table.lfm-table col.col-actions { width: 6.5ch; }

      .lost-found-manager-page table.lfm-table thead th {
        font-size: 0.58rem !important;
        padding: 6px 2px !important;
        letter-spacing: 0 !important;
        line-height: 1.05 !important;
      }

      .lost-found-manager-page table.lfm-table thead th:first-child { padding-left: 0 !important; }
      .lost-found-manager-page .lfm-sort-indicator { font-size: 0.56rem !important; }

      .lost-found-manager-page table.lfm-table tbody td {
        font-size: 0.76rem !important;
        padding: 6px 2px !important;
        line-height: 1.06 !important;
      }

      .lost-found-manager-page table.lfm-table tbody td:first-child { padding-left: 0 !important; }

      .lost-found-manager-page .lfm-row-actions .lfm-button {
        min-height: 30px;
        padding: 0 8px;
        font-size: 0.76rem;
      }
    }

    @media (max-width: 420px) {
      .lost-found-manager-page h1 { font-size: 1.9rem; }
      .lost-found-manager-page .lfm-card { padding: 18px 10px 14px; }
      .lost-found-manager-page table.lfm-table col.col-name { width: 6ch; }
      .lost-found-manager-page table.lfm-table col.col-disc { width: 7ch; }
      .lost-found-manager-page table.lfm-table col.col-color { width: 4.8ch; }
      .lost-found-manager-page table.lfm-table col.col-phone { width: 7.4ch; }
      .lost-found-manager-page table.lfm-table col.col-actions { width: 6ch; }

      .lost-found-manager-page table.lfm-table thead th {
        font-size: 0.54rem !important;
        padding: 5px 2px !important;
      }

      .lost-found-manager-page .lfm-sort-indicator { font-size: 0.52rem !important; }

      .lost-found-manager-page table.lfm-table tbody td {
        font-size: 0.72rem !important;
        padding: 5px 2px !important;
      }
    }
  </style>

  <div class="wrap lost-found-manager-page">
    <div class="lfm-stack">
      <section id="lfmLoginCard" class="lfm-card lfm-login" hidden>
        <h1>Lost &amp; Found Manager</h1>

        <form id="lfmUnlockForm" class="lfm-password-row" autocomplete="off">
          <input
            id="lfmPassword"
            name="manager_key"
            type="password"
            autocomplete="off"
            autocapitalize="none"
            spellcheck="false"
            placeholder="Manager password"
            required
          />
          <button class="lfm-button lfm-button-primary" type="submit">Unlock</button>
        </form>

        <div id="lfmLoginStatus" class="lfm-status" aria-live="polite"></div>
      </section>

      <div id="lfmApp" hidden>
        <section class="lfm-card">
          <div class="lfm-section-head">
            <h2>Add a new disc</h2>
          </div>

          <form id="lfmAddForm" class="lfm-grid" autocomplete="off">
            <div class="lfm-grid lfm-grid-4">
              <input name="name" type="text" placeholder="Name" aria-label="Name" />
              <input name="disc" type="text" placeholder="Disc" aria-label="Disc" required />
              <input name="color" type="text" placeholder="Color" aria-label="Color" />
              <input name="phone" type="text" inputmode="tel" placeholder="Full phone" aria-label="Full phone" />
            </div>

            <div class="lfm-actions">
              <button class="lfm-button lfm-button-primary" type="submit">Add disc</button>
            </div>
          </form>

          <div id="lfmAppStatus" class="lfm-status" aria-live="polite"></div>
        </section>

        <section class="lfm-card">
          <div class="lfm-section-head">
            <h2 id="lfmTableHeading">Current inventory</h2>

            <div class="lfm-filter-wrap" role="tablist" aria-label="Inventory filters">
              <button id="lfmFilterCurrent" class="lfm-filter-button is-active" type="button" data-view="current">Current (0)</button>
              <button id="lfmFilterReturned" class="lfm-filter-button" type="button" data-view="returned">Returned (0)</button>
              <button id="lfmFilterDonated" class="lfm-filter-button" type="button" data-view="donated">Donated (0)</button>
              <button id="lfmFilterSold" class="lfm-filter-button" type="button" data-view="sold">Sold (0)</button>
            </div>
          </div>

          <div class="lfm-bulk-bar">
            <div class="lfm-bulk-meta">
              <span id="lfmBulkCount" class="lfm-bulk-count">0 selected</span>
            </div>

            <div class="lfm-bulk-actions">
              <button id="lfmBulkReturned" class="lfm-button lfm-button-danger" type="button">Mark returned</button>
              <button id="lfmBulkRestore" class="lfm-button lfm-button-restore" type="button" hidden>Restore to Current</button>
              <button id="lfmBulkDonated" class="lfm-button lfm-button-donated" type="button">Mark donated</button>
              <button id="lfmBulkSold" class="lfm-button lfm-button-sold" type="button" hidden>Mark sold</button>
              <button id="lfmBulkClear" class="lfm-button lfm-button-light" type="button">Clear</button>
            </div>
          </div>

          <div class="lfm-table-wrap">
            <table class="lfm-table">
              <colgroup>
                <col class="col-select" />
                <col class="col-name" />
                <col class="col-disc" />
                <col class="col-color" />
                <col class="col-phone" />
                <col class="col-actions" />
              </colgroup>
              <thead>
                <tr>
                  <th class="lfm-select-th"></th>
                  <th>
                    <button class="lfm-th-button" type="button" data-sort-index="0">
                      <span>Name</span>
                      <span class="lfm-sort-indicator" data-sort-indicator="0"></span>
                    </button>
                  </th>
                  <th>
                    <button class="lfm-th-button" type="button" data-sort-index="1">
                      <span>Disc</span>
                      <span class="lfm-sort-indicator" data-sort-indicator="1"></span>
                    </button>
                  </th>
                  <th>
                    <button class="lfm-th-button" type="button" data-sort-index="2">
                      <span>Color</span>
                      <span class="lfm-sort-indicator" data-sort-indicator="2"></span>
                    </button>
                  </th>
                  <th>
                    <button class="lfm-th-button" type="button" data-sort-index="3">
                      <span>Phone</span>
                      <span class="lfm-sort-indicator" data-sort-indicator="3"></span>
                    </button>
                  </th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="lfmTableBody">
                <tr>
                  <td class="lfm-empty" colspan="6">Loading…</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <div id="lfmModalLayer" class="lfm-modal-layer" hidden>
        <div class="lfm-modal-backdrop" data-close-modal></div>

        <div class="lfm-modal-card" role="dialog" aria-modal="true" aria-labelledby="lfmModalTitle">
          <div class="lfm-modal-head">
            <h2 id="lfmModalTitle">Edit disc</h2>
            <button id="lfmModalClose" class="lfm-modal-close" type="button" aria-label="Close edit dialog">×</button>
          </div>

          <form id="lfmEditForm" class="lfm-modal-grid" autocomplete="off">
            <input id="lfmEditName" name="name" type="text" placeholder="Name" aria-label="Name" />
            <input id="lfmEditDisc" name="disc" type="text" placeholder="Disc" aria-label="Disc" required />
            <input id="lfmEditColor" name="color" type="text" placeholder="Color" aria-label="Color" />
            <input id="lfmEditPhone" name="phone" type="text" inputmode="tel" placeholder="Full phone" aria-label="Full phone" />
          </form>

          <div class="lfm-modal-actions">
            <button id="lfmSaveEdit" class="lfm-button lfm-button-primary" type="button">Save changes</button>
            <button id="lfmActionRestore" class="lfm-button lfm-button-restore" type="button" hidden>Restore to Current</button>
            <button id="lfmActionReturned" class="lfm-button lfm-button-danger" type="button" hidden>Mark returned</button>
            <button id="lfmActionDonated" class="lfm-button lfm-button-donated" type="button" hidden>Mark donated</button>
            <button id="lfmActionSold" class="lfm-button lfm-button-sold" type="button" hidden>Mark sold</button>
            <button id="lfmCancelEdit" class="lfm-button lfm-button-light" type="button">Cancel</button>
          </div>
        </div>
      </div>

      <div id="lfmBusyOverlay" class="lfm-busy-overlay" hidden>
        <div class="lfm-busy-card">
          <div class="lfm-spinner" aria-hidden="true"></div>
          <div id="lfmBusyText" class="lfm-busy-text">Working…</div>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ apiUrl, messageText }}>
    const loginCard = document.getElementById("lfmLoginCard");
    const appWrap = document.getElementById("lfmApp");
    const unlockForm = document.getElementById("lfmUnlockForm");
    const passwordInput = document.getElementById("lfmPassword");
    const loginStatus = document.getElementById("lfmLoginStatus");
    const appStatus = document.getElementById("lfmAppStatus");
    const addForm = document.getElementById("lfmAddForm");
    const tableBody = document.getElementById("lfmTableBody");
    const tableHeading = document.getElementById("lfmTableHeading");
    const bulkCount = document.getElementById("lfmBulkCount");
    const bulkReturnedButton = document.getElementById("lfmBulkReturned");
    const bulkRestoreButton = document.getElementById("lfmBulkRestore");
    const bulkDonatedButton = document.getElementById("lfmBulkDonated");
    const bulkSoldButton = document.getElementById("lfmBulkSold");
    const bulkClearButton = document.getElementById("lfmBulkClear");

    const filterButtons = {
      current: document.getElementById("lfmFilterCurrent"),
      returned: document.getElementById("lfmFilterReturned"),
      donated: document.getElementById("lfmFilterDonated"),
      sold: document.getElementById("lfmFilterSold"),
    };

    const modalLayer = document.getElementById("lfmModalLayer");
    const modalClose = document.getElementById("lfmModalClose");
    const modalCancel = document.getElementById("lfmCancelEdit");
    const modalTitle = document.getElementById("lfmModalTitle");
    const editForm = document.getElementById("lfmEditForm");
    const editName = document.getElementById("lfmEditName");
    const editDisc = document.getElementById("lfmEditDisc");
    const editColor = document.getElementById("lfmEditColor");
    const editPhone = document.getElementById("lfmEditPhone");
    const saveEditButton = document.getElementById("lfmSaveEdit");
    const actionRestoreButton = document.getElementById("lfmActionRestore");
    const actionReturnedButton = document.getElementById("lfmActionReturned");
    const actionDonatedButton = document.getElementById("lfmActionDonated");
    const actionSoldButton = document.getElementById("lfmActionSold");

    const busyOverlay = document.getElementById("lfmBusyOverlay");
    const busyText = document.getElementById("lfmBusyText");

    const state = {
      password: "",
      records: {
        current: [],
        returned: [],
        donated: [],
        sold: [],
      },
      loaded: {
        current: false,
        returned: false,
        donated: false,
        sold: false,
      },
      activeView: "current",
      editing: null,
      selectedRows: new Set(),
      sorts: {
        current: { index: 4, dir: "desc" },
        returned: { index: 4, dir: "desc" },
        donated: { index: 4, dir: "desc" },
        sold: { index: 4, dir: "desc" },
      },
    };

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function setStatus(target, message, type = "") {
      if (!target) return;
      target.textContent = message || "";
      target.className = `lfm-status${type ? ` is-${type}` : ""}`;
    }

    function setBusy(isBusy, message = "Working…") {
      if (!busyOverlay || !busyText) return;
      busyText.textContent = message;
      busyOverlay.hidden = !isBusy;
    }

    async function runWithBusy(message, fn) {
      setBusy(true, message);
      try {
        return await fn();
      } finally {
        setBusy(false);
      }
    }

    function parseDisplayDate(value) {
      const text = String(value ?? "").trim();
      if (!text) return null;

      const mdy = text.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/);
      if (mdy) {
        let year = Number(mdy[3]);
        if (year < 100) year += 2000;
        const date = new Date(year, Number(mdy[1]) - 1, Number(mdy[2]));
        return Number.isNaN(date.getTime()) ? null : date;
      }

      const direct = new Date(text);
      return Number.isNaN(direct.getTime()) ? null : direct;
    }

    function normalizePhone(value) {
      return String(value ?? "").replace(/[^\d+]/g, "");
    }

    function formatPhone(value) {
      return String(value ?? "").trim();
    }

    function getSmsHref(phone) {
      const cleaned = normalizePhone(phone);
      if (!cleaned) return "#";
      const separator = /iPad|iPhone|iPod/i.test(navigator.userAgent) ? "&" : "?";
      return `sms:${cleaned}${separator}body=${encodeURIComponent(messageText)}`;
    }

    function getSortValue(row, index) {
      switch (index) {
        case 0:
          return String(row.name ?? "").trim().toLowerCase();
        case 1:
          return String(row.disc ?? "").trim().toLowerCase();
        case 2:
          return String(row.color ?? "").trim().toLowerCase();
        case 3:
          return String(row.phone ?? "").replace(/[^\d]/g, "");
        case 4: {
          const parsed = parseDisplayDate(row.date);
          return parsed ? parsed.getTime() : 0;
        }
        default:
          return "";
      }
    }

    function compareRows(a, b, view) {
      const sort = state.sorts[view];
      const left = getSortValue(a, sort.index);
      const right = getSortValue(b, sort.index);

      const leftEmpty = left === "" || left === 0 || left == null;
      const rightEmpty = right === "" || right === 0 || right == null;

      if (leftEmpty && rightEmpty) return 0;
      if (leftEmpty) return 1;
      if (rightEmpty) return -1;

      let comparison = 0;

      if (typeof left === "number" && typeof right === "number") {
        comparison = left - right;
      } else {
        comparison = String(left).localeCompare(String(right), undefined, {
          numeric: true,
          sensitivity: "base",
        });
      }

      return sort.dir === "asc" ? comparison : -comparison;
    }

    function sortRows(rows, view) {
      return [...rows].sort((a, b) => compareRows(a, b, view));
    }

    function updateSortIndicators() {
      const activeSort = state.sorts[state.activeView];

      document.querySelectorAll("[data-sort-indicator]").forEach((el) => {
        const index = Number(el.getAttribute("data-sort-indicator"));

        if (activeSort.index !== index) {
          el.textContent = "";
          return;
        }

        el.textContent = activeSort.dir === "asc" ? "▲" : "▼";
      });
    }

    function getViewCount(view) {
      return Array.isArray(state.records[view]) ? state.records[view].length : 0;
    }

    function getViewHeading(view) {
      if (view === "current") return "Current inventory";
      if (view === "returned") return "Returned discs";
      if (view === "donated") return "Donated discs";
      return "Sold discs";
    }

    function getViewButtonLabel(view) {
      const count = getViewCount(view);

      if (view === "current") return `Current (${count})`;
      if (view === "returned") return `Returned (${count})`;
      if (view === "donated") return `Donated (${count})`;
      return `Sold (${count})`;
    }

    function updateFilterButtons() {
      Object.entries(filterButtons).forEach(([view, button]) => {
        if (!button) return;
        button.classList.toggle("is-active", state.activeView === view);
        button.textContent = getViewButtonLabel(view);
      });

      if (tableHeading) {
        tableHeading.textContent = getViewHeading(state.activeView);
      }
    }

    function getVisibleRows() {
      return sortRows(state.records[state.activeView] || [], state.activeView);
    }

    function updateBulkUi(rows = getVisibleRows()) {
      const totalSelectedCount = state.selectedRows.size;
      const hasSelection = totalSelectedCount > 0;

      if (bulkCount) {
        bulkCount.textContent = `${totalSelectedCount} selected`;
      }

      if (bulkReturnedButton) {
        bulkReturnedButton.hidden = state.activeView !== "current";
        bulkReturnedButton.disabled = !hasSelection;
      }

      if (bulkDonatedButton) {
        bulkDonatedButton.hidden = !["current", "returned"].includes(state.activeView);
        bulkDonatedButton.disabled = !hasSelection;
      }

      if (bulkSoldButton) {
        bulkSoldButton.hidden = state.activeView !== "donated";
        bulkSoldButton.disabled = !hasSelection;
      }

      if (bulkRestoreButton) {
        bulkRestoreButton.hidden = state.activeView === "current";
        bulkRestoreButton.disabled = !hasSelection;
      }

      if (bulkClearButton) {
        bulkClearButton.disabled = !hasSelection;
      }
    }

    async function runBulkAction(operation, busyMessage, successMessage) {
      if (!state.selectedRows.size) {
        setStatus(appStatus, "Select at least one disc.", "error");
        return;
      }

      await runWithBusy(busyMessage, async () => {
        const response = await jsonp({
          action: "bulkUpdate",
          password: state.password,
          operation,
          rowNumbers: [...state.selectedRows].join(","),
        });

        if (!response?.ok) {
          throw new Error(response?.error || "Unable to update discs.");
        }

        state.selectedRows.clear();
        await refreshLoadedViews();
      });

      setStatus(appStatus, successMessage, "success");
    }

    function renderTable() {
      const rows = sortRows(state.records[state.activeView] || [], state.activeView);

      if (!rows.length) {
        const emptyText =
          state.activeView === "current"
            ? "No active discs found."
            : state.activeView === "returned"
              ? "No returned discs found."
              : state.activeView === "donated"
                ? "No donated discs found."
                : "No sold discs found.";

        tableBody.innerHTML = `
          <tr>
            <td class="lfm-empty" colspan="6">${emptyText}</td>
          </tr>
        `;
        updateSortIndicators();
        updateFilterButtons();
        updateBulkUi(rows);
        return;
      }

      tableBody.innerHTML = rows
        .map((row) => {
          const rowNumber = Number(row.rowNumber);
          const checked = state.selectedRows.has(rowNumber) ? "checked" : "";
          const hasPhone = String(row.phone ?? "").trim() !== "";
          const phoneHtml = hasPhone
            ? `<a class="lfm-phone-link" href="${escapeHtml(getSmsHref(row.phone))}">${escapeHtml(formatPhone(row.phone))}</a>`
            : "—";

          return `
            <tr>
              <td class="lfm-select-cell">
                <input type="checkbox" class="lfm-row-check" data-select-row="${rowNumber}" ${checked} />
              </td>
              <td>${escapeHtml(row.name || "") || "&nbsp;"}</td>
              <td>${escapeHtml(row.disc || "") || "&nbsp;"}</td>
              <td>${escapeHtml(row.color || "") || "&nbsp;"}</td>
              <td>${phoneHtml}</td>
              <td>
                <div class="lfm-row-actions">
                  <button class="lfm-button" type="button" data-edit-row="${rowNumber}">Edit</button>
                </div>
              </td>
            </tr>
          `;
        })
        .join("");

      updateSortIndicators();
      updateFilterButtons();
      updateBulkUi(rows);
    }

    function handleSort(index) {
      const current = state.sorts[state.activeView];

      if (current.index === index) {
        current.dir = current.dir === "asc" ? "desc" : "asc";
      } else {
        current.index = index;
        current.dir = "asc";
      }

      renderTable();
    }

    function jsonp(params) {
      return new Promise((resolve, reject) => {
        const callbackName = `__lfm_cb_${Date.now()}_${Math.random().toString(36).slice(2)}`;
        const url = new URL(apiUrl);

        Object.entries(params || {}).forEach(([key, value]) => {
          if (value !== undefined && value !== null) {
            url.searchParams.set(key, String(value));
          }
        });

        url.searchParams.set("callback", callbackName);

        const script = document.createElement("script");
        const timeout = window.setTimeout(() => {
          cleanup();
          reject(new Error("Request timed out."));
        }, 15000);

        function cleanup() {
          window.clearTimeout(timeout);
          if (script.parentNode) script.parentNode.removeChild(script);
          try {
            delete window[callbackName];
          } catch {
            window[callbackName] = undefined;
          }
        }

        window[callbackName] = (payload) => {
          cleanup();
          resolve(payload);
        };

        script.onerror = () => {
          cleanup();
          reject(new Error("Unable to reach the manager service."));
        };

        script.src = url.toString();
        document.body.appendChild(script);
      });
    }

    function getActionForView(view) {
      return view === "current"
        ? "list"
        : view === "returned"
          ? "listReturned"
          : view === "donated"
            ? "listDonated"
            : "listSold";
    }

    async function loadView(view) {
      const payload = await jsonp({
        action: getActionForView(view),
        password: state.password,
      });

      if (!payload?.ok) {
        throw new Error(payload?.error || `Unable to load ${view} discs.`);
      }

      state.records[view] = Array.isArray(payload.records) ? payload.records : [];
      state.loaded[view] = true;

      if (state.activeView === view) {
        renderTable();
      }
    }

    async function ensureViewLoaded(view) {
      if (state.loaded[view]) return;
      await loadView(view);
    }

    async function refreshLoadedViews() {
      const views = ["current", "returned", "donated", "sold"];

      for (const view of views) {
        await loadView(view);
      }
    }

    async function unlock(password) {
      const trimmed = String(password || "");
      if (!trimmed) {
        throw new Error("Enter the manager password.");
      }

      state.password = trimmed;
      state.activeView = "current";
      await refreshLoadedViews();
      renderTable();

      loginCard.hidden = true;
      appWrap.hidden = false;
      setStatus(loginStatus, "");
      setStatus(appStatus, "");
    }

    function showLogin(message = "", type = "") {
      appWrap.hidden = true;
      loginCard.hidden = false;
      if (passwordInput) passwordInput.value = "";
      setStatus(loginStatus, message, type);
    }

    function getRecordByRow(rowNumber) {
      const source = state.records[state.activeView] || [];
      return source.find((row) => Number(row.rowNumber) === Number(rowNumber)) || null;
    }

    function openEditModal(row) {
      if (!row) return;

      state.editing = {
        rowNumber: Number(row.rowNumber),
        mode: state.activeView,
      };

      modalTitle.textContent =
        state.activeView === "current"
          ? "Edit disc"
          : state.activeView === "returned"
            ? "Edit returned disc"
            : state.activeView === "donated"
              ? "Edit donated disc"
              : "Edit sold disc";

      editName.value = row.name || "";
      editDisc.value = row.disc || "";
      editColor.value = row.color || "";
      editPhone.value = row.phone || "";

      if (state.activeView === "current") {
        actionRestoreButton.hidden = true;
        actionReturnedButton.hidden = false;
        actionDonatedButton.hidden = false;
        actionSoldButton.hidden = true;
      } else if (state.activeView === "returned") {
        actionRestoreButton.hidden = false;
        actionRestoreButton.textContent = "Restore to Current";
        actionReturnedButton.hidden = true;
        actionDonatedButton.hidden = false;
        actionSoldButton.hidden = true;
      } else if (state.activeView === "donated") {
        actionRestoreButton.hidden = false;
        actionRestoreButton.textContent = "Restore to Current";
        actionReturnedButton.hidden = true;
        actionDonatedButton.hidden = true;
        actionSoldButton.hidden = false;
      } else {
        actionRestoreButton.hidden = false;
        actionRestoreButton.textContent = "Restore to Current";
        actionReturnedButton.hidden = true;
        actionDonatedButton.hidden = true;
        actionSoldButton.hidden = true;
      }

      modalLayer.hidden = false;
      document.body.style.overflow = "hidden";
    }

    function closeEditModal() {
      modalLayer.hidden = true;
      document.body.style.overflow = "";
      state.editing = null;
      editForm.reset();
    }

    function getEditPayload() {
      return {
        rowNumber: state.editing?.rowNumber,
        name: editName.value,
        disc: editDisc.value,
        color: editColor.value,
        phone: editPhone.value,
      };
    }

    async function saveEditWithState({ returned, status }, busyMessage, successMessage) {
      if (!state.editing) return;

      await runWithBusy(busyMessage, async () => {
        const payload = {
          action: "update",
          password: state.password,
          ...getEditPayload(),
        };

        if (returned !== undefined) {
          payload.returned = returned ? "true" : "false";
        }

        if (status !== undefined) {
          payload.status = status;
        }

        const response = await jsonp(payload);

        if (!response?.ok) {
          throw new Error(response?.error || "Unable to update disc.");
        }

        closeEditModal();
        await refreshLoadedViews();
      });

      setStatus(appStatus, successMessage, "success");
      window.alert(successMessage);
    }

    addForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const formData = new FormData(addForm);
      const submittedPhone = String(formData.get("phone") || "").trim();

      try {
        await runWithBusy("Adding disc…", async () => {
          const payload = await jsonp({
            action: "add",
            password: state.password,
            name: formData.get("name"),
            disc: formData.get("disc"),
            color: formData.get("color"),
            phone: submittedPhone,
          });

          if (!payload?.ok) {
            throw new Error(payload?.error || "Unable to add disc.");
          }

          addForm.reset();
          await refreshLoadedViews();
        });

        setStatus(appStatus, "Disc added.", "success");

        if (submittedPhone) {
          const shouldText = window.confirm(
            "Disc added. Would you like to text the owner now?"
          );

          if (shouldText) {
            window.location.href = getSmsHref(submittedPhone);
          }
        }
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to add disc.", "error");
      }
    });

    unlockForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      try {
        setStatus(loginStatus, "Unlocking…");
        await runWithBusy("Unlocking…", () => unlock(passwordInput?.value || ""));
      } catch (error) {
        state.password = "";
        showLogin(error?.message || "Unable to unlock.", "error");
      }
    });

    tableBody?.addEventListener("click", (event) => {
      const button = event.target.closest("[data-edit-row]");
      if (!button) return;

      const rowNumber = Number(button.getAttribute("data-edit-row"));
      const row = getRecordByRow(rowNumber);
      openEditModal(row);
    });

    tableBody?.addEventListener("change", (event) => {
      const checkbox = event.target.closest("[data-select-row]");
      if (!checkbox) return;

      const rowNumber = Number(checkbox.getAttribute("data-select-row"));
      if (!rowNumber) return;

      if (checkbox.checked) {
        state.selectedRows.add(rowNumber);
      } else {
        state.selectedRows.delete(rowNumber);
      }

      updateBulkUi();
    });

    document.addEventListener("click", async (event) => {
      const sortButton = event.target.closest("[data-sort-index]");
      if (sortButton && sortButton.closest(".lfm-table")) {
        const index = Number(sortButton.getAttribute("data-sort-index"));
        if (!Number.isNaN(index)) handleSort(index);
        return;
      }

      const filterButton = event.target.closest("[data-view]");
      if (filterButton && filterButton.closest(".lfm-filter-wrap")) {
        const view = filterButton.getAttribute("data-view");
        if (!view || state.activeView === view) return;

        try {
          await runWithBusy(`Loading ${view} discs…`, async () => {
            state.activeView = view;
            state.selectedRows.clear();
            await ensureViewLoaded(view);
            renderTable();
          });
          setStatus(appStatus, "");
        } catch (error) {
          setStatus(appStatus, error?.message || `Unable to load ${view} discs.`, "error");
        }
      }
    });

    saveEditButton?.addEventListener("click", async () => {
      try {
        await runWithBusy("Saving changes…", async () => {
          const payload = {
            action: "update",
            password: state.password,
            ...getEditPayload(),
          };

          const response = await jsonp(payload);

          if (!response?.ok) {
            throw new Error(response?.error || "Unable to save changes.");
          }

          closeEditModal();
          await refreshLoadedViews();
        });

        setStatus(appStatus, "Changes saved.", "success");
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to save changes.", "error");
      }
    });

    actionReturnedButton?.addEventListener("click", async () => {
      try {
        await saveEditWithState(
          { returned: true, status: "" },
          "Marking disc returned…",
          "Disc marked returned."
        );
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to mark disc returned.", "error");
      }
    });

    actionRestoreButton?.addEventListener("click", async () => {
      try {
        await saveEditWithState(
          { returned: false, status: "" },
          "Restoring disc…",
          "Disc restored to current inventory."
        );
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to restore disc.", "error");
      }
    });

    actionDonatedButton?.addEventListener("click", async () => {
      try {
        await saveEditWithState(
          { returned: true, status: "Donated" },
          "Marking disc donated…",
          "Disc marked donated."
        );
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to mark disc donated.", "error");
      }
    });

    actionSoldButton?.addEventListener("click", async () => {
      try {
        await saveEditWithState(
          { returned: true, status: "Sold" },
          "Archiving sold disc…",
          "Disc marked sold and archived."
        );
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to mark disc sold.", "error");
      }
    });

    bulkReturnedButton?.addEventListener("click", async () => {
      try {
        await runBulkAction(
          "returned",
          "Marking discs returned…",
          "Discs marked returned."
        );
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to mark discs returned.", "error");
      }
    });

    bulkRestoreButton?.addEventListener("click", async () => {
      try {
        await runBulkAction(
          "restore",
          "Restoring discs…",
          "Discs restored to current inventory."
        );
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to restore discs.", "error");
      }
    });

    bulkDonatedButton?.addEventListener("click", async () => {
      try {
        await runBulkAction(
          "donated",
          "Marking discs donated…",
          "Discs marked donated."
        );
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to mark discs donated.", "error");
      }
    });

    bulkSoldButton?.addEventListener("click", async () => {
      try {
        await runBulkAction(
          "sold",
          "Archiving sold discs…",
          "Discs marked sold and archived."
        );
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to mark discs sold.", "error");
      }
    });

    bulkClearButton?.addEventListener("click", () => {
      state.selectedRows.clear();
      renderTable();
      setStatus(appStatus, "");
    });

    modalClose?.addEventListener("click", closeEditModal);
    modalCancel?.addEventListener("click", closeEditModal);
    modalLayer?.addEventListener("click", (event) => {
      if (event.target.closest("[data-close-modal]")) {
        closeEditModal();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !modalLayer.hidden) {
        closeEditModal();
      }
    });

    showLogin();
  </script>
</SiteLayout>
