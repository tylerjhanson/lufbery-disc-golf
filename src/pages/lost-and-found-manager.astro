---
import SiteLayout from "../layouts/SiteLayout.astro";

const apiUrl = "https://script.google.com/macros/s/AKfycbyOVn9a5mphmeROGJPmHDD4Rpz-SeRpT50Cbk5qbuxn3BBCi1iaiHHU2fUrPg5Ccr9c/exec";
const messageText =
  "Your disc was returned to the Lufbery lost and found. Please visit https://lufberydiscgolf.com/lost-and-found/ for our current lost disc inventory and pick-up instructions. Discs not picked up within 60 days will be donated.";
---

<SiteLayout title="Lost & Found Manager" showBrandBar={true} noindex={true}>
  <style is:global>
    .lost-found-manager-page * {
      box-sizing: border-box;
    }

    .lost-found-manager-page {
      width: 100%;
      max-width: none;
      margin: 0;
    }

    .lost-found-manager-page .lfm-card {
      background: var(--card) !important;
      border: 1px solid var(--line-soft) !important;
      border-radius: 10px !important;
      box-shadow: var(--shadow) !important;
      overflow: hidden;
      padding: 22px 22px 18px;
    }

    .lost-found-manager-page .lfm-stack {
      display: grid;
      gap: 16px;
    }

    .lost-found-manager-page h1 {
      margin: 0 0 14px;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--text);
    }

    .lost-found-manager-page h2 {
      margin: 0;
      font-size: 0.98rem;
      line-height: 1.2;
      color: var(--text);
      font-weight: 700;
    }

    .lost-found-manager-page p {
      margin: 0;
      font-size: 1rem;
      line-height: 1.6;
      color: var(--text);
    }

    .lost-found-manager-page .lfm-muted {
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.45;
    }

    .lost-found-manager-page .lfm-login {
      max-width: 520px;
      margin: 0 auto;
    }

    .lost-found-manager-page .lfm-password-row {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 10px;
      margin-top: 12px;
    }

    .lost-found-manager-page .lfm-grid {
      display: grid;
      gap: 10px;
    }

    .lost-found-manager-page .lfm-grid-4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .lost-found-manager-page .lfm-grid-2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .lost-found-manager-page input,
    .lost-found-manager-page button {
      font: inherit;
    }

    .lost-found-manager-page input {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #fff;
      color: var(--text);
      min-height: 40px;
      padding: 0 12px;
      outline: none;
      transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }

    .lost-found-manager-page input:focus {
      border-color: rgba(37, 99, 235, 0.5);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
    }

    .lost-found-manager-page .lfm-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .lost-found-manager-page .lfm-button,
    .lost-found-manager-page .lfm-link-button {
      transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
    }

    .lost-found-manager-page .lfm-button {
      min-height: 40px;
      padding: 0 14px;
      font-weight: 600;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--text);
      border-radius: 10px;
      cursor: pointer;
    }

    .lost-found-manager-page .lfm-button:hover {
      background: #f8fafc;
      border-color: var(--line-soft);
    }

    .lost-found-manager-page .lfm-button:active {
      transform: translateY(1px);
    }

    .lost-found-manager-page .lfm-button-primary {
      background: #111827;
      color: #fff;
      border-color: #111827;
    }

    .lost-found-manager-page .lfm-button-primary:hover {
      background: #1f2937;
      border-color: #1f2937;
    }

    .lost-found-manager-page .lfm-button-danger {
      background: #fff5f5;
      border-color: #fecaca;
      color: #991b1b;
    }

    .lost-found-manager-page .lfm-button-danger:hover {
      background: #fee2e2;
      border-color: #fca5a5;
    }

    .lost-found-manager-page .lfm-button-restore {
      background: #f0fdf4;
      border-color: #bbf7d0;
      color: #166534;
    }

    .lost-found-manager-page .lfm-button-restore:hover {
      background: #dcfce7;
      border-color: #86efac;
    }

    .lost-found-manager-page .lfm-button-light {
      background: #fff;
      color: var(--text);
      border-color: var(--line);
    }

    .lost-found-manager-page .lfm-link-button {
      border: 0;
      background: transparent;
      padding: 0;
      color: var(--accent);
      cursor: pointer;
      font-size: 0.95rem;
      font-weight: 600;
      text-decoration: none;
    }

    .lost-found-manager-page .lfm-link-button:hover {
      text-decoration: underline;
    }

    .lost-found-manager-page .lfm-status {
      min-height: 22px;
      font-size: 0.94rem;
      color: var(--muted);
      margin-top: 10px;
    }

    .lost-found-manager-page .lfm-status.is-error {
      color: #b91c1c;
    }

    .lost-found-manager-page .lfm-status.is-success {
      color: #166534;
    }

    .lost-found-manager-page .lfm-section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 8px;
    }

    .lost-found-manager-page .lfm-table-wrap {
      padding: 0;
      margin: 0;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .lost-found-manager-page table.lfm-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      table-layout: fixed;
      min-width: 420px;
      background: transparent;
      margin: 0;
    }

    .lost-found-manager-page table.lfm-table col.col-name {
      width: 9ch;
    }

    .lost-found-manager-page table.lfm-table col.col-disc {
      width: 11ch;
    }

    .lost-found-manager-page table.lfm-table col.col-color {
      width: 6ch;
    }

    .lost-found-manager-page table.lfm-table col.col-phone {
      width: 10ch;
    }

    .lost-found-manager-page table.lfm-table col.col-actions {
      width: 8ch;
    }

    .lost-found-manager-page table.lfm-table thead th {
      background: var(--header, #f8fafc);
      color: var(--muted);
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      padding: 8px 5px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      white-space: normal;
      line-height: 1.1;
    }

    .lost-found-manager-page table.lfm-table thead th:first-child {
      border-top-left-radius: 14px;
      padding-left: 0;
    }

    .lost-found-manager-page table.lfm-table thead th:last-child {
      border-top-right-radius: 14px;
    }

    .lost-found-manager-page table.lfm-table tbody td {
      padding: 8px 5px;
      border-bottom: 1px solid var(--line-soft);
      font-size: 0.84rem;
      text-align: left;
      vertical-align: middle;
      line-height: 1.1;
      white-space: normal;
      overflow-wrap: anywhere;
      word-break: break-word;
      background: transparent;
    }

    .lost-found-manager-page table.lfm-table tbody td:first-child {
      padding-left: 0;
    }

    .lost-found-manager-page table.lfm-table tbody tr:nth-child(even) td {
      background: #fcfdff !important;
    }

    .lost-found-manager-page table.lfm-table tbody tr:nth-child(odd) td {
      background: transparent !important;
    }

    .lost-found-manager-page table.lfm-table tbody tr:hover td {
      background: var(--hover, #f9fbff) !important;
    }

    .lost-found-manager-page .lfm-phone-link {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
    }

    .lost-found-manager-page .lfm-phone-link:hover {
      text-decoration: underline;
    }

    .lost-found-manager-page .lfm-row-actions {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 6px;
      flex-wrap: wrap;
    }

    .lost-found-manager-page .lfm-row-actions .lfm-button {
      min-height: 32px;
      padding: 0 10px;
      font-size: 0.8rem;
    }

    .lost-found-manager-page .lfm-empty {
      color: var(--muted);
      text-align: center;
      padding: 18px 12px;
    }

    .lost-found-manager-page [hidden] {
      display: none !important;
    }

    .lost-found-manager-page .lfm-modal-layer {
      position: fixed;
      inset: 0;
      z-index: 110;
      display: grid;
      place-items: center;
      padding: 16px;
    }

    .lost-found-manager-page .lfm-modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(15, 23, 42, 0.4);
    }

    .lost-found-manager-page .lfm-modal-card {
      position: relative;
      width: min(100%, 560px);
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-radius: 14px;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.18);
      padding: 18px 18px 16px;
    }

    .lost-found-manager-page .lfm-modal-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 12px;
    }

    .lost-found-manager-page .lfm-modal-close {
      width: 36px;
      height: 36px;
      border: 1px solid var(--line);
      background: #fff;
      color: var(--text);
      border-radius: 10px;
      cursor: pointer;
      font-size: 1.15rem;
      line-height: 1;
    }

    .lost-found-manager-page .lfm-modal-grid {
      display: grid;
      gap: 10px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .lost-found-manager-page .lfm-modal-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 14px;
    }

    html[data-theme="dark"] .lost-found-manager-page .lfm-card,
    html[data-theme="dark"] .lost-found-manager-page .lfm-modal-card {
      background: var(--card) !important;
      border-color: var(--line-soft) !important;
    }

    html[data-theme="dark"] .lost-found-manager-page input,
    html[data-theme="dark"] .lost-found-manager-page .lfm-button,
    html[data-theme="dark"] .lost-found-manager-page .lfm-modal-close {
      background: #0f172a !important;
      color: var(--text) !important;
      border-color: var(--line) !important;
    }

    html[data-theme="dark"] .lost-found-manager-page .lfm-button-primary {
      background: #e5e7eb !important;
      color: #111827 !important;
      border-color: #e5e7eb !important;
    }

    html[data-theme="dark"] .lost-found-manager-page .lfm-button-danger {
      background: rgba(127, 29, 29, 0.22) !important;
      border-color: rgba(248, 113, 113, 0.35) !important;
      color: #fecaca !important;
    }

    html[data-theme="dark"] .lost-found-manager-page .lfm-button-restore {
      background: rgba(20, 83, 45, 0.22) !important;
      border-color: rgba(134, 239, 172, 0.35) !important;
      color: #bbf7d0 !important;
    }

    html[data-theme="dark"] .lost-found-manager-page table.lfm-table thead th {
      background: #162033 !important;
      color: var(--muted) !important;
      border-bottom-color: var(--line) !important;
    }

    html[data-theme="dark"] .lost-found-manager-page table.lfm-table tbody td {
      color: var(--text) !important;
      border-bottom-color: var(--line-soft) !important;
      background: transparent !important;
    }

    html[data-theme="dark"] .lost-found-manager-page table.lfm-table tbody tr:nth-child(odd) td {
      background: transparent !important;
    }

    html[data-theme="dark"] .lost-found-manager-page table.lfm-table tbody tr:nth-child(even) td {
      background: rgba(255, 255, 255, 0.03) !important;
    }

    html[data-theme="dark"] .lost-found-manager-page table.lfm-table tbody tr:hover td {
      background: rgba(255, 255, 255, 0.06) !important;
    }

    @media (prefers-color-scheme: dark) {
      html[data-theme="system"] .lost-found-manager-page .lfm-card,
      html[data-theme="system"] .lost-found-manager-page .lfm-modal-card {
        background: var(--card) !important;
        border-color: var(--line-soft) !important;
      }

      html[data-theme="system"] .lost-found-manager-page input,
      html[data-theme="system"] .lost-found-manager-page .lfm-button,
      html[data-theme="system"] .lost-found-manager-page .lfm-modal-close {
        background: #0f172a !important;
        color: var(--text) !important;
        border-color: var(--line) !important;
      }

      html[data-theme="system"] .lost-found-manager-page .lfm-button-primary {
        background: #e5e7eb !important;
        color: #111827 !important;
        border-color: #e5e7eb !important;
      }

      html[data-theme="system"] .lost-found-manager-page .lfm-button-danger {
        background: rgba(127, 29, 29, 0.22) !important;
        border-color: rgba(248, 113, 113, 0.35) !important;
        color: #fecaca !important;
      }

      html[data-theme="system"] .lost-found-manager-page .lfm-button-restore {
        background: rgba(20, 83, 45, 0.22) !important;
        border-color: rgba(134, 239, 172, 0.35) !important;
        color: #bbf7d0 !important;
      }

      html[data-theme="system"] .lost-found-manager-page table.lfm-table thead th {
        background: #162033 !important;
        color: var(--muted) !important;
        border-bottom-color: var(--line) !important;
      }

      html[data-theme="system"] .lost-found-manager-page table.lfm-table tbody td {
        color: var(--text) !important;
        border-bottom-color: var(--line-soft) !important;
        background: transparent !important;
      }

      html[data-theme="system"] .lost-found-manager-page table.lfm-table tbody tr:nth-child(odd) td {
        background: transparent !important;
      }

      html[data-theme="system"] .lost-found-manager-page table.lfm-table tbody tr:nth-child(even) td {
        background: rgba(255, 255, 255, 0.03) !important;
      }

      html[data-theme="system"] .lost-found-manager-page table.lfm-table tbody tr:hover td {
        background: rgba(255, 255, 255, 0.06) !important;
      }
    }

    @media (max-width: 700px) {
      .lost-found-manager-page .lfm-card {
        padding: 18px 14px 16px;
      }

      .lost-found-manager-page .lfm-password-row,
      .lost-found-manager-page .lfm-grid-4,
      .lost-found-manager-page .lfm-grid-2,
      .lost-found-manager-page .lfm-modal-grid {
        grid-template-columns: 1fr;
      }

      .lost-found-manager-page .lfm-section-head {
        align-items: flex-start;
        flex-direction: column;
      }

      .lost-found-manager-page table.lfm-table {
        min-width: 380px;
      }

      .lost-found-manager-page table.lfm-table thead th {
        font-size: 0.58rem !important;
        padding: 6px 2px !important;
        letter-spacing: 0 !important;
        line-height: 1.05 !important;
      }

      .lost-found-manager-page table.lfm-table thead th:first-child {
        padding-left: 0 !important;
      }

      .lost-found-manager-page table.lfm-table tbody td {
        font-size: 0.76rem !important;
        padding: 6px 2px !important;
        line-height: 1.06 !important;
      }

      .lost-found-manager-page table.lfm-table tbody td:first-child {
        padding-left: 0 !important;
      }

      .lost-found-manager-page .lfm-row-actions .lfm-button {
        min-height: 30px;
        padding: 0 8px;
        font-size: 0.76rem;
      }
    }

    @media (max-width: 420px) {
      .lost-found-manager-page h1 {
        font-size: 1.9rem;
      }

      .lost-found-manager-page .lfm-card {
        padding: 18px 10px 14px;
      }

      .lost-found-manager-page table.lfm-table {
        min-width: 360px;
      }

      .lost-found-manager-page table.lfm-table thead th {
        font-size: 0.54rem !important;
        padding: 5px 2px !important;
      }

      .lost-found-manager-page table.lfm-table tbody td {
        font-size: 0.72rem !important;
        padding: 5px 2px !important;
      }
    }
  </style>

  <div class="wrap lost-found-manager-page">
    <div class="lfm-stack">
      <section id="lfmLoginCard" class="lfm-card lfm-login" hidden>
        <h1>Lost &amp; Found Manager</h1>

        <form id="lfmUnlockForm" class="lfm-password-row" autocomplete="off">
          <input
            id="lfmPassword"
            name="manager_key"
            type="password"
            autocomplete="new-password"
            autocapitalize="none"
            spellcheck="false"
            placeholder="Manager password"
            required
          />
          <button class="lfm-button lfm-button-primary" type="submit">Unlock</button>
        </form>

        <div id="lfmLoginStatus" class="lfm-status" aria-live="polite"></div>
      </section>

      <div id="lfmApp" hidden>
        <section class="lfm-card">
          <div class="lfm-section-head">
            <h2>Add a new disc</h2>
          </div>

          <form id="lfmAddForm" class="lfm-grid" autocomplete="off">
            <div class="lfm-grid lfm-grid-4">
              <input id="lfmDate" name="date" type="date" required aria-label="Date found" placeholder="Date found" />
              <input name="name" type="text" placeholder="Name" aria-label="Name" />
              <input name="disc" type="text" placeholder="Disc" aria-label="Disc" required />
              <input name="color" type="text" placeholder="Color" aria-label="Color" />
            </div>

            <div class="lfm-grid lfm-grid-2">
              <input name="last4" type="text" maxlength="4" inputmode="numeric" placeholder="Last 4" aria-label="Last 4" />
              <input name="phone" type="text" inputmode="tel" placeholder="Full phone" aria-label="Full phone" />
            </div>

            <div class="lfm-actions">
              <button class="lfm-button lfm-button-primary" type="submit">Add disc</button>
            </div>
          </form>

          <div id="lfmAppStatus" class="lfm-status" aria-live="polite"></div>
        </section>

        <section class="lfm-card">
          <div class="lfm-section-head">
            <div>
              <h2>Current inventory</h2>
              <p class="lfm-muted">Tap a phone number to open a text with the prefilled message.</p>
            </div>

            <button id="lfmToggleReturned" class="lfm-link-button" type="button">
              View returned discs
            </button>
          </div>

          <div class="lfm-table-wrap">
            <table class="lfm-table">
              <colgroup>
                <col class="col-name" />
                <col class="col-disc" />
                <col class="col-color" />
                <col class="col-phone" />
                <col class="col-actions" />
              </colgroup>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Disc</th>
                  <th>Color</th>
                  <th>Phone</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="lfmInventoryBody">
                <tr>
                  <td class="lfm-empty" colspan="5">Loading…</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <section id="lfmReturnedSection" class="lfm-card" hidden>
          <div class="lfm-section-head">
            <div>
              <h2>Returned discs</h2>
              <p class="lfm-muted">Open a disc to restore it or edit it.</p>
            </div>
          </div>

          <div class="lfm-table-wrap">
            <table class="lfm-table">
              <colgroup>
                <col class="col-name" />
                <col class="col-disc" />
                <col class="col-color" />
                <col class="col-phone" />
                <col class="col-actions" />
              </colgroup>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Disc</th>
                  <th>Color</th>
                  <th>Phone</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="lfmReturnedBody">
                <tr>
                  <td class="lfm-empty" colspan="5">Hidden.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>
      </div>

      <div id="lfmModalLayer" class="lfm-modal-layer" hidden>
        <div class="lfm-modal-backdrop" data-close-modal></div>

        <div class="lfm-modal-card" role="dialog" aria-modal="true" aria-labelledby="lfmModalTitle">
          <div class="lfm-modal-head">
            <h2 id="lfmModalTitle">Edit disc</h2>
            <button id="lfmModalClose" class="lfm-modal-close" type="button" aria-label="Close edit dialog">×</button>
          </div>

          <form id="lfmEditForm" class="lfm-modal-grid" autocomplete="off">
            <input id="lfmEditDate" name="date" type="date" required aria-label="Date found" placeholder="Date found" />
            <input id="lfmEditName" name="name" type="text" placeholder="Name" aria-label="Name" />
            <input id="lfmEditDisc" name="disc" type="text" placeholder="Disc" aria-label="Disc" required />
            <input id="lfmEditColor" name="color" type="text" placeholder="Color" aria-label="Color" />
            <input id="lfmEditLast4" name="last4" type="text" maxlength="4" inputmode="numeric" placeholder="Last 4" aria-label="Last 4" />
            <input id="lfmEditPhone" name="phone" type="text" inputmode="tel" placeholder="Full phone" aria-label="Full phone" />
          </form>

          <div class="lfm-modal-actions">
            <button id="lfmSaveEdit" class="lfm-button lfm-button-primary" type="button">Save changes</button>
            <button id="lfmSecondaryEditAction" class="lfm-button" type="button">Mark returned</button>
            <button id="lfmCancelEdit" class="lfm-button lfm-button-light" type="button">Cancel</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ apiUrl, messageText }}>
    const PASSWORD_KEY = "lufbery-lf-manager-password";
    const loginCard = document.getElementById("lfmLoginCard");
    const appWrap = document.getElementById("lfmApp");
    const unlockForm = document.getElementById("lfmUnlockForm");
    const passwordInput = document.getElementById("lfmPassword");
    const loginStatus = document.getElementById("lfmLoginStatus");
    const appStatus = document.getElementById("lfmAppStatus");
    const addForm = document.getElementById("lfmAddForm");
    const inventoryBody = document.getElementById("lfmInventoryBody");
    const returnedBody = document.getElementById("lfmReturnedBody");
    const returnedSection = document.getElementById("lfmReturnedSection");
    const toggleReturnedButton = document.getElementById("lfmToggleReturned");
    const dateInput = document.getElementById("lfmDate");

    const modalLayer = document.getElementById("lfmModalLayer");
    const modalClose = document.getElementById("lfmModalClose");
    const modalCancel = document.getElementById("lfmCancelEdit");
    const modalTitle = document.getElementById("lfmModalTitle");
    const editForm = document.getElementById("lfmEditForm");
    const editDate = document.getElementById("lfmEditDate");
    const editName = document.getElementById("lfmEditName");
    const editDisc = document.getElementById("lfmEditDisc");
    const editColor = document.getElementById("lfmEditColor");
    const editLast4 = document.getElementById("lfmEditLast4");
    const editPhone = document.getElementById("lfmEditPhone");
    const saveEditButton = document.getElementById("lfmSaveEdit");
    const secondaryEditAction = document.getElementById("lfmSecondaryEditAction");

    const state = {
      password: "",
      activeRecords: [],
      returnedRecords: [],
      returnedLoaded: false,
      returnedVisible: false,
      editing: null,
    };

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function setStatus(target, message, type = "") {
      if (!target) return;
      target.textContent = message || "";
      target.className = `lfm-status${type ? ` is-${type}` : ""}`;
    }

    function todayIso() {
      const now = new Date();
      const y = now.getFullYear();
      const m = String(now.getMonth() + 1).padStart(2, "0");
      const d = String(now.getDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    }

    function toSheetDate(value) {
      if (!value) return "";
      const match = String(value).match(/^(\d{4})-(\d{2})-(\d{2})$/);
      if (!match) return String(value);
      return `${Number(match[2])}/${Number(match[3])}/${match[1]}`;
    }

    function parseDisplayDate(value) {
      const text = String(value ?? "").trim();
      if (!text) return null;

      const mdy = text.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/);
      if (mdy) {
        let year = Number(mdy[3]);
        if (year < 100) year += 2000;
        const date = new Date(year, Number(mdy[1]) - 1, Number(mdy[2]));
        return Number.isNaN(date.getTime()) ? null : date;
      }

      const direct = new Date(text);
      return Number.isNaN(direct.getTime()) ? null : direct;
    }

    function toInputDate(value) {
      const parsed = parseDisplayDate(value);
      if (!parsed) return "";

      const y = parsed.getFullYear();
      const m = String(parsed.getMonth() + 1).padStart(2, "0");
      const d = String(parsed.getDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    }

    function sortDateValue(value) {
      const parsed = parseDisplayDate(value);
      return parsed ? parsed.getTime() : Number.MAX_SAFE_INTEGER;
    }

    function normalizePhone(value) {
      return String(value ?? "").replace(/[^\d+]/g, "");
    }

    function formatPhone(value) {
      return String(value ?? "").trim();
    }

    function getSmsHref(phone) {
      const cleaned = normalizePhone(phone);
      if (!cleaned) return "#";
      const separator = /iPad|iPhone|iPod/i.test(navigator.userAgent) ? "&" : "?";
      return `sms:${cleaned}${separator}body=${encodeURIComponent(messageText)}`;
    }

    function jsonp(params) {
      return new Promise((resolve, reject) => {
        const callbackName = `__lfm_cb_${Date.now()}_${Math.random().toString(36).slice(2)}`;
        const url = new URL(apiUrl);

        Object.entries(params || {}).forEach(([key, value]) => {
          if (value !== undefined && value !== null && String(value) !== "") {
            url.searchParams.set(key, String(value));
          }
        });

        url.searchParams.set("callback", callbackName);

        const script = document.createElement("script");
        const timeout = window.setTimeout(() => {
          cleanup();
          reject(new Error("Request timed out."));
        }, 15000);

        function cleanup() {
          window.clearTimeout(timeout);
          if (script.parentNode) script.parentNode.removeChild(script);
          try {
            delete window[callbackName];
          } catch {
            window[callbackName] = undefined;
          }
        }

        window[callbackName] = (payload) => {
          cleanup();
          resolve(payload);
        };

        script.onerror = () => {
          cleanup();
          reject(new Error("Unable to reach the manager service."));
        };

        script.src = url.toString();
        document.body.appendChild(script);
      });
    }

    function renderRows(target, rows, mode) {
      const sortedRows = [...rows].sort((a, b) => {
        const deadlineDiff = sortDateValue(a.deadline) - sortDateValue(b.deadline);
        if (deadlineDiff !== 0) return deadlineDiff;
        return sortDateValue(b.date) - sortDateValue(a.date);
      });

      if (!sortedRows.length) {
        target.innerHTML = `
          <tr>
            <td class="lfm-empty" colspan="5">${mode === "returned" ? "No returned discs found." : "No active discs found."}</td>
          </tr>
        `;
        return;
      }

      target.innerHTML = sortedRows
        .map((row) => {
          const hasPhone = String(row.phone ?? "").trim() !== "";
          const phoneHtml = hasPhone
            ? `<a class="lfm-phone-link" href="${escapeHtml(getSmsHref(row.phone))}">${escapeHtml(formatPhone(row.phone))}</a>`
            : "—";

          return `
            <tr>
              <td>${escapeHtml(row.name || "") || "&nbsp;"}</td>
              <td>${escapeHtml(row.disc || "") || "&nbsp;"}</td>
              <td>${escapeHtml(row.color || "") || "&nbsp;"}</td>
              <td>${phoneHtml}</td>
              <td>
                <div class="lfm-row-actions">
                  <button
                    class="lfm-button"
                    type="button"
                    data-edit-row="${Number(row.rowNumber)}"
                    data-mode="${mode}"
                  >
                    Edit
                  </button>
                </div>
              </td>
            </tr>
          `;
        })
        .join("");
    }

    function renderTables() {
      renderRows(inventoryBody, state.activeRecords, "active");
      renderRows(returnedBody, state.returnedRecords, "returned");
    }

    async function loadActiveInventory() {
      const payload = await jsonp({
        action: "list",
        password: state.password,
      });

      if (!payload?.ok) {
        throw new Error(payload?.error || "Unable to load inventory.");
      }

      state.activeRecords = Array.isArray(payload.records) ? payload.records : [];
      renderTables();
    }

    async function loadReturnedInventory() {
      const payload = await jsonp({
        action: "listReturned",
        password: state.password,
      });

      if (!payload?.ok) {
        throw new Error(payload?.error || "Unable to load returned discs.");
      }

      state.returnedRecords = Array.isArray(payload.records) ? payload.records : [];
      state.returnedLoaded = true;
      renderTables();
    }

    async function refreshAfterChange() {
      await loadActiveInventory();
      if (state.returnedVisible || state.returnedLoaded) {
        await loadReturnedInventory();
      }
    }

    async function unlock(password, { remember = true } = {}) {
      const trimmed = String(password || "");
      if (!trimmed) {
        throw new Error("Enter the manager password.");
      }

      state.password = trimmed;
      await loadActiveInventory();

      if (remember) {
        try {
          localStorage.setItem(PASSWORD_KEY, trimmed);
        } catch {}
      }

      loginCard.hidden = true;
      appWrap.hidden = false;
      setStatus(loginStatus, "");
      setStatus(
        appStatus,
        `${state.activeRecords.length} active disc${state.activeRecords.length === 1 ? "" : "s"} loaded.`,
        "success"
      );
    }

    function showLogin(message = "", type = "") {
      appWrap.hidden = true;
      loginCard.hidden = false;
      if (passwordInput) passwordInput.value = "";
      setStatus(loginStatus, message, type);
    }

    function getRecordByRow(rowNumber, mode) {
      const source = mode === "returned" ? state.returnedRecords : state.activeRecords;
      return source.find((row) => Number(row.rowNumber) === Number(rowNumber)) || null;
    }

    function openEditModal(row, mode) {
      if (!row) return;

      state.editing = {
        rowNumber: Number(row.rowNumber),
        mode,
      };

      modalTitle.textContent = mode === "returned" ? "Edit returned disc" : "Edit disc";
      editDate.value = toInputDate(row.date) || todayIso();
      editName.value = row.name || "";
      editDisc.value = row.disc || "";
      editColor.value = row.color || "";
      editLast4.value = row.last4 || "";
      editPhone.value = row.phone || "";

      if (mode === "returned") {
        secondaryEditAction.textContent = "Restore";
        secondaryEditAction.className = "lfm-button lfm-button-restore";
      } else {
        secondaryEditAction.textContent = "Mark returned";
        secondaryEditAction.className = "lfm-button lfm-button-danger";
      }

      modalLayer.hidden = false;
      document.body.style.overflow = "hidden";
      window.setTimeout(() => editDisc.focus(), 0);
    }

    function closeEditModal() {
      modalLayer.hidden = true;
      document.body.style.overflow = "";
      state.editing = null;
      editForm.reset();
    }

    function getEditPayload() {
      return {
        rowNumber: state.editing?.rowNumber,
        date: toSheetDate(editDate.value),
        name: editName.value,
        disc: editDisc.value,
        color: editColor.value,
        last4: editLast4.value,
        phone: editPhone.value,
      };
    }

    async function saveEdit(returnedOverride) {
      if (!state.editing) return;

      const payload = {
        action: "update",
        password: state.password,
        ...getEditPayload(),
      };

      if (returnedOverride === true) payload.returned = "true";
      if (returnedOverride === false) payload.returned = "false";

      const response = await jsonp(payload);

      if (!response?.ok) {
        throw new Error(response?.error || "Unable to save changes.");
      }

      await refreshAfterChange();
      closeEditModal();
    }

    unlockForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      try {
        setStatus(loginStatus, "Unlocking…");
        await unlock(passwordInput?.value || "");
      } catch (error) {
        try {
          localStorage.removeItem(PASSWORD_KEY);
        } catch {}
        state.password = "";
        showLogin(error?.message || "Unable to unlock.", "error");
      }
    });

    addForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const formData = new FormData(addForm);

      try {
        setStatus(appStatus, "Adding disc…");

        const payload = await jsonp({
          action: "add",
          password: state.password,
          date: toSheetDate(formData.get("date")),
          name: formData.get("name"),
          disc: formData.get("disc"),
          color: formData.get("color"),
          last4: formData.get("last4"),
          phone: formData.get("phone"),
        });

        if (!payload?.ok) {
          throw new Error(payload?.error || "Unable to add disc.");
        }

        addForm.reset();
        if (dateInput) dateInput.value = todayIso();
        await refreshAfterChange();
        setStatus(appStatus, "Disc added.", "success");
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to add disc.", "error");
      }
    });

    function handleEditClick(event, mode) {
      const button = event.target.closest("[data-edit-row]");
      if (!button) return;

      const rowNumber = Number(button.getAttribute("data-edit-row"));
      const row = getRecordByRow(rowNumber, mode);
      openEditModal(row, mode);
    }

    inventoryBody?.addEventListener("click", (event) => {
      handleEditClick(event, "active");
    });

    returnedBody?.addEventListener("click", (event) => {
      handleEditClick(event, "returned");
    });

    toggleReturnedButton?.addEventListener("click", async () => {
      state.returnedVisible = !state.returnedVisible;
      returnedSection.hidden = !state.returnedVisible;
      toggleReturnedButton.textContent = state.returnedVisible ? "Hide returned discs" : "View returned discs";

      if (state.returnedVisible && !state.returnedLoaded) {
        try {
          setStatus(appStatus, "Loading returned discs…");
          await loadReturnedInventory();
          setStatus(appStatus, "Returned discs loaded.", "success");
        } catch (error) {
          state.returnedVisible = false;
          returnedSection.hidden = true;
          toggleReturnedButton.textContent = "View returned discs";
          setStatus(appStatus, error?.message || "Unable to load returned discs.", "error");
        }
      }
    });

    saveEditButton?.addEventListener("click", async () => {
      try {
        setStatus(appStatus, "Saving changes…");
        await saveEdit(undefined);
        setStatus(appStatus, "Changes saved.", "success");
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to save changes.", "error");
      }
    });

    secondaryEditAction?.addEventListener("click", async () => {
      if (!state.editing) return;

      try {
        const makeReturned = state.editing.mode === "active";
        setStatus(appStatus, makeReturned ? "Saving and marking returned…" : "Saving and restoring…");
        await saveEdit(makeReturned ? true : false);
        setStatus(appStatus, makeReturned ? "Disc marked returned." : "Disc restored.", "success");
      } catch (error) {
        setStatus(appStatus, error?.message || "Unable to update disc.", "error");
      }
    });

    modalClose?.addEventListener("click", closeEditModal);
    modalCancel?.addEventListener("click", closeEditModal);
    modalLayer?.addEventListener("click", (event) => {
      if (event.target.closest("[data-close-modal]")) {
        closeEditModal();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !modalLayer.hidden) {
        closeEditModal();
      }
    });

    if (dateInput) {
      dateInput.value = todayIso();
    }

    try {
      const savedPassword = localStorage.getItem(PASSWORD_KEY);

      if (savedPassword) {
        unlock(savedPassword, { remember: false }).catch((error) => {
          try {
            localStorage.removeItem(PASSWORD_KEY);
          } catch {}
          state.password = "";
          showLogin(error?.message || "Unable to unlock.", "error");
        });
      } else {
        showLogin();
      }
    } catch {
      showLogin();
    }
  </script>
</SiteLayout>
