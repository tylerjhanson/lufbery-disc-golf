---
interface Props {
  title?: string;
  description?: string;
  showBrandBar?: boolean;
  noindex?: boolean;
}

const {
  title = "Lufbery Disc Golf",
  description = "Lufbery Disc Golf results, handicaps, course records, aces, and league information.",
  showBrandBar = true,
  noindex = false,
} = Astro.props;

const siteUrl = "https://lufberydiscgolf.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const logoUrl = "/logo.png";
const singlesLinks = [
  { href: "/singles/handicaps-tags", label: "Handicaps & Tags" },
  { href: "/singles/weekly-results", label: "Weekly Results" },
  { href: "/singles/weekly-winners", label: "Weekly Winners" },
  { href: "/singles/course-records", label: "Course Records" },
  { href: "/singles/aces", label: "Aces" },
  { href: "/singles/course-stats", label: "Course Stats" },
];
const doublesLinks = [
  { href: "/doubles/course-records", label: "Course Records" },
  { href: "/doubles/aces", label: "Aces" },
];
const bottomLinks = [
  { href: "/", label: "Home", icon: "⌂" },
  { href: "/singles/weekly-results", label: "Results", icon: "▦" },
  { href: "/singles/handicaps-tags", label: "Tags", icon: "#" },
  { href: "/singles/course-stats", label: "Stats", icon: "◌" },
  { href: "#siteMenuLayer", label: "More", icon: "•••", menu: true },
];

function isActiveBottomLink(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow"} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#eef2f7" />
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-TH1LXLH0MH"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-TH1LXLH0MH');
    </script>

    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem("lufbery-theme");
          const mode = saved === "light" || saved === "dark" || saved === "system" ? saved : "system";
          document.documentElement.setAttribute("data-theme", mode);
        } catch {
          document.documentElement.setAttribute("data-theme", "system");
        }
      })();
    </script>

    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f5f7fb;
        --bg-strong: #eef2f7;
        --bg-orb-one: rgba(96, 165, 250, 0.28);
        --bg-orb-two: rgba(248, 113, 113, 0.16);
        --card: rgba(255, 255, 255, 0.76);
        --card-solid: #ffffff;
        --glass: rgba(255, 255, 255, 0.68);
        --glass-strong: rgba(255, 255, 255, 0.88);
        --text: #101828;
        --muted: #667085;
        --line-soft: rgba(148, 163, 184, 0.24);
        --line: rgba(148, 163, 184, 0.36);
        --accent: #2563eb;
        --accent-soft: rgba(37, 99, 235, 0.12);
        --button-bg: rgba(255, 255, 255, 0.58);
        --button-bg-hover: rgba(255, 255, 255, 0.86);
        --shadow: 0 18px 46px rgba(15, 23, 42, 0.10);
        --shadow-strong: 0 26px 70px rgba(15, 23, 42, 0.18);
        --radius-card: 24px;
        --radius-panel: 30px;
        --radius-control: 999px;
        --safe-bottom: env(safe-area-inset-bottom, 0px);
        --ease-out: cubic-bezier(.2, .8, .2, 1);
        --motion-fast: 140ms;
        --motion-normal: 220ms;
      }

      html[data-theme="dark"] {
        color-scheme: dark;
        --bg: #080d18;
        --bg-strong: #101827;
        --bg-orb-one: rgba(59, 130, 246, 0.18);
        --bg-orb-two: rgba(248, 113, 113, 0.10);
        --card: rgba(15, 23, 42, 0.72);
        --card-solid: #0f172a;
        --glass: rgba(15, 23, 42, 0.68);
        --glass-strong: rgba(15, 23, 42, 0.88);
        --text: #f8fafc;
        --muted: #a6b3c5;
        --line-soft: rgba(148, 163, 184, 0.18);
        --line: rgba(148, 163, 184, 0.30);
        --accent: #7db7ff;
        --accent-soft: rgba(125, 183, 255, 0.14);
        --button-bg: rgba(30, 41, 59, 0.62);
        --button-bg-hover: rgba(51, 65, 85, 0.84);
        --shadow: 0 18px 46px rgba(0, 0, 0, 0.34);
        --shadow-strong: 0 26px 70px rgba(0, 0, 0, 0.48);
      }

      @media (prefers-color-scheme: dark) {
        html[data-theme="system"] {
          color-scheme: dark;
          --bg: #080d18;
          --bg-strong: #101827;
          --bg-orb-one: rgba(59, 130, 246, 0.18);
          --bg-orb-two: rgba(248, 113, 113, 0.10);
          --card: rgba(15, 23, 42, 0.72);
          --card-solid: #0f172a;
          --glass: rgba(15, 23, 42, 0.68);
          --glass-strong: rgba(15, 23, 42, 0.88);
          --text: #f8fafc;
          --muted: #a6b3c5;
          --line-soft: rgba(148, 163, 184, 0.18);
          --line: rgba(148, 163, 184, 0.30);
          --accent: #7db7ff;
          --accent-soft: rgba(125, 183, 255, 0.14);
          --button-bg: rgba(30, 41, 59, 0.62);
          --button-bg-hover: rgba(51, 65, 85, 0.84);
          --shadow: 0 18px 46px rgba(0, 0, 0, 0.34);
          --shadow-strong: 0 26px 70px rgba(0, 0, 0, 0.48);
        }
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      html { background: var(--bg-strong); scroll-behavior: smooth; }

      body {
        min-height: 100vh;
        margin: 0 !important;
        padding: 0 !important;
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro Display", "Segoe UI", system-ui, sans-serif;
        background:
          radial-gradient(circle at 18% -10%, var(--bg-orb-one), transparent 34rem),
          radial-gradient(circle at 92% 8%, var(--bg-orb-two), transparent 28rem),
          linear-gradient(180deg, var(--bg-strong) 0%, var(--bg) 48%, var(--bg-strong) 100%);
        color: var(--text);
        overflow-x: hidden;
        text-rendering: geometricPrecision;
        -webkit-font-smoothing: antialiased;
      }

      a { color: inherit; text-decoration: none; }
      button, input, select, textarea { font: inherit; }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 70;
        width: 100%;
        padding: max(10px, env(safe-area-inset-top, 0px)) 12px 8px;
        background: linear-gradient(180deg, rgba(245, 247, 251, 0.92), rgba(245, 247, 251, 0));
        border-bottom: 0;
      }

      html[data-theme="dark"] .site-header { background: linear-gradient(180deg, rgba(8, 13, 24, 0.92), rgba(8, 13, 24, 0)); }
      @media (prefers-color-scheme: dark) {
        html[data-theme="system"] .site-header { background: linear-gradient(180deg, rgba(8, 13, 24, 0.92), rgba(8, 13, 24, 0)); }
      }

      .site-header-inner {
        width: min(calc(100% - 0px), 1420px);
        margin: 0 auto;
        padding: 10px 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        border: 1px solid var(--line-soft);
        border-radius: var(--radius-control);
        background: var(--glass);
        box-shadow: 0 12px 36px rgba(15, 23, 42, 0.10), inset 0 1px 0 rgba(255, 255, 255, 0.42);
        backdrop-filter: blur(24px) saturate(1.35);
        -webkit-backdrop-filter: blur(24px) saturate(1.35);
      }

      .site-brand {
        display: inline-flex;
        align-items: center;
        justify-content: flex-start;
        gap: 12px;
        min-width: 0;
        flex: 1 1 auto;
        color: var(--text);
        padding-left: 4px;
      }

      .site-brand img {
        width: 38px;
        height: 38px;
        display: block;
        flex: 0 0 38px;
        border-radius: 12px;
        filter: drop-shadow(0 8px 14px rgba(15, 23, 42, 0.16));
      }

      .site-brand-text {
        font-size: clamp(1.02rem, 2.6vw, 1.18rem);
        font-weight: 760;
        line-height: 1.1;
        letter-spacing: -0.035em;
        white-space: nowrap;
      }

      .site-topbar-right {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 0 0 auto;
      }

      .site-icon-button {
        width: 40px;
        height: 40px;
        border: 1px solid var(--line-soft);
        background: var(--button-bg);
        color: var(--muted);
        border-radius: var(--radius-control);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.28);
        transition: transform var(--motion-fast) var(--ease-out), background var(--motion-fast) var(--ease-out), color var(--motion-fast) var(--ease-out), border-color var(--motion-fast) var(--ease-out);
      }

      .site-icon-button:hover,
      .site-icon-button:focus-visible {
        color: var(--text);
        background: var(--button-bg-hover);
        border-color: var(--line);
        transform: translateY(-1px);
        outline: none;
      }

      .site-icon-button svg {
        width: 18px;
        height: 18px;
        display: block;
      }

      .site-shell {
        width: min(100%, 1440px);
        margin: 0 auto;
        padding: 18px 16px 34px;
      }

      .site-content { min-width: 0; }

      .site-content .wrap {
        width: 100% !important;
        max-width: none !important;
        margin: 0 !important;
        padding: 0 !important;
        min-width: 0 !important;
      }

      .site-content h1 {
        font-size: clamp(1.72rem, 3vw, 2.42rem) !important;
        font-weight: 780 !important;
        line-height: 1.04 !important;
        letter-spacing: -0.045em !important;
      }

      .site-content h2,
      .site-content h3 {
        letter-spacing: -0.03em;
      }

      .site-content .page-header { margin-bottom: 14px !important; }

      .site-content .card,
      .site-content .utility-card,
      .site-content .result-table-wrap,
      .site-content .table-wrap,
      .site-content .calendar-link,
      .site-content .event-item,
      .site-content .link-item {
        border-color: var(--line-soft) !important;
      }

      .site-content .card,
      .site-content .utility-card {
        background: var(--card) !important;
        border-radius: var(--radius-card) !important;
        box-shadow: var(--shadow) !important;
        backdrop-filter: blur(20px) saturate(1.25);
        -webkit-backdrop-filter: blur(20px) saturate(1.25);
      }

      .site-content .link-item,
      .site-content .event-item,
      .site-content .calendar-link,
      .site-content .result-toggle,
      .site-content .result-view-full,
      .site-content button:not(.site-icon-button):not(.site-menu-close):not(.site-menu-summary),
      .site-content .filter-select,
      .site-content .search-input,
      .site-content input,
      .site-content select {
        border-radius: var(--radius-control) !important;
        border-color: var(--line-soft) !important;
        background: var(--button-bg) !important;
        color: var(--text) !important;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22);
      }

      .site-content .search-input,
      .site-content input[type="search"],
      .site-content input[type="text"] {
        min-height: 44px;
      }

      .site-content .filter-select,
      .site-content select,
      .site-content button,
      .site-content .result-toggle,
      .site-content .result-view-full {
        min-height: 42px;
      }

      .site-content .link-item:hover,
      .site-content .event-item:hover,
      .site-content .calendar-link:hover,
      .site-content .utility-card:hover,
      .site-content .result-toggle:hover,
      .site-content .result-view-full:hover {
        background: var(--button-bg-hover) !important;
        transform: translateY(-1px);
      }

      .site-content .card-header { padding: 20px 20px 12px !important; }
      .site-content .table-wrap { padding: 0 10px 10px !important; }

      .site-content table {
        border-radius: 18px;
        overflow: hidden;
      }

      .site-content thead th {
        padding: 10px 8px !important;
        font-size: 0.76rem !important;
        background: rgba(148, 163, 184, 0.10) !important;
        color: var(--muted) !important;
        border-bottom-color: var(--line-soft) !important;
      }

      .site-content tbody td {
        padding: 10px 8px !important;
        font-size: 0.95rem !important;
        border-bottom-color: var(--line-soft) !important;
      }

      .site-content tbody td:first-child { font-weight: 400 !important; }

      .site-menu-layer {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: none;
      }

      .site-menu-layer.open { display: block; }

      .site-menu-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(15, 23, 42, 0.20);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
      }

      .site-menu-panel {
        position: absolute;
        top: 78px;
        right: 16px;
        width: min(92vw, 330px);
        background: var(--glass-strong);
        border: 1px solid var(--line-soft);
        border-radius: var(--radius-panel);
        box-shadow: var(--shadow-strong);
        overflow: hidden;
        backdrop-filter: blur(28px) saturate(1.35);
        -webkit-backdrop-filter: blur(28px) saturate(1.35);
      }

      .site-menu-row {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: 12px 14px 8px;
        border-bottom: 1px solid var(--line-soft);
      }

      .site-menu-row-closeonly { min-height: 60px; }

      .site-menu-close {
        width: 40px;
        height: 40px;
        border: 1px solid var(--line-soft);
        background: var(--button-bg);
        color: var(--text);
        border-radius: var(--radius-control);
        cursor: pointer;
        font-size: 1.35rem;
        line-height: 1;
      }

      .site-menu-group { border-bottom: 1px solid var(--line-soft); }
      .site-menu-group:last-child { border-bottom: 0; }

      .site-menu-summary {
        width: 100%;
        background: none;
        border: 0;
        color: var(--text);
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 18px;
        font-size: 1rem;
        font-weight: 640;
        cursor: pointer;
        text-align: left;
      }

      .site-menu-summary:hover,
      .site-menu-link:hover,
      .site-submenu a:hover {
        background: var(--accent-soft);
      }

      .site-submenu {
        display: none;
        padding: 0 10px 12px;
        gap: 5px;
      }

      .site-menu-group.open .site-submenu { display: grid; }

      .site-submenu a {
        display: block;
        padding: 11px 13px;
        border-radius: 16px;
        color: var(--muted);
        font-size: 0.97rem;
        font-weight: 560;
      }

      .site-menu-link {
        display: block;
        padding: 15px 18px;
        font-size: 1rem;
        font-weight: 640;
      }

      .site-chev {
        width: 14px;
        height: 14px;
        transition: transform var(--motion-fast) var(--ease-out);
      }

      .site-menu-group.open .site-chev { transform: rotate(90deg); }

      .site-go-top {
        position: fixed;
        right: 18px;
        bottom: 18px;
        z-index: 90;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 46px;
        height: 46px;
        border-radius: var(--radius-control);
        border: 1px solid var(--line-soft);
        background: var(--glass-strong);
        color: var(--accent);
        box-shadow: var(--shadow);
        text-decoration: none;
        font-size: 1.2rem;
        font-weight: 800;
        line-height: 1;
        backdrop-filter: blur(18px) saturate(1.25);
        -webkit-backdrop-filter: blur(18px) saturate(1.25);
      }

      .site-go-top:hover,
      .site-go-top:focus-visible {
        background: var(--button-bg-hover);
        color: var(--text);
        text-decoration: none;
      }

      .site-bottom-nav {
        position: fixed;
        left: 50%;
        bottom: calc(10px + var(--safe-bottom));
        z-index: 95;
        display: none;
        width: min(calc(100vw - 20px), 430px);
        transform: translateX(-50%);
        padding: 7px;
        border: 1px solid var(--line-soft);
        border-radius: 28px;
        background: var(--glass-strong);
        box-shadow: var(--shadow-strong);
        backdrop-filter: blur(26px) saturate(1.35);
        -webkit-backdrop-filter: blur(26px) saturate(1.35);
      }

      .site-bottom-nav-list {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 4px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .site-bottom-nav-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 54px;
        gap: 3px;
        border: 0;
        border-radius: 22px;
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        font: inherit;
        text-align: center;
        transition: background var(--motion-fast) var(--ease-out), color var(--motion-fast) var(--ease-out), transform var(--motion-fast) var(--ease-out);
      }

      .site-bottom-nav-link:hover,
      .site-bottom-nav-link:focus-visible,
      .site-bottom-nav-link.active {
        background: var(--accent-soft);
        color: var(--text);
        outline: none;
      }

      .site-bottom-nav-link.active .site-bottom-nav-icon { color: var(--accent); }

      .site-bottom-nav-icon {
        font-size: 1.04rem;
        font-weight: 760;
        line-height: 1;
      }

      .site-bottom-nav-label {
        font-size: 0.68rem;
        font-weight: 680;
        letter-spacing: -0.01em;
      }

      @media (max-width: 700px) {
        .site-header { padding: max(8px, env(safe-area-inset-top, 0px)) 8px 6px; }
        .site-header-inner { padding: 8px 9px; }
        .site-shell { padding: 10px 8px calc(98px + var(--safe-bottom)); }
        .site-brand { gap: 10px; }
        .site-brand img { width: 31px; height: 31px; flex-basis: 31px; border-radius: 10px; }
        .site-brand-text { font-size: 1.04rem; }
        .site-icon-button { width: 38px; height: 38px; }
        .site-menu-panel {
          top: auto;
          right: 8px;
          left: 8px;
          bottom: calc(86px + var(--safe-bottom));
          width: auto;
          max-height: min(72vh, 560px);
          overflow: auto;
        }
        .site-go-top {
          right: 12px;
          bottom: calc(92px + var(--safe-bottom));
          width: 40px;
          height: 40px;
          font-size: 1.05rem;
        }
        .site-bottom-nav { display: block; }
        .site-content .card-header { padding: 16px 16px 9px !important; }
        .site-content .table-wrap { padding: 0 4px 6px !important; }
        .site-content thead th { padding: 8px 5px !important; font-size: 0.68rem !important; }
        .site-content tbody td { padding: 8px 5px !important; font-size: 0.86rem !important; }
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          scroll-behavior: auto !important;
          transition-duration: 0.001ms !important;
        }
      }
    </style>
  </head>

  <body>
    <div id="site-page-top"></div>

    {showBrandBar && (
      <header class="site-header">
        <div class="site-header-inner">
          <a class="site-brand" href="/" aria-label="Home">
            <img src={logoUrl} alt="Lufbery Disc Golf logo" />
            <span class="site-brand-text">Lufbery Disc Golf</span>
          </a>

          <div class="site-topbar-right">
            <button id="themeToggle" class="site-icon-button" type="button" aria-label="Theme mode"></button>
            <button
              id="menuButton"
              class="site-icon-button"
              type="button"
              aria-label="Open menu"
              aria-controls="siteMenuLayer"
              aria-expanded="false"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" aria-hidden="true">
                <path d="M4 7h16"></path>
                <path d="M4 12h16"></path>
                <path d="M4 17h16"></path>
              </svg>
            </button>
          </div>
        </div>
      </header>
    )}

    <div class="site-shell">
      <main class="site-content">
        <slot />
      </main>
    </div>

    <aside id="siteMenuLayer" class="site-menu-layer" aria-hidden="true">
      <div class="site-menu-backdrop" data-close-menu></div>
      <div class="site-menu-panel" role="dialog" aria-modal="true" aria-label="Site menu">
        <div class="site-menu-row site-menu-row-closeonly">
          <button class="site-menu-close" type="button" aria-label="Close menu" data-close-menu>×</button>
        </div>

        <div class="site-menu-group" data-menu-group>
          <button class="site-menu-summary" type="button">
            <span>Singles</span>
            <svg class="site-chev" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 3l5 5-5 5"></path>
            </svg>
          </button>
          <nav class="site-submenu">
            {singlesLinks.map((item) => <a href={item.href}>{item.label}</a>)}
          </nav>
        </div>

        <div class="site-menu-group" data-menu-group>
          <button class="site-menu-summary" type="button">
            <span>Doubles</span>
            <svg class="site-chev" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 3l5 5-5 5"></path>
            </svg>
          </button>
          <nav class="site-submenu">
            {doublesLinks.map((item) => <a href={item.href}>{item.label}</a>)}
          </nav>
        </div>

        <a class="site-menu-link" href="/lost-and-found">Lost &amp; Found</a>
        <a class="site-menu-link" href="https://udisc.com/leagues/lufbery-league" target="_blank" rel="noopener">Lufbery on UDisc</a>
      </div>
    </aside>

    {showBrandBar && (
      <nav class="site-bottom-nav" aria-label="Primary mobile navigation">
        <ul class="site-bottom-nav-list">
          {bottomLinks.map((item) => (
            <li>
              {item.menu ? (
                <button class="site-bottom-nav-link" type="button" data-open-menu aria-label="Open more navigation">
                  <span class="site-bottom-nav-icon" aria-hidden="true">{item.icon}</span>
                  <span class="site-bottom-nav-label">{item.label}</span>
                </button>
              ) : (
                <a class={`site-bottom-nav-link${isActiveBottomLink(item.href) ? " active" : ""}`} href={item.href} aria-current={isActiveBottomLink(item.href) ? "page" : undefined}>
                  <span class="site-bottom-nav-icon" aria-hidden="true">{item.icon}</span>
                  <span class="site-bottom-nav-label">{item.label}</span>
                </a>
              )}
            </li>
          ))}
        </ul>
      </nav>
    )}

    <a class="site-go-top" href="#site-page-top" aria-label="Go to top" title="Go to top">↑</a>

    <script>
      function decorateExternalLink(link) {
        if (!(link instanceof HTMLAnchorElement)) return;

        const href = (link.getAttribute("href") || "").trim();
        if (!href) return;
        if (
          href.startsWith("#") ||
          href.startsWith("/") ||
          href.startsWith("mailto:") ||
          href.startsWith("tel:") ||
          href.startsWith("sms:") ||
          href.startsWith("javascript:")
        ) {
          return;
        }

        try {
          const url = new URL(href, window.location.href);
          if (url.origin === window.location.origin) return;

          link.setAttribute("target", "_blank");

          const relValues = new Set(
            (link.getAttribute("rel") || "")
              .split(/\s+/)
              .map((value) => value.trim())
              .filter(Boolean)
          );
          relValues.add("noopener");
          relValues.add("noreferrer");
          link.setAttribute("rel", Array.from(relValues).join(" "));
        } catch {
          // Ignore invalid URLs.
        }
      }

      function decorateExternalLinks(root = document) {
        if (root instanceof HTMLAnchorElement) {
          decorateExternalLink(root);
          return;
        }

        if (!(root instanceof Document || root instanceof Element)) return;

        root.querySelectorAll("a[href]").forEach((link) => {
          decorateExternalLink(link);
        });
      }

      const html = document.documentElement;
      const themeToggle = document.getElementById("themeToggle");
      const themeModes = ["system", "light", "dark"];

      function themeIcon(mode) {
        if (mode === "light") {
          return `
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4.2"></circle>
          <path d="M12 2v2.5M12 19.5V22M4.93 4.93l1.77 1.77M17.3 17.3l1.77 1.77M2 12h2.5M19.5 12H22M4.93 19.07l1.77-1.77M17.3 6.7l1.77-1.77"></path>
        </svg>
      `;
        }

        if (mode === "dark") {
          return `
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.4 14.7A8.5 8.5 0 0 1 9.3 3.6a.7.7 0 0 0-.9-.9A10 10 0 1 0 21.3 15.6a.7.7 0 0 0-.9-.9Z"></path>
        </svg>
      `;
        }

        return `
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="12" rx="2"></rect>
        <path d="M8 20h8"></path>
        <path d="M12 16v4"></path>
      </svg>
    `;
      }

      function getSavedTheme() {
        try {
          const saved = localStorage.getItem("lufbery-theme");
          return themeModes.includes(saved) ? saved : "system";
        } catch {
          return "system";
        }
      }

      function saveTheme(mode) {
        try {
          localStorage.setItem("lufbery-theme", mode);
        } catch {}
      }

      function applyTheme(mode) {
        html.setAttribute("data-theme", mode);

        if (themeToggle) {
          themeToggle.innerHTML = themeIcon(mode);
          themeToggle.setAttribute("aria-label", `Theme mode: ${mode}`);
          themeToggle.title = `Theme: ${mode}`;
        }
      }

      let savedTheme = getSavedTheme();
      applyTheme(savedTheme);

      if (themeToggle) {
        themeToggle.addEventListener("click", () => {
          const index = themeModes.indexOf(savedTheme);
          savedTheme = themeModes[(index + 1) % themeModes.length];
          saveTheme(savedTheme);
          applyTheme(savedTheme);
        });
      }

      const menuButton = document.getElementById("menuButton");
      const menuLayer = document.getElementById("siteMenuLayer");
      const closeMenuButtons = menuLayer?.querySelectorAll("[data-close-menu]") || [];
      const openMenuButtons = document.querySelectorAll("[data-open-menu]");
      const menuGroups = menuLayer?.querySelectorAll("[data-menu-group]") || [];

      function openMenu() {
        menuLayer?.classList.add("open");
        menuLayer?.setAttribute("aria-hidden", "false");
        menuButton?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
      }

      function closeMenu() {
        menuLayer?.classList.remove("open");
        menuLayer?.setAttribute("aria-hidden", "true");
        menuButton?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      }

      menuButton?.addEventListener("click", () => {
        if (menuLayer?.classList.contains("open")) closeMenu();
        else openMenu();
      });

      openMenuButtons.forEach((button) => button.addEventListener("click", openMenu));
      closeMenuButtons.forEach((button) => button.addEventListener("click", closeMenu));
      menuLayer?.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeMenu));

      menuGroups.forEach((group) => {
        const button = group.querySelector(".site-menu-summary");
        button?.addEventListener("click", () => {
          const isOpen = group.classList.contains("open");
          menuGroups.forEach((g) => g.classList.remove("open"));
          if (!isOpen) group.classList.add("open");
        });
      });

      decorateExternalLinks(document);

      const externalLinksObserver = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          mutation.addedNodes.forEach((node) => {
            if (node instanceof Element) {
              decorateExternalLinks(node);
            }
          });
        });
      });

      if (document.body) {
        externalLinksObserver.observe(document.body, {
          childList: true,
          subtree: true,
        });
      }

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeMenu();
      });
    </script>
  </body>
</html>
